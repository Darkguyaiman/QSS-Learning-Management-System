<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="icon" type="image/x-icon" href="/favicon.ico">
  <link rel="shortcut icon" type="image/x-icon" href="/favicon.ico">
  <link rel="icon" type="image/x-icon" href="/QSS.ico">
  <title><%= typeof pageTitle !== 'undefined' ? pageTitle + ' - ' : '' %>Learning Management System</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="/css/tailwind.output.css">
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body class="<%= typeof user !== 'undefined' && user.userId && ['admin', 'trainer'].includes(user.userRole) ? 'has-sidebar' : 'has-navbar' %>">
  <% if (typeof user !== 'undefined' && user.userId) { %>
    <% if (['admin', 'trainer'].includes(user.userRole)) { %>
      <%- include('partials/sidebar', { user }) %>
    <% } else { %>
      <%- include('partials/navbar', { user }) %>
    <% } %>
  <% } %>
  
  <main class="main-content">
    <%- body %>
  </main>
  
  <script src="/js/tw-components.js"></script>
  <script src="/js/main.js"></script>
</body>
</html>
