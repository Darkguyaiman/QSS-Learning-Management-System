        padding-right: 1rem;
      }
      
      .dashboard-header h1 {
        font-size: 1.25rem;
        line-height: 1.3;
        margin-bottom: 0.375rem;
      }
      
      .dashboard-header .welcome-message {
        font-size: 0.875rem;
        margin-bottom: 0;
      }
      
      .dashboard-header .welcome-message .user-name {
        font-weight: 500;
      }
      
      .dashboard-section {
        padding: 1rem !important;
        border-radius: 12px;
      }
      
      .dashboard-section h2 {
        font-size: 1rem;
        flex-wrap: wrap;
        gap: 0.5rem;
      }
      
      .dashboard-section h2::before {
        height: 20px;
      }
      
      .stats-grid {
        gap: 0.75rem;
      }
      
      .stat-card {
        padding: 1rem 0.75rem;
      }
      
      .stat-card h3 {
        font-size: 1.75rem;
      }
      
      .stat-card p {
        font-size: 0.6875rem;
      }
      
      .trainer-card {
        padding: 1rem;
      }
      
      .trainer-avatar {
        width: 50px;
        height: 50px;
        font-size: 1.25rem;
        margin-bottom: 0.75rem;
      }
      
      .trainer-name {
        font-size: 0.9375rem;
      }
      
      .trainer-role {
        font-size: 0.75rem;
      }
      
      .trainer-stat-value {
        font-size: 1.125rem;
      }
      
      .trainer-stat-label {
        font-size: 0.625rem;
      }
      
      .table-card {
        padding: 0.875rem;
        margin-bottom: 0.75rem;
      }
      
      .table-card-header {
        margin-bottom: 0.875rem;
        padding-bottom: 0.75rem;
      }
      
      .table-card-title {
        font-size: 0.9375rem;
        line-height: 1.4;
      }
      
      .table-card-row {
        gap: 0.25rem;
        margin-bottom: 0.5rem;
      }
      
      .table-card-label {
        font-size: 0.5625rem;
        letter-spacing: 0.3px;
      }
      
      .table-card-value {
        font-size: 0.75rem;
        line-height: 1.5;
      }
      
      .chip-container {
        gap: 0.375rem;
      }
      
      .chip {
        font-size: 0.5625rem;
        padding: 0.15rem 0.4rem;
        border-radius: 8px;
      }
      
      .status-badge {
        font-size: 0.5625rem;
        padding: 0.2rem 0.4rem;
        border-radius: 12px;
      }
      
      .badge {
        font-size: 0.625rem;
        padding: 0.25rem 0.5rem;
      }
      
      .btn {
        font-size: 0.8125rem;
        padding: 0.5rem 0.75rem;
      }
      
      .btn-sm {
        font-size: 0.75rem;
        padding: 0.375rem 0.625rem;
      }
      
      .quick-actions h2 {
        font-size: 1rem;
      }
      
      .action-card {
        padding: 1rem;
      }
      
      .action-card h3 {
        font-size: 1rem;
      }
      
      .action-card p {
        font-size: 0.8125rem;
      }
      
      /* Recent Trainings header adjustments */
      .recent-trainings-header h3 {
        font-size: 1rem !important;
      }
      
      .recent-trainings-header h3 i {
        font-size: 0.875rem;
        margin-right: 0.375rem;
      }
      
      .recent-trainings-subtitle {
        font-size: 0.75rem !important;
      }
      
      /* Better spacing for very small screens */
      .table-card-grid {
        gap: 0.75rem;
      }
      
      .table-card-body {
        gap: 0.625rem;
      }
    }
    
    /* Responsive for action cards */
    @media (max-width: 768px) {
      .action-cards {
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 1rem;
      }
    }
    
    /* Table card styles for mobile/tablet */
    .table-card {
      display: none;
      background: linear-gradient(135deg, #ffffff 0%, #f8f9fa 100%);
      border-radius: 12px;
      padding: 1.5rem;
      margin-bottom: 1rem;
      box-shadow: 0 2px 8px rgba(0,0,0,0.08);
      border: 1px solid #E8EAED;
      transition: all 0.3s ease;
    }
    
    .table-card:hover {
      box-shadow: 0 4px 16px rgba(87, 63, 215, 0.1);
      border-color: #573FD7;
    }
    
    .table-card-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      margin-bottom: 1.25rem;
      padding-bottom: 1rem;
      border-bottom: 2px solid #E8EAED;
    }
    
    .table-card-title {
      font-size: 1.125rem;
      font-weight: 600;
      color: #202124;
      margin: 0;
      flex: 1;
    }
    
    .table-card-body {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }
    
    .table-card-row {
      display: flex;
      flex-direction: column;
      gap: 0.25rem;
    }
    
    .table-card-label {
      font-size: 0.75rem;
      font-weight: 600;
      color: #5F6368;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
    
    .table-card-value {
      font-size: 0.875rem;
      color: #202124;
      word-break: break-word;
    }
    
    .table-card-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 1rem;
    }
    
    /* Hide tables on mobile/tablet, show cards */
    @media (max-width: 1024px) {
      .data-table {
        display: none;
      }
      
      .table-card {
        display: block;
      }
      
      .table-responsive {
        overflow: visible;
      }

      .client-chart-layout {
        grid-template-columns: 1fr;
      }

      .client-chart-summary {
        border-left: none;
        border-top: 1px solid #E8EAED;
        padding-left: 0;
        padding-top: 1rem;
      }

      .client-chart-canvas-wrap {
        height: 400px;
      }
    }
    
    /* Show tables on desktop, hide cards */
    @media (min-width: 1025px) {
      .table-card {
        display: none;
      }
      
      .data-table {
        display: table;
      }
    }
  </style>
</head>
<body class="has-sidebar">
  <%- include('../partials/sidebar', { user }) %>
  <%
    const activeDashboardDateRange = dashboardDateRange || {};
    const dateRangeLabel = activeDashboardDateRange.preset === 'all_time'
      ? 'All time'
      : activeDashboardDateRange.startDate && activeDashboardDateRange.endDate
      ? `${new Date(activeDashboardDateRange.startDate + 'T00:00:00').toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })} - ${new Date(activeDashboardDateRange.endDate + 'T00:00:00').toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}`
      : 'This month';
    const dashboardPdfUrl = activeDashboardDateRange.preset === 'all_time'
      ? '/dashboard/pdf?preset=all_time'
      : `/dashboard/pdf?preset=${encodeURIComponent(activeDashboardDateRange.preset || 'this_month')}${activeDashboardDateRange.startDate && activeDashboardDateRange.endDate ? `&startDate=${encodeURIComponent(activeDashboardDateRange.startDate)}&endDate=${encodeURIComponent(activeDashboardDateRange.endDate)}` : ''}`;
  %>
  
  <main class="main-content">
    <div class="container">
      <div class="dashboard-header">
        <div class="dashboard-header-content">
          <h1>
            <%= isAdmin ? 'Admin Dashboard' : 'Dashboard' %>
          </h1>
          <p class="welcome-message">
            Welcome back, <span class="user-name"><%= user.userName %></span>!
          </p>
        </div>
        <div class="dashboard-header-actions">
          <button type="button" class="date-range-trigger" id="date-range-open" aria-haspopup="dialog" aria-controls="date-range-panel">
            <i class="fas fa-calendar-alt"></i>
            <span id="date-range-trigger-label"><%= dateRangeLabel %></span>
          </button>
          <a href="<%= dashboardPdfUrl %>" class="btn btn-primary">
            <i class="fas fa-file-pdf"></i> Download PDF
          </a>
          <a href="/training/create" class="btn btn-primary">Create Training</a>
        </div>
      </div>

      <div class="date-range-overlay" id="date-range-overlay" hidden></div>
      <aside class="date-range-panel" id="date-range-panel" role="dialog" aria-modal="true" aria-labelledby="date-range-title" hidden>
        <div class="date-range-panel-header">
          <button type="button" class="date-range-close" id="date-range-close" aria-label="Close date range panel">
            <i class="fas fa-chevron-left"></i>
          </button>
          <h2 class="date-range-panel-title" id="date-range-title">Date range</h2>
        </div>

        <div class="date-range-panel-body">
          <div class="date-range-presets" id="date-range-presets">
            <label class="date-range-option"><input type="radio" name="dashboardPreset" value="all_time"> All time</label>
            <label class="date-range-option"><input type="radio" name="dashboardPreset" value="today"> Today</label>
            <label class="date-range-option"><input type="radio" name="dashboardPreset" value="yesterday"> Yesterday</label>
            <label class="date-range-option"><input type="radio" name="dashboardPreset" value="last_7_days"> Last 7 days</label>
            <label class="date-range-option"><input type="radio" name="dashboardPreset" value="last_14_days"> Last 14 days</label>
            <label class="date-range-option"><input type="radio" name="dashboardPreset" value="last_28_days"> Last 28 days</label>
            <label class="date-range-option"><input type="radio" name="dashboardPreset" value="last_30_days"> Last 30 days</label>
            <label class="date-range-option"><input type="radio" name="dashboardPreset" value="this_week"> This week</label>
            <label class="date-range-option"><input type="radio" name="dashboardPreset" value="last_week"> Last week</label>
            <label class="date-range-option"><input type="radio" name="dashboardPreset" value="this_month"> This month</label>
            <label class="date-range-option"><input type="radio" name="dashboardPreset" value="last_month"> Last month</label>
            <label class="date-range-option"><input type="radio" name="dashboardPreset" value="custom"> Custom</label>
          </div>

          <div class="date-range-workspace">
            <div class="date-range-toolbar">
              <button type="button" class="date-range-soft-btn" id="date-range-clear">Clear</button>
              <button type="button" class="date-range-soft-btn" id="date-range-today">Today</button>
              <button type="button" class="date-range-icon-btn" id="date-range-prev-month" aria-label="Previous month">
                <i class="fas fa-chevron-left"></i>
              </button>
              <button type="button" class="date-range-icon-btn" id="date-range-next-month" aria-label="Next month">
                <i class="fas fa-chevron-right"></i>
              </button>
            </div>

            <div class="date-range-calendars" id="date-range-calendars"></div>

            <div class="date-input-row">
              <button type="button" class="date-display-trigger is-active" id="panel-start-date-btn" data-boundary="start">
                <span class="date-display-value" id="panel-start-date-value"></span>
                <i class="far fa-calendar"></i>
              </button>
              <button type="button" class="date-display-trigger" id="panel-end-date-btn" data-boundary="end">
                <span class="date-display-value" id="panel-end-date-value"></span>
                <i class="far fa-calendar"></i>
              </button>
            </div>
            <p class="date-range-helper" id="date-range-helper">Pick a start date, then an end date from the calendar.</p>
          </div>
        </div>

        <div class="date-range-panel-footer">
          <button type="button" class="btn btn-outline" id="date-range-cancel">Cancel</button>
          <button type="button" class="btn btn-primary" id="date-range-apply">Filter</button>
        </div>
      </aside>
      
      <!-- Quick Actions -->
      <div class="quick-actions dashboard-section" style="margin-bottom: 2rem;">
        <h2><i class="fas fa-bolt" style="color: #573FD7;"></i> Quick Actions</h2>
        <div class="action-cards">
          <a href="/training" class="action-card">
            <div class="card-image">
              <img src="/images/Dashboard Images/Trainings.webp" alt="Trainings">
            </div>
            <div class="card-content">
              <h3>Manage Trainings</h3>
              <p>View and manage all training programs</p>
            </div>
          </a>
          
          <a href="/trainees" class="action-card">
            <div class="card-image">
              <img src="/images/Dashboard Images/Trainees.webp" alt="Trainees">
            </div>
            <div class="card-content">
              <h3>Trainees</h3>
              <p>View and manage all trainees</p>
            </div>
          </a>
          
          <a href="/questions" class="action-card">
            <div class="card-image">
              <img src="/images/Dashboard Images/Questions.webp" alt="Questions">
            </div>
            <div class="card-content">
              <h3>Questions</h3>
              <p>Manage training questions and answers</p>
            </div>
          </a>
        </div>
      </div>
      
      <!-- Trainings Section -->
      <section class="dashboard-section">
        <h2><i class="fas fa-graduation-cap" style="color: #573FD7;"></i> Trainings</h2>
        
        <div class="stats-grid">
          <div class="stat-card">
            <h3><%= trainingStats.total %></h3>
            <p>Total Trainings</p>
          </div>
          <div class="stat-card">
            <h3><%= trainingStats.in_progress ?? 0 %></h3>
            <p>In Progress</p>
          </div>
          <div class="stat-card">
            <h3><%= trainingStats.completed ?? 0 %></h3>
            <p>Completed</p>
          </div>
          <div class="stat-card">
            <h3><%= trainingStats.canceled ?? 0 %></h3>
            <p>Canceled</p>
          </div>
          <div class="stat-card">
            <h3><%= trainingStats.rescheduled ?? 0 %></h3>
            <p>Rescheduled</p>
          </div>
          <div class="stat-card">
            <h3><%= trainingStats.course_completion_rate ?? 0 %>%</h3>
            <p>Course Completion Rate</p>
          </div>
          <div class="stat-card">
            <h3><%= trainingStats.assessment_pass_rate ?? 0 %>%</h3>
            <p>Assessment Pass Rate</p>
          </div>
        </div>
        
        <div class="recent-trainings-header" style="margin-bottom: 1.5rem; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 0.75rem;">
          <h3 style="margin: 0; color: #202124; font-size: 1.25rem; font-weight: 600;">
            <i class="fas fa-clock" style="color: #573FD7; margin-right: 0.5rem;"></i>
            Recent Trainings
          </h3>
          <span class="recent-trainings-subtitle" style="color: #5F6368; font-size: 0.875rem;">
            Showing latest 10 trainings
          </span>
        </div>
        
        <div class="table-responsive">
          <!-- Desktop Table View -->
          <table class="data-table">
            <thead>
              <tr>
                <th>Training Title</th>
                <th>Training Type</th>
                <th>Start Date & Time</th>
                <th>End Date & Time</th>
                <th>Participating Healthcare Centres</th>
                <th>Device Serial Numbers</th>
                <th>Status</th>
              </tr>
            </thead>
            <tbody>
              <% if (recentTrainings.length === 0) { %>
                <tr>
                  <td colspan="7" style="text-align: center; padding: 2rem; color: #5F6368;">
                    No trainings found
                  </td>
                </tr>
              <% } else { %>
                <% recentTrainings.forEach(training => { %>
                  <tr>
                    <td><strong><%= training.title %></strong></td>
                    <td>
                      <span class="badge badge-<%= training.type %>">
                        Main
                      </span>
                    </td>
                    <td>
                      <%= training.start_datetime 
                        ? new Date(training.start_datetime).toLocaleString('en-US', { 
                            year: 'numeric', 
                            month: 'short', 
                            day: 'numeric', 
                            hour: '2-digit', 
                            minute: '2-digit' 
                          })
                        : '-' %>
                    </td>
                    <td>
                      <%= training.end_datetime 
                        ? new Date(training.end_datetime).toLocaleString('en-US', { 
                            year: 'numeric', 
                            month: 'short', 
                            day: 'numeric', 
                            hour: '2-digit', 
                            minute: '2-digit' 
                          })
                        : '-' %>
                    </td>
                    <td>
                      <% if (training.healthcare_centres) { %>
                        <div class="chip-container">
                          <% training.healthcare_centres.split(', ').forEach(hc => { %>
                            <span class="chip chip-healthcare"><%= hc %></span>
                          <% }); %>
                        </div>
                      <% } else { %>
                        <span style="color: #9CA3AF;">-</span>
                      <% } %>
                    </td>
                    <td>
                      <% if (training.device_serial_numbers) { %>
                        <div class="chip-container">
                          <% training.device_serial_numbers.split(', ').forEach(device => { %>
                            <span class="chip chip-device"><%= device %></span>
                          <% }); %>
                        </div>
                      <% } else { %>
                        <span style="color: #9CA3AF;">-</span>
                      <% } %>
                    </td>
                    <td>
                      <% 
                        const statusLabels = {
                          'in_progress': 'In Progress',
                          'completed': 'Completed',
                          'canceled': 'Canceled',
                          'rescheduled': 'Rescheduled'
                        };
                        const statusClass = `status-${training.status.replace('_', '-')}`;
                      %>
                      <span class="status-badge <%= statusClass %>">
                        <%= statusLabels[training.status] || training.status.replace('_', ' ').replace(/\b\w/g, l => l.toUpperCase()) %>
                      </span>
                    </td>
                  </tr>
                <% }); %>
              <% } %>
            </tbody>
          </table>
          
          <!-- Mobile/Tablet Card View -->
          <div class="table-card-grid">
            <% if (recentTrainings.length === 0) { %>
              <div class="table-card" style="text-align: center; padding: 2rem; color: #5F6368;">
                No trainings found
              </div>
            <% } else { %>
              <% recentTrainings.forEach(training => { %>
                <% 
                  const statusLabels = {
                    'in_progress': 'In Progress',
                    'completed': 'Completed',
                    'canceled': 'Canceled',
                    'rescheduled': 'Rescheduled'
                  };
                  const statusClass = `status-${training.status.replace('_', '-')}`;
                %>
                <div class="table-card">
                  <div class="table-card-header">
                    <h3 class="table-card-title"><%= training.title %></h3>
                    <span class="status-badge <%= statusClass %>">
                      <%= statusLabels[training.status] || training.status.replace('_', ' ').replace(/\b\w/g, l => l.toUpperCase()) %>
                    </span>
                  </div>
                  <div class="table-card-body">
                    <div class="table-card-row">
                      <div class="table-card-label">Training Type</div>
                      <div class="table-card-value">
                        <span class="badge badge-<%= training.type %>">
                          Main
                        </span>
                      </div>
                    </div>
                    <div class="table-card-row">
                      <div class="table-card-label">Start Date & Time</div>
                      <div class="table-card-value">
                        <%= training.start_datetime 
                          ? new Date(training.start_datetime).toLocaleString('en-US', { 
                              year: 'numeric', 
                              month: 'short', 
                              day: 'numeric', 
                              hour: '2-digit', 
                              minute: '2-digit' 
                            })
                          : '-' %>
                      </div>
                    </div>
                    <div class="table-card-row">
                      <div class="table-card-label">End Date & Time</div>
                      <div class="table-card-value">
                        <%= training.end_datetime 
                          ? new Date(training.end_datetime).toLocaleString('en-US', { 
                              year: 'numeric', 
                              month: 'short', 
                              day: 'numeric', 
                              hour: '2-digit', 
                              minute: '2-digit' 
                            })
                          : '-' %>
                      </div>
                    </div>
                    <div class="table-card-row">
                      <div class="table-card-label">Participating Healthcare Centres</div>
                      <div class="table-card-value">
                        <% if (training.healthcare_centres) { %>
                          <div class="chip-container">
                            <% training.healthcare_centres.split(', ').forEach(hc => { %>
                              <span class="chip chip-healthcare"><%= hc %></span>
                            <% }); %>
                          </div>
                        <% } else { %>
                          <span style="color: #9CA3AF;">-</span>
                        <% } %>
                      </div>
                    </div>
                    <div class="table-card-row">
                      <div class="table-card-label">Device Serial Numbers</div>
                      <div class="table-card-value">
                        <% if (training.device_serial_numbers) { %>
                          <div class="chip-container">
                            <% training.device_serial_numbers.split(', ').forEach(device => { %>
                              <span class="chip chip-device"><%= device %></span>
                            <% }); %>
                          </div>
                        <% } else { %>
                          <span style="color: #9CA3AF;">-</span>
                        <% } %>
                      </div>
                    </div>
                  </div>
                </div>
              <% }); %>
            <% } %>
          </div>
        </div>
      </section>

      <!-- Top Clients Chart -->
      <section class="dashboard-section">
        <h2><i class="fas fa-chart-bar" style="color: #573FD7;"></i> Top Clients by Trainings</h2>
        <p style="color:#5F6368; margin: -0.5rem 0 1.25rem 0;">Top 20 healthcare clients by number of trainings in the selected date range.</p>

        <% if (!topClientTrainings || topClientTrainings.length === 0) { %>
          <div class="empty-state">
            <p>No client training data found for this date range.</p>
          </div>
        <% } else { %>
          <div class="client-chart-layout">
            <div class="client-chart-canvas-wrap">
              <canvas id="top-clients-chart" aria-label="Top clients by trainings chart" role="img"></canvas>
            </div>
            <div class="client-chart-summary" aria-label="Top clients by training count">
              <% topClientTrainings.slice(0, 5).forEach(client => { %>
                <div class="client-chart-summary-item">
                  <span class="client-chart-summary-name" title="<%= client.name %>"><%= client.name %></span>
                  <span class="client-chart-summary-count"><%= client.training_count %></span>
                </div>
              <% }); %>
            </div>
          </div>
        <% } %>
      </section>

      <!-- Healthcare Training Reminders -->
      <section class="dashboard-section">
        <h2><i class="fas fa-hospital-user" style="color: #573FD7;"></i> Healthcare Training Reminders</h2>
        <p style="color:#5F6368; margin: -0.5rem 0 1.25rem 0;">Healthcare reminders due within 60 days</p>

        <% if (!healthcareTrainingReminders || healthcareTrainingReminders.length === 0) { %>
          <div class="empty-state">
            <p>No upcoming healthcare training reminders.</p>
          </div>
        <% } else { %>
          <div class="table-responsive">
            <table class="recert-table">
              <thead>
                <tr>
                  <th>Healthcare</th>
                  <th>Hospital Address</th>
                  <th>Reminder</th>
                  <th>Reminder Date</th>
                  <th>Days Left</th>
                  <th>Status</th>
                </tr>
              </thead>
              <tbody>
                <% healthcareTrainingReminders.forEach(reminder => { %>
                  <%
                    const daysLeft = reminder.days_remaining;
                    const badgeClass = (daysLeft !== null && daysLeft <= 30)
                      ? 'recert-badge--urgent'
                      : 'recert-badge--warn';
                    const badgeText = (daysLeft !== null && daysLeft <= 30)
                      ? 'Urgent'
                      : 'Upcoming';
                    const reminderLabelMap = {
                      '6_months': '6 Months',
                      '1_year': '1 Year',
                      '2_years': '2 Years',
                      '3_years': '3 Years'
                    };
                  %>
                  <tr>
                    <td><strong><%= reminder.name %></strong></td>
                    <td><%= reminder.hospital_address || '-' %></td>
                    <td><%= reminderLabelMap[reminder.training_reminder_interval] || 'Custom' %></td>
                    <td>
                      <% if (reminder.training_reminder_due_date) { %>
                        <%
                          const reminderDateValue = reminder.training_reminder_due_date instanceof Date
                            ? `${reminder.training_reminder_due_date.getFullYear()}-${String(reminder.training_reminder_due_date.getMonth() + 1).padStart(2, '0')}-${String(reminder.training_reminder_due_date.getDate()).padStart(2, '0')}`
                            : String(reminder.training_reminder_due_date).slice(0, 10);
                        %>
                        <%= reminderDateValue %>
                      <% } else { %>
                        -
                      <% } %>
                    </td>
                    <td><%= daysLeft %> days</td>
                    <td><span class="recert-badge <%= badgeClass %>"><%= badgeText %></span></td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        <% } %>
      </section>

      <!-- Upcoming Recertifications -->
      <section class="dashboard-section">
        <h2><i class="fas fa-bell" style="color: #573FD7;"></i> Upcoming Recertifications</h2>
        <p style="color:#5F6368; margin: -0.5rem 0 1.25rem 0;">Certificates expiring within 60 days</p>

        <% if (!recertificationsByHospital || recertificationsByHospital.length === 0) { %>
          <div class="empty-state">
            <p>No upcoming recertifications.</p>
          </div>
        <% } else { %>
          <% recertificationsByHospital.forEach(group => { %>
            <details class="recert-details" style="margin-bottom: 1rem;">
              <summary class="recert-summary">
                <span><i class="fas fa-hospital"></i> <%= group.hospital %></span>
                <span class="recert-count"><%= group.trainees.length %> trainee(s)</span>
              </summary>
              <div class="table-responsive">
                <table class="recert-table">
                  <thead>
                    <tr>
                      <th>Trainee</th>
                      <th>Latest Training</th>
                      <th>Valid Certificate</th>
                      <th>Days Left</th>
                      <th>Status</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% group.trainees.forEach(t => { %>
                      <%
                        const daysLeft = t.days_remaining;
                        const badgeClass = (daysLeft !== null && daysLeft <= 30)
                          ? 'recert-badge--urgent'
                          : 'recert-badge--warn';
                        const badgeText = (daysLeft !== null && daysLeft <= 30)
                          ? 'Urgent'
                          : 'Upcoming';
                      %>
                      <tr>
                        <td><%= t.first_name %> <%= t.last_name %> (<%= t.trainee_public_id %>)</td>
                        <td><%= t.training_title %></td>
                        <td>
                          <a class="btn btn-sm btn-outline" href="/training/<%= t.training_id %>/certificate/<%= t.enrollment_id %>" target="_blank">
                            View Certificate
                          </a>
                        </td>
                        <td><%= daysLeft %> days</td>
                        <td><span class="recert-badge <%= badgeClass %>"><%= badgeText %></span></td>
                      </tr>
                    <% }); %>
                  </tbody>
                </table>
              </div>
            </details>
          <% }); %>
        <% } %>
      </section>
      
      <!-- Trainee Registration Status -->
      <section class="dashboard-section">
        <h2><i class="fas fa-users" style="color: #573FD7;"></i> Trainee Registration Status</h2>
        
        <div class="stats-grid">
          <div class="stat-card">
            <h3><%= traineeStats.total %></h3>
            <p>Total Trainees</p>
            <div class="stat-card-desc">All trainees in the system.</div>
          </div>
          <div class="stat-card">
            <h3><%= traineeStats.active %></h3>
            <p>Active</p>
            <div class="stat-card-desc">Currently active and eligible.</div>
          </div>
          <div class="stat-card">
            <h3><%= traineeStats.inactive %></h3>
            <p>Inactive</p>
            <div class="stat-card-desc">Temporarily inactive accounts.</div>
          </div>
          <div class="stat-card">
            <h3><%= traineeStats.suspended %></h3>
            <p>Suspended</p>
            <div class="stat-card-desc">Access suspended by admin.</div>
          </div>
          <div class="stat-card">
            <h3><%= traineeStats.registered %></h3>
            <p>Registered</p>
            <div class="stat-card-desc">Registered but not yet active.</div>
          </div>
        </div>
      </section>
      
      <!-- Trainers Section -->
      <section class="dashboard-section">
        <h2><i class="fas fa-chalkboard-teacher" style="color: #573FD7;"></i> Trainers</h2>
        <div class="trainers-grid">
          <% if (trainers.length === 0) { %>
            <p style="color: #5F6368;">No trainers found</p>
          <% } else { %>
            <% trainers.forEach(trainer => { %>
              <%
                const taughtHours = Number(trainer.taught_hours || 0);
                const taughtHoursLabel = Number.isInteger(taughtHours)
                  ? taughtHours.toString()
                  : taughtHours.toFixed(1);
              %>
              <div class="trainer-card">
                <div class="trainer-avatar">
                  <% if (trainer.profile_picture) { %>
                    <img src="<%= trainer.profile_picture.startsWith('/') ? trainer.profile_picture : '/uploads/profiles/' + trainer.profile_picture %>" alt="<%= trainer.first_name %> <%= trainer.last_name %>">
                  <% } else { %>
                    <%= trainer.first_name.charAt(0).toUpperCase() %><%= trainer.last_name.charAt(0).toUpperCase() %>
                  <% } %>
                </div>
                <div class="trainer-name"><%= trainer.first_name %> <%= trainer.last_name %></div>
                <div class="trainer-role"><%= trainer.role %></div>
                <div class="trainer-stats">
                  <div class="trainer-stat">
                    <div class="trainer-stat-value"><%= trainer.completed_trainings || 0 %></div>
                    <div class="trainer-stat-label">Completed</div>
                  </div>
                  <div class="trainer-stat">
                    <div class="trainer-stat-value"><%= trainer.in_progress_trainings || 0 %></div>
                    <div class="trainer-stat-label">In Progress</div>
                  </div>
                  <div class="trainer-stat">
                    <div class="trainer-stat-value"><%= taughtHoursLabel %></div>
                    <div class="trainer-stat-label">Hours Taught</div>
                  </div>
                </div>
              </div>
            <% }); %>
          <% } %>
        </div>
      </section>
      
      <!-- Recent Registrations Section -->
      <section class="dashboard-section">
        <h2><i class="fas fa-user-plus" style="color: #573FD7;"></i> Recent Registrations</h2>
        <div class="table-responsive">
          <!-- Desktop Table View -->
          <table class="data-table">
            <thead>
              <tr>
                <th>Name</th>
                <th>IC/Passport</th>
                <th>Healthcare</th>
                <th>Email</th>
                <th>Phone Number</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% if (recentRegistrations.length === 0) { %>
                <tr>
                  <td colspan="6" style="text-align: center; padding: 2rem; color: #5F6368;">
                    No recent registrations
                  </td>
                </tr>
              <% } else { %>
                <% recentRegistrations.forEach(trainee => { %>
                  <tr>
                    <td><%= trainee.first_name %> <%= trainee.last_name %></td>
                    <td><%= trainee.ic_passport %></td>
                    <td><%= trainee.healthcare || '-' %></td>
                    <td><%= trainee.email %></td>
                    <td><%= trainee.handphone_number || '-' %></td>
                    <td>
                      <a href="/trainees/<%= trainee.id %>/edit" class="btn btn-sm btn-secondary">
                        <i class="fas fa-edit"></i> Edit Trainee
                      </a>
                    </td>
                  </tr>
                <% }); %>
              <% } %>
            </tbody>
          </table>
          
          <!-- Mobile/Tablet Card View -->
          <div class="table-card-grid">
            <% if (recentRegistrations.length === 0) { %>
              <div class="table-card" style="text-align: center; padding: 2rem; color: #5F6368;">
                No recent registrations
              </div>
            <% } else { %>
              <% recentRegistrations.forEach(trainee => { %>
                <div class="table-card">
                  <div class="table-card-header">
                    <h3 class="table-card-title"><%= trainee.first_name %> <%= trainee.last_name %></h3>
                  </div>
                  <div class="table-card-body">
                    <div class="table-card-row">
                      <div class="table-card-label">IC/Passport</div>
                      <div class="table-card-value"><%= trainee.ic_passport %></div>
                    </div>
                    <div class="table-card-row">
                      <div class="table-card-label">Healthcare</div>
                      <div class="table-card-value"><%= trainee.healthcare || '-' %></div>
                    </div>
                    <div class="table-card-row">
                      <div class="table-card-label">Email</div>
                      <div class="table-card-value">
                        <a href="mailto:<%= trainee.email %>" style="color: #573FD7; text-decoration: none;">
                          <%= trainee.email %>
                        </a>
                      </div>
                    </div>
                    <div class="table-card-row">
                      <div class="table-card-label">Phone Number</div>
                      <div class="table-card-value">
                        <% if (trainee.handphone_number) { %>
                          <a href="tel:<%= trainee.handphone_number %>" style="color: #573FD7; text-decoration: none;">
                            <%= trainee.handphone_number %>
                          </a>
                        <% } else { %>
                          <span style="color: #9CA3AF;">-</span>
                        <% } %>
                      </div>
                    </div>
                    <div class="table-card-row" style="margin-top: 0.5rem; padding-top: 0.75rem; border-top: 1px solid #E8EAED;">
                      <a href="/trainees/<%= trainee.id %>/edit" class="btn btn-sm btn-secondary" style="width: 100%; text-align: center; justify-content: center;">
                        <i class="fas fa-edit"></i> Edit Trainee
                      </a>
                    </div>
                  </div>
                </div>
              <% }); %>
            <% } %>
          </div>
        </div>
      </section>
    </div>
  </main>
  
  <script src="/vendor/chart.js/dist/chart.umd.js"></script>
  <script>
    (() => {
      const topClientTrainings = <%- JSON.stringify((topClientTrainings || []).map(client => ({
        name: client.name || 'Unknown Client',
        training_count: Number(client.training_count || 0)
      }))) %>;
      const chartCanvas = document.getElementById('top-clients-chart');

      if (!chartCanvas || !window.Chart || topClientTrainings.length === 0) return;

      const labels = topClientTrainings.map(client => client.name);
      const counts = topClientTrainings.map(client => client.training_count);

      new Chart(chartCanvas, {
        type: 'bar',
        data: {
          labels,
          datasets: [{
            label: 'Trainings',
            data: counts,
            backgroundColor: 'rgba(87, 63, 215, 0.78)',
            borderColor: '#573FD7',
            borderWidth: 1,
            borderRadius: 6,
            barThickness: 16,
            maxBarThickness: 18
          }]
        },
        options: {
          indexAxis: 'y',
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: {
              display: false
            },
            tooltip: {
              callbacks: {
                label: context => `${context.parsed.x} training${context.parsed.x === 1 ? '' : 's'}`
              }
            }
          },
          scales: {
            x: {
              beginAtZero: true,
              ticks: {
                precision: 0
              },
              grid: {
                color: 'rgba(148, 163, 184, 0.22)'
              }
            },
            y: {
              ticks: {
                color: '#374151',
                font: {
                  size: 11,
                  weight: '400'
                },
                callback(value) {
                  const label = this.getLabelForValue(value);
                  return label.length > 28 ? `${label.slice(0, 28)}...` : label;
                }
              },
              grid: {
                display: false
              }
            }
          }
        }
      });
    })();
  </script>
  <script>
    (() => {
      const initialRange = <%- JSON.stringify(dashboardDateRange || {}) %>;
      const openButton = document.getElementById('date-range-open');
      const overlay = document.getElementById('date-range-overlay');
      const panel = document.getElementById('date-range-panel');
      const closeButton = document.getElementById('date-range-close');
      const cancelButton = document.getElementById('date-range-cancel');
      const applyButton = document.getElementById('date-range-apply');
      const clearButton = document.getElementById('date-range-clear');
      const todayButton = document.getElementById('date-range-today');
      const prevButton = document.getElementById('date-range-prev-month');
      const nextButton = document.getElementById('date-range-next-month');
      const calendars = document.getElementById('date-range-calendars');
      const startButton = document.getElementById('panel-start-date-btn');
      const endButton = document.getElementById('panel-end-date-btn');
      const startValue = document.getElementById('panel-start-date-value');
      const endValue = document.getElementById('panel-end-date-value');
      const presetInputs = Array.from(document.querySelectorAll('input[name="dashboardPreset"]'));

      const monthFormatter = new Intl.DateTimeFormat('en-US', { month: 'short', year: 'numeric' });
      const displayDateFormatter = new Intl.DateTimeFormat('en-GB', { day: 'numeric', month: 'short', year: 'numeric' });
      const presets = {
        today: () => {
          const today = startOfDay(new Date());
          return [today, today];
        },
        yesterday: () => {
          const day = addDays(startOfDay(new Date()), -1);
          return [day, day];
        },
        last_7_days: () => rangeEndingToday(6),
        last_14_days: () => rangeEndingToday(13),
        last_28_days: () => rangeEndingToday(27),
        last_30_days: () => rangeEndingToday(29),
        this_week: () => {
          const today = startOfDay(new Date());
          const mondayOffset = (today.getDay() || 7) - 1;
          const start = addDays(today, -mondayOffset);
          return [start, addDays(start, 6)];
        },
        last_week: () => {
          const today = startOfDay(new Date());
          const mondayOffset = (today.getDay() || 7) - 1;
          const end = addDays(today, -mondayOffset - 1);
          return [addDays(end, -6), end];
        },
        this_month: () => {
          const today = new Date();
          return [new Date(today.getFullYear(), today.getMonth(), 1), new Date(today.getFullYear(), today.getMonth() + 1, 0)];
        },
        last_month: () => {
          const today = new Date();
          return [new Date(today.getFullYear(), today.getMonth() - 1, 1), new Date(today.getFullYear(), today.getMonth(), 0)];
        }
      };

      let selectedStart = parseDate(initialRange.startDate) || presets.this_month()[0];
      let selectedEnd = parseDate(initialRange.endDate) || presets.this_month()[1];
      let activePreset = initialRange.preset || 'this_month';
      let visibleMonth = new Date(selectedStart.getFullYear(), selectedStart.getMonth(), 1);
      let activeBoundary = 'start';

      function startOfDay(date) {
        return new Date(date.getFullYear(), date.getMonth(), date.getDate());
      }

      function addDays(date, days) {
        const next = new Date(date);
        next.setDate(next.getDate() + days);
        return next;
      }

      function rangeEndingToday(offsetDays) {
        const end = startOfDay(new Date());
        return [addDays(end, -offsetDays), end];
      }

      function parseDate(value) {
        if (!value) return null;
        const parts = String(value).split('-').map(Number);
        if (parts.length !== 3 || parts.some(Number.isNaN)) return null;
        return new Date(parts[0], parts[1] - 1, parts[2]);
      }

      function formatDate(date) {
        const year = date.getFullYear();
        const month = String(date.getMonth() + 1).padStart(2, '0');
        const day = String(date.getDate()).padStart(2, '0');
        return `${year}-${month}-${day}`;
      }

      function formatDisplayDate(date) {
        return date ? displayDateFormatter.format(date) : '';
      }

      function applyPreset(preset) {
        activePreset = preset;
        if (preset === 'all_time') {
          activeBoundary = 'start';
        } else if (presets[preset]) {
          [selectedStart, selectedEnd] = presets[preset]();
          visibleMonth = new Date(selectedStart.getFullYear(), selectedStart.getMonth(), 1);
          activeBoundary = 'start';
        }
        syncControls();
      }

      function syncControls() {
        if (selectedStart && selectedEnd && selectedStart > selectedEnd) {
          [selectedStart, selectedEnd] = [selectedEnd, selectedStart];
        }

        startValue.textContent = activePreset === 'all_time' ? 'All time' : formatDisplayDate(selectedStart);
        endValue.textContent = activePreset === 'all_time' ? 'All time' : formatDisplayDate(selectedEnd);
        startButton.classList.toggle('is-active', activeBoundary === 'start');
        endButton.classList.toggle('is-active', activeBoundary === 'end');

        presetInputs.forEach(input => {
          input.checked = input.value === activePreset;
        });

        renderCalendars();
      }

      function renderCalendars() {
        calendars.innerHTML = '';
        calendars.appendChild(renderMonth(visibleMonth));
        calendars.appendChild(renderMonth(new Date(visibleMonth.getFullYear(), visibleMonth.getMonth() + 1, 1)));
      }

      function renderMonth(monthDate) {
        const calendar = document.createElement('div');
        calendar.className = 'date-calendar';

        const title = document.createElement('h3');
        title.textContent = monthFormatter.format(monthDate);
        calendar.appendChild(title);

        const grid = document.createElement('div');
        grid.className = 'date-calendar-grid';
        ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'].forEach(day => {
          const weekday = document.createElement('div');
          weekday.className = 'date-calendar-weekday';
          weekday.textContent = day;
          grid.appendChild(weekday);
        });

        const firstDay = new Date(monthDate.getFullYear(), monthDate.getMonth(), 1);
        const blanks = (firstDay.getDay() || 7) - 1;
        const daysInMonth = new Date(monthDate.getFullYear(), monthDate.getMonth() + 1, 0).getDate();

        for (let index = 0; index < blanks; index += 1) {
          const blank = document.createElement('span');
          blank.className = 'date-calendar-day is-muted';
          grid.appendChild(blank);
        }

        for (let day = 1; day <= daysInMonth; day += 1) {
          const date = new Date(monthDate.getFullYear(), monthDate.getMonth(), day);
          const button = document.createElement('button');
          button.type = 'button';
          button.className = getDayClass(date);
          button.textContent = String(day);
          button.addEventListener('click', () => selectCalendarDate(date));
          grid.appendChild(button);
        }

        calendar.appendChild(grid);
        return calendar;
      }

      function getDayClass(date) {
        const dayValue = formatDate(date);
        const startValue = activePreset === 'all_time' ? null : selectedStart ? formatDate(selectedStart) : null;
        const endValue = activePreset === 'all_time' ? null : selectedEnd ? formatDate(selectedEnd) : null;
        const classes = ['date-calendar-day'];

        if (dayValue === startValue || dayValue === endValue) {
          classes.push('is-selected');
        } else if (startValue && endValue && dayValue > startValue && dayValue < endValue) {
          classes.push('is-in-range');
        }

        return classes.join(' ');
      }

      function selectCalendarDate(date) {
        activePreset = 'custom';
        if (activeBoundary === 'start') {
          selectedStart = startOfDay(date);
          if (!selectedEnd || selectedStart > selectedEnd) {
            selectedEnd = selectedStart;
          }
          activeBoundary = 'end';
        } else {
          selectedEnd = startOfDay(date);
          if (!selectedStart || selectedEnd < selectedStart) {
            selectedStart = selectedEnd;
          }
          activeBoundary = 'start';
        }
        syncControls();
      }

      function openPanel() {
        overlay.hidden = false;
        panel.hidden = false;
        requestAnimationFrame(() => {
          overlay.classList.add('is-open');
          panel.classList.add('is-open');
        });
      }

      function closePanel() {
        overlay.classList.remove('is-open');
        panel.classList.remove('is-open');
        window.setTimeout(() => {
          overlay.hidden = true;
          panel.hidden = true;
        }, 240);
      }

      function applyFilter() {
        const url = new URL(window.location.href);
        url.searchParams.set('preset', activePreset || 'custom');
        if (activePreset === 'all_time') {
          url.searchParams.delete('startDate');
          url.searchParams.delete('endDate');
        } else {
          if (!selectedStart || !selectedEnd) return;
          url.searchParams.set('startDate', formatDate(selectedStart));
          url.searchParams.set('endDate', formatDate(selectedEnd));
        }
        window.location.href = url.toString();
      }

      presetInputs.forEach(input => {
        input.addEventListener('change', () => applyPreset(input.value));
      });

      startButton.addEventListener('click', () => {
        activeBoundary = 'start';
        syncControls();
      });

      endButton.addEventListener('click', () => {
        activeBoundary = 'end';
        syncControls();
      });

      openButton.addEventListener('click', openPanel);
      closeButton.addEventListener('click', closePanel);
      cancelButton.addEventListener('click', closePanel);
      overlay.addEventListener('click', closePanel);
      applyButton.addEventListener('click', applyFilter);
      clearButton.addEventListener('click', () => applyPreset('this_month'));
      todayButton.addEventListener('click', () => applyPreset('today'));
      prevButton.addEventListener('click', () => {
        visibleMonth = new Date(visibleMonth.getFullYear(), visibleMonth.getMonth() - 1, 1);
        renderCalendars();
      });
      nextButton.addEventListener('click', () => {
        visibleMonth = new Date(visibleMonth.getFullYear(), visibleMonth.getMonth() + 1, 1);
        renderCalendars();
      });
      document.addEventListener('keydown', event => {
        if (event.key === 'Escape' && panel.classList.contains('is-open')) {
          closePanel();
        }
      });

      syncControls();
    })();
  </script>
  <script src="/js/main.js"></script>
</body>
</html>
