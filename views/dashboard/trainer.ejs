      .dashboard-section {
        padding: 1.25rem !important;
        margin-bottom: 1.5rem;
        border-radius: 12px;
      }
      
      .dashboard-section h2 {
        font-size: 1.125rem;
        margin-bottom: 1rem;
        padding-bottom: 0.5rem;
      }
      
      .dashboard-section h2 i {
        font-size: 1rem;
      }
      
      .table-card {
        padding: 1rem;
      }
      
      .table-card-header {
        flex-direction: column;
        gap: 0.75rem;
        align-items: flex-start;
      }
      
      .table-card-title {
