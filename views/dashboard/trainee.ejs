<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Trainee Dashboard - LMS</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body class="has-sidebar">
  <%- include('../partials/sidebar', { user }) %>

  <main class="main-content trainee-dashboard">
    <div class="container">
      <style>
        .cert-status {
          display: inline-flex;
          align-items: center;
          gap: 0.4rem;
          padding: 0.35rem 0.75rem;
          border-radius: 999px;
          font-size: 0.75rem;
          font-weight: 700;
          letter-spacing: 0.04em;
          text-transform: uppercase;
        }
        .cert-status--safe {
          background: rgba(16, 185, 129, 0.15);
          color: #047857;
        }
        .cert-status--warn {
          background: rgba(245, 158, 11, 0.18);
          color: #B45309;
        }
        .cert-status--urgent {
          background: rgba(239, 68, 68, 0.18);
          color: #B91C1C;
        }
        .cert-status--expired {
          background: rgba(107, 114, 128, 0.18);
          color: #374151;
        }
        .recert-list {
          display: grid;
          gap: 0.75rem;
        }
        .recert-item {
          display: flex;
          justify-content: space-between;
          align-items: center;
          gap: 0.75rem;
          padding: 0.75rem 1rem;
          border: 1px solid #E8EAED;
          border-radius: 12px;
          background: #fff;
        }
        .recert-name {
          font-weight: 600;
          color: #202124;
        }
        .recert-meta {
          color: #5F6368;
          font-size: 0.85rem;
        }
        .recert-badge {
          white-space: nowrap;
        }
        .certificates-mobile-list {
          display: none;
        }
      </style>
      <!-- Top Grid: Welcome + Quick Actions -->
      <div class="dashboard-top-grid">
        <!-- Welcome Hero Section -->
        <div class="welcome-hero">
          <div class="hero-content">
            <div class="hero-content-centered">
              <h1>Welcome back, <%= user.userName %> <span class="emoji-wave">👋</span></h1>
              <p>Continue your learning journey and track your progress</p>
            </div>
          </div>
        </div>

        <!-- Quick Actions + Profile Section -->
        <div class="quick-actions-section">
          <div class="section-header">
            <h2><i class="fas fa-bolt"></i> Quick Actions</h2>
            <p>Get started with your training</p>
          </div>
          <div class="quick-actions-grid">
            <a href="/training" class="action-card-primary">
              <div class="action-card-bg">
                <div class="action-card-content">
                  <div class="action-card-text">
                    <h3>Browse Trainings</h3>
                    <p>Explore available training programs and enroll in new courses</p>
                    <div class="action-card-arrow">
                      <i class="fas fa-arrow-right"></i>
                    </div>
                  </div>
                </div>
              </div>
            </a>

            <a href="/profile" class="action-card-secondary quick-profile-card">
              <div class="action-card-secondary-header">
                <h4><i class="fas fa-id-card"></i> Your Profile</h4>
              </div>
              <div class="action-card-secondary-content">
                <div class="profile-info-item">
                  <i class="fas fa-user"></i>
                  <span><%= user.userName %></span>
                </div>
                <% if (traineeProfile.email) { %>
                  <div class="profile-info-item">
                    <i class="fas fa-envelope"></i>
                    <span><%= traineeProfile.email %></span>
                  </div>
                <% } %>
                <% if (traineeProfile.designation) { %>
                  <div class="profile-info-item">
                    <i class="fas fa-briefcase"></i>
                    <span><%= traineeProfile.designation %></span>
                  </div>
                <% } %>
                <% if (traineeProfile.hospital_name) { %>
                  <div class="profile-info-item">
                    <i class="fas fa-hospital"></i>
                    <span><%= traineeProfile.hospital_name %></span>
                  </div>
                <% } %>
                <% if (!traineeProfile.email && !traineeProfile.designation && !traineeProfile.hospital_name) { %>
                  <div class="profile-info-item">
                    <i class="fas fa-info-circle"></i>
                    <span>View and update your information</span>
                  </div>
                <% } %>
              </div>
            </a>
          </div>
        </div>
      </div>

      <!-- Progress Analytics Section -->
      <div class="analytics-section">
        <div class="section-header">
          <h2><i class="fas fa-chart-line"></i> Learning Progress</h2>
          <p>Your training journey at a glance</p>
        </div>
        <div class="analytics-grid">
          <div class="analytics-main-card">
            <div class="analytics-main-header">
              <div class="analytics-main-icon">
                <i class="fas fa-trophy"></i>
              </div>
              <div class="analytics-main-content">
                <h3><%= analytics.trainings_completed %></h3>
                <p>Trainings Completed</p>
              </div>
            </div>
            <div class="analytics-main-progress">
              <div class="progress-ring">
                <svg width="120" height="120" viewBox="0 0 120 120">
                  <circle cx="60" cy="60" r="50" stroke="rgba(87, 63, 215, 0.2)" stroke-width="8" fill="none"/>
                  <circle cx="60" cy="60" r="50" stroke="url(#progressGradient)" stroke-width="8" fill="none"
                          stroke-dasharray="<%= 2 * Math.PI * 50 %>"
                          stroke-dashoffset="<%= 2 * Math.PI * 50 * (1 - analytics.trainings_completed / (analytics.total_enrolled || 1)) %>"
                          transform="rotate(-90 60 60)"/>
                  <defs>
                    <linearGradient id="progressGradient" x1="0%" y1="0%" x2="100%" y2="0%">
                      <stop offset="0%" style="stop-color:#6366f1"/>
                      <stop offset="100%" style="stop-color:#4f46e5"/>
                    </linearGradient>
                  </defs>
                </svg>
                <div class="progress-ring-text">
                  <span class="progress-ring-number"><%= Math.round((analytics.trainings_completed / (analytics.total_enrolled || 1)) * 100) %>%</span>
                  <span class="progress-ring-label">Complete</span>
                </div>
              </div>
            </div>
          </div>

          <div class="analytics-cards">
            <div class="analytics-card">
              <div class="analytics-card-icon">
                <i class="fas fa-check-circle"></i>
              </div>
              <div class="analytics-card-content">
                <div class="analytics-card-number"><%= analytics.activities_completed %></div>
                <div class="analytics-card-label">Activities Done</div>
                <div class="analytics-card-trend">
                  <i class="fas fa-arrow-up"></i>
                  <span>Tests & Assessments</span>
                </div>
              </div>
            </div>

            <div class="analytics-card">
              <div class="analytics-card-icon">
                <i class="fas fa-calendar-alt"></i>
              </div>
              <div class="analytics-card-content">
                <div class="analytics-card-number"><%= analytics.total_enrolled %></div>
                <div class="analytics-card-label">Active Courses</div>
                <div class="analytics-card-trend">
                  <i class="fas fa-book-open"></i>
                  <span>In Progress</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Certificates Section -->
      <div class="trainings-section">
        <div class="section-header">
          <h2><i class="fas fa-certificate"></i> My Certificates</h2>
          <p>Track validity and view certificates</p>
        </div>

        <% if (!certificates || certificates.length === 0) { %>
          <div class="empty-trainings">
            <div class="empty-trainings-icon">
              <i class="fas fa-certificate"></i>
            </div>
            <div class="empty-trainings-content">
              <h3>No certificates yet</h3>
              <p>Complete your training to earn certificates.</p>
            </div>
          </div>
        <% } else { %>
          <div class="table-responsive">
            <table class="data-table">
              <thead>
                <tr>
                  <th>Training</th>
                  <th>Certificate No.</th>
                  <th>Valid Until</th>
                  <th>Status</th>
                  <th>Action</th>
                </tr>
              </thead>
              <tbody>
                <% certificates.forEach(cert => { %>
                  <%
                    const daysLeft = cert.days_remaining;
                    const statusClass = (daysLeft !== null && daysLeft < 0)
                      ? 'cert-status--expired'
                      : (daysLeft !== null && daysLeft <= 30)
                        ? 'cert-status--urgent'
                        : (daysLeft !== null && daysLeft <= 60)
                          ? 'cert-status--warn'
                          : 'cert-status--safe';
                    const statusText = (daysLeft !== null && daysLeft < 0)
                      ? 'Expired'
                      : (daysLeft !== null && daysLeft <= 30)
                        ? 'Expiring Soon'
                        : (daysLeft !== null && daysLeft <= 60)
                          ? 'Renewal Window'
                          : 'Active';
                  %>
                  <tr>
                    <td><strong><%= cert.training_title %></strong></td>
                    <td><%= cert.certificate_number %></td>
                    <td><%= cert.validity_end ? new Date(cert.validity_end).toLocaleDateString('en-GB') : 'N/A' %></td>
                    <td>
                      <span class="cert-status <%= statusClass %>">
                        <%= statusText %>
                        <% if (daysLeft !== null && daysLeft >= 0) { %>
                          (<%= daysLeft %>d)
                        <% } %>
                      </span>
                    </td>
                    <td>
                      <a class="btn btn-sm btn-primary" href="/training/<%= cert.training_id %>/certificate/<%= cert.enrollment_id %>" target="_blank">
                        View Certificate
                      </a>
                    </td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
          <div class="certificates-mobile-list">
            <% certificates.forEach(cert => { %>
              <%
                const daysLeft = cert.days_remaining;
                const statusClass = (daysLeft !== null && daysLeft < 0)
                  ? 'cert-status--expired'
                  : (daysLeft !== null && daysLeft <= 30)
                    ? 'cert-status--urgent'
                    : (daysLeft !== null && daysLeft <= 60)
                      ? 'cert-status--warn'
                      : 'cert-status--safe';
                const statusText = (daysLeft !== null && daysLeft < 0)
                  ? 'Expired'
                  : (daysLeft !== null && daysLeft <= 30)
                    ? 'Expiring Soon'
                    : (daysLeft !== null && daysLeft <= 60)
                      ? 'Renewal Window'
                      : 'Active';
              %>
              <article class="certificate-mobile-card">
                <div class="certificate-mobile-card__header">
                  <h3><%= cert.training_title %></h3>
                  <span class="cert-status <%= statusClass %>">
                    <%= statusText %>
                    <% if (daysLeft !== null && daysLeft >= 0) { %>
                      (<%= daysLeft %>d)
                    <% } %>
                  </span>
                </div>
                <div class="certificate-mobile-card__meta">
                  <div class="certificate-mobile-card__row">
                    <span class="certificate-mobile-card__label">Certificate No.</span>
                    <strong><%= cert.certificate_number %></strong>
                  </div>
                  <div class="certificate-mobile-card__row">
                    <span class="certificate-mobile-card__label">Valid Until</span>
                    <strong><%= cert.validity_end ? new Date(cert.validity_end).toLocaleDateString('en-GB') : 'N/A' %></strong>
                  </div>
                </div>
                <a class="btn btn-primary certificate-mobile-card__action" href="/training/<%= cert.training_id %>/certificate/<%= cert.enrollment_id %>" target="_blank">
                  View Certificate
                </a>
              </article>
            <% }); %>
          </div>
        <% } %>
      </div>
      <!-- Recent Trainings Section -->
      <div class="trainings-section">
        <div class="section-header">
          <h2><i class="fas fa-list"></i> Recent Trainings</h2>
          <p>Continue where you left off</p>
          <a href="/training" class="section-link">
            <span>View All Trainings</span>
            <i class="fas fa-arrow-right"></i>
          </a>
        </div>

        <% if (enrollments.length === 0) { %>
          <div class="empty-trainings">
            <div class="empty-trainings-icon">
              <i class="fas fa-book-open"></i>
            </div>
            <div class="empty-trainings-content">
              <h3>No trainings yet</h3>
              <p>Start your learning journey by exploring available training programs</p>
              <a href="/training" class="btn btn-primary">
                <i class="fas fa-search"></i>
                Explore Trainings
              </a>
            </div>
          </div>
        <% } else { %>
          <div class="trainings-grid">
            <% enrollments.forEach(enrollment => { %>
              <%
                // Calculate completion percentage
                let totalActivities = 1; // Pre-test always required for main trainings
                let completedActivities = enrollment.pre_test_completed ? 1 : 0;
                const handsOnDone = enrollment.hands_on_total > 0
                  ? enrollment.hands_on_completed >= enrollment.hands_on_total
                  : false;

                if (enrollment.type === 'main') {
                  totalActivities += 3; // Post-test + Practical learning outcome assessment + Certificate enrolment
                  completedActivities += enrollment.post_test_completed ? 1 : 0;
                  completedActivities += handsOnDone ? 1 : 0;
                  completedActivities += enrollment.certificate_enrolment_test_completed ? 1 : 0;
                } else {
                  // Refresher: 100% when both certificate enrolment + refresher test are completed
                  totalActivities = 2;
                  completedActivities = (enrollment.certificate_enrolment_test_completed ? 1 : 0)
                    + (enrollment.refresher_training_test_completed ? 1 : 0);
                }

                const completionPercentage = Math.round((completedActivities / totalActivities) * 100);
                const isCompleted = completionPercentage === 100;
                const isInProgress = completionPercentage > 0 && completionPercentage < 100;
                const isNotStarted = completionPercentage === 0;
              %>
              <div class="training-card-modern">
                <div class="training-card-header">
                  <div class="training-badge">
                    <span class="badge badge-<%= enrollment.type %>">
                      <i class="fas fa-<%= enrollment.type === 'main' ? 'star' : 'refresh' %>"></i>
                      <%= enrollment.type %>
                    </span>
                  </div>
                  <div class="training-status">
                    <% if (isCompleted) { %>
                      <span class="status-completed">
                        <i class="fas fa-check"></i>
                        Completed
                      </span>
                    <% } else if (isInProgress) { %>
                      <span class="status-in-progress">
                        <i class="fas fa-play"></i>
                        In Progress
                      </span>
                    <% } else { %>
                      <span class="status-not-started">
                        <i class="fas fa-clock"></i>
                        Not Started
                      </span>
                    <% } %>
                  </div>
                </div>

                <div class="training-card-content">
                  <h3 class="training-title"><%= enrollment.title %></h3>

                  <!-- Progress Visualization -->
                  <div class="training-progress">
                    <div class="progress-circle">
                      <svg width="80" height="80" viewBox="0 0 80 80">
                        <circle cx="40" cy="40" r="35" stroke="rgba(87, 63, 215, 0.2)" stroke-width="6" fill="none"/>
                        <circle cx="40" cy="40" r="35" stroke="url(#trainingProgress<%= enrollment.id %>)" stroke-width="6" fill="none"
                                stroke-dasharray="<%= 2 * Math.PI * 35 %>"
                                stroke-dashoffset="<%= 2 * Math.PI * 35 * (1 - completionPercentage / 100) %>"
                                transform="rotate(-90 40 40)"/>
                        <defs>
                          <linearGradient id="trainingProgress<%= enrollment.id %>" x1="0%" y1="0%" x2="100%" y2="0%">
                            <stop offset="0%" style="stop-color:<%= isCompleted ? '#10B981' : isInProgress ? '#F59E0B' : '#6B7280' %>"/>
                            <stop offset="100%" style="stop-color:<%= isCompleted ? '#059669' : isInProgress ? '#D97706' : '#4B5563' %>"/>
                          </linearGradient>
                        </defs>
                      </svg>
                      <div class="progress-circle-text">
                        <span class="progress-circle-number" data-target="<%= completionPercentage %>">0%</span>
                      </div>
                    </div>

                    <div class="progress-details">
                      <div class="progress-stats">
                        <div class="progress-stat">
                          <span class="progress-stat-number"><%= completedActivities %></span>
                          <span class="progress-stat-label">Done</span>
                        </div>
                        <div class="progress-stat">
                          <span class="progress-stat-number"><%= totalActivities - completedActivities %></span>
                          <span class="progress-stat-label">Left</span>
                        </div>
                      </div>
                    </div>
                  </div>

                  <!-- Quick Progress Checklist -->
                  <div class="training-checklist">
                    <% if (enrollment.type === 'main') { %>
                      <div class="checklist-item <%= enrollment.pre_test_completed ? 'completed' : 'pending' %>">
                        <i class="fas fa-<%= enrollment.pre_test_completed ? 'check-circle' : 'circle' %>"></i>
                        <span>Pre-Test</span>
                      </div>
                      <div class="checklist-item <%= handsOnDone ? 'completed' : 'pending' %>">
                        <i class="fas fa-<%= handsOnDone ? 'check-circle' : 'circle' %>"></i>
                        <span>Practical Learning Outcome</span>
                      </div>
                      <div class="checklist-item <%= enrollment.post_test_completed ? 'completed' : 'pending' %>">
                        <i class="fas fa-<%= enrollment.post_test_completed ? 'check-circle' : 'circle' %>"></i>
                        <span>Post-Test</span>
                      </div>
                      <div class="checklist-item <%= enrollment.certificate_enrolment_test_completed ? 'completed' : 'pending' %>">
                        <i class="fas fa-<%= enrollment.certificate_enrolment_test_completed ? 'check-circle' : 'circle' %>"></i>
                        <span>Certificate Enrolment</span>
                      </div>
                    <% } else { %>
                      <div class="checklist-item <%= enrollment.refresher_training_test_completed ? 'completed' : 'pending' %>">
                        <i class="fas fa-<%= enrollment.refresher_training_test_completed ? 'check-circle' : 'circle' %>"></i>
                        <span>Refresher Training Test</span>
                      </div>
                      <div class="checklist-item <%= enrollment.certificate_enrolment_test_completed ? 'completed' : 'pending' %>">
                        <i class="fas fa-<%= enrollment.certificate_enrolment_test_completed ? 'check-circle' : 'circle' %>"></i>
                        <span>Certificate Enrolment</span>
                      </div>
                    <% } %>
                  </div>
                </div>

                <div class="training-card-actions">
                  <a href="/training/<%= enrollment.training_id %>" class="btn btn-primary">
                    <i class="fas fa-play"></i>
                    <%= isCompleted ? 'Review' : 'Continue' %>
                  </a>
                  <a href="/training/<%= enrollment.training_id %>?tab=results" class="btn btn-outline">
                    <i class="fas fa-chart-bar"></i>
                    Results
                  </a>
                </div>
              </div>
            <% }); %>
          </div>
        <% } %>
      </div>

      </div>
    </div>
  </main>

  <style>
    /* Top grid layout: hero + quick actions */
    .dashboard-top-grid {
      display: grid;
      grid-template-columns: minmax(0, 1.4fr) minmax(0, 1.6fr);
      gap: var(--spacing-xl);
      align-items: stretch;
      margin-top: var(--spacing-lg);
    }

    /* Compact welcome header card with background image */
    .welcome-hero {
      background: linear-gradient(135deg, rgba(0, 0, 0, 0.45), rgba(0, 0, 0, 0.75)), url('/images/Dashboard Images/Hero.webp');
      background-size: cover;
      background-position: center;
      background-repeat: no-repeat;
      color: white;
      border-radius: 18px;
      min-height: 140px;
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 10px 26px rgba(15, 23, 42, 0.35);
      border: 1px solid rgba(15, 23, 42, 0.45);
      overflow: hidden;
    }

    .hero-content {
      width: 100%;
      display: flex;
      justify-content: center;
    }

    .welcome-hero::before {
      content: none;
    }

    .hero-content-centered {
      position: relative;
      left: 0;
      top: 0;
      transform: none;
      z-index: 1;
      text-align: left;
      max-width: 520px;
      width: 100%;
      padding: var(--spacing-sm) var(--spacing-md);
      box-sizing: border-box;
    }

    .hero-content-centered h1 {
      font-size: clamp(1.75rem, 3vw, 2.4rem);
      font-weight: 700;
      margin: 0 0 var(--spacing-sm) 0;
      color: white;
      text-shadow: 0 3px 6px rgba(0, 0, 0, 0.7);
      line-height: 1.2;
      letter-spacing: -0.02em;
    }


    .hero-content-centered p {
      font-size: clamp(0.95rem, 2vw, 1.15rem);
      opacity: 0.95;
      margin: 0;
      color: rgba(255, 255, 255, 0.95);
      text-shadow: 0 2px 4px rgba(0, 0, 0, 0.6);
      line-height: 1.4;
      max-width: 520px;
    }

    .emoji-wave {
      color: white;
      filter: brightness(0) invert(1);
    }

    /* Section Headers */
    .section-header {
      text-align: left;
      margin-bottom: var(--spacing-lg);
      display: grid;
      grid-template-columns: 1fr auto;
      grid-auto-rows: auto;
      column-gap: var(--spacing-lg);
      row-gap: var(--spacing-xs);
      align-items: center;
    }

    .section-header h2 {
      font-size: 2rem;
      font-weight: 700;
      color: var(--color-dark);
      margin: 0 0 var(--spacing-sm) 0;
      display: flex;
      align-items: center;
      gap: var(--spacing-sm);
    }

    .section-header h2 i {
      color: var(--color-purple);
      font-size: 1.5rem;
    }

    .section-header p {
      font-size: 1rem;
      color: var(--color-gray);
      margin: 0;
      grid-column: 1;
    }

    .section-link {
      display: inline-flex;
      align-items: center;
      gap: var(--spacing-sm);
      color: var(--color-purple);
      text-decoration: none;
      font-weight: 600;
      font-size: 0.875rem;
      margin-top: var(--spacing-md);
      transition: all 0.3s ease;
      grid-column: 2;
      grid-row: 1 / span 2;
      justify-self: end;
    }

    .section-link:hover {
      transform: translateX(4px);
    }

    /* Quick Actions Section */
    .quick-actions-section {
      margin-top: 0;
      margin-bottom: var(--spacing-xl);
    }

    .quick-actions-grid {
      display: grid;
      grid-template-rows: auto auto;
      gap: var(--spacing-md);
      align-items: stretch;
    }

    .action-card-primary {
      background: white;
      border-radius: 20px;
      overflow: hidden;
      text-decoration: none;
      color: var(--color-dark);
      transition: all 0.4s ease;
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
      border: 2px solid rgba(0, 0, 0, 0.05);
      position: relative;
      height: 100%;
    }

    .action-card-primary:hover {
      transform: translateY(-4px);
      box-shadow: 0 16px 40px rgba(0, 0, 0, 0.12);
      border-color: var(--color-purple);
    }

    .action-card-bg {
      position: relative;
      min-height: 200px;
      display: flex;
      background: url('/images/Dashboard Images/Trainings.webp');
      background-size: cover;
      background-position: center;
      background-repeat: no-repeat;
      border-radius: 20px;
    }


    .action-card-content {
      position: relative;
      z-index: 2;
      padding: var(--spacing-xl);
      display: flex;
      align-items: center;
      gap: var(--spacing-lg);
      width: 100%;
      background: linear-gradient(135deg, rgba(0,0,0,0.3) 0%, rgba(0,0,0,0.5) 100%);
      backdrop-filter: blur(2px);
    }


    .action-card-text {
      flex: 1;
    }

    .action-card-text h3 {
      font-size: 1.5rem;
      font-weight: 700;
      margin: 0 0 var(--spacing-sm) 0;
      color: white;
    }

    .action-card-text p {
      margin: 0 0 var(--spacing-md) 0;
      color: white;
      font-size: 0.95rem;
    }


    .action-card-arrow {
      font-size: 1.25rem;
      color: white;
      transition: all 0.3s ease;
    }

    .action-card-primary:hover .action-card-arrow {
