  </style>

  <script>
    // Animate progress bars and circles on page load
    document.addEventListener('DOMContentLoaded', function() {
      function animateCircleStroke(circle, percentage, duration) {
        const radius = parseFloat(circle.getAttribute('r')) || 0;
        const circumference = 2 * Math.PI * radius;
        circle.style.transition = 'none';
        circle.style.strokeDasharray = `${circumference}`;
        circle.style.strokeDashoffset = `${circumference}`;
        circle.getBoundingClientRect();
        setTimeout(() => {
          circle.style.transition = `stroke-dashoffset ${duration}ms ease`;
          const offset = circumference - (percentage / 100) * circumference;
          circle.style.strokeDashoffset = `${offset}`;
        }, 20);
      }

      // Animate progress ring in analytics section
      const analyticsRing = document.querySelector('.progress-ring svg circle:nth-of-type(2)');
      const analyticsPercentEl = document.querySelector('.progress-ring-number');
      if (analyticsRing && analyticsPercentEl) {
        const analyticsPercent = parseInt(analyticsPercentEl.textContent, 10) || 0;
        animateCircleStroke(analyticsRing, analyticsPercent, 900);
      }

      // Animate training progress circles
      const trainingCircles = document.querySelectorAll('.training-progress .progress-circle');
      trainingCircles.forEach((circleWrap, index) => {
        const circle = circleWrap.querySelector('svg circle:nth-of-type(2)');
        const label = circleWrap.querySelector('.progress-circle-number[data-target]');
        if (!circle || !label) return;
        const percentage = parseInt(label.getAttribute('data-target'), 10) || 0;
        setTimeout(() => {
          animateCircleStroke(circle, percentage, 900);
        }, index * 120);
      });

      // Animate percentage counters in training cards
      const percentageCounters = document.querySelectorAll('.progress-circle-number[data-target]');
      percentageCounters.forEach((counter, index) => {
        const target = parseInt(counter.getAttribute('data-target'));
        let current = 0;
        const increment = target / 60; // 60 frames for smooth animation
        const timer = setInterval(() => {
          current += increment;
          if (current >= target) {
            current = target;
            clearInterval(timer);
          }
          counter.textContent = Math.floor(current) + '%';
        }, 25);
      });

      // Add entrance animations for cards
      const cards = document.querySelectorAll('.analytics-card, .training-card-modern, .action-card-secondary');
      cards.forEach((card, index) => {
        card.style.opacity = '0';
        card.style.transform = 'translateY(20px)';
        setTimeout(() => {
          card.style.transition = 'all 0.6s ease';
          card.style.opacity = '1';
          card.style.transform = 'translateY(0)';
        }, index * 100);
      });
    });
  </script>
