<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Results - LMS</title>
  <link rel="stylesheet" href="/css/styles.css">
  <style>
    .trainer-comment-card {
      margin: 0 0 1rem 0;
      padding: 1rem 1.1rem;
      border-radius: 12px;
      background: linear-gradient(135deg, #f8fafc 0%, #eef5ff 100%);
      border: 1px solid #dbe4ee;
    }
    .trainer-comment-card h3 {
      margin: 0 0 0.35rem 0;
      font-size: 0.95rem;
      font-weight: 700;
      color: #0b1f44;
    }
    .trainer-comment-card p {
      margin: 0 0 0.5rem 0;
      color: #334155;
      line-height: 1.6;
      white-space: pre-wrap;
    }
    .trainer-comment-card p:last-child {
      margin-bottom: 0;
    }
    .btn-warning {
      background: #FEF7E0;
      color: #B06000;
      border: 1px solid #F9AB00;
    }
    .btn-warning:hover {
      background: #FEEFC3;
      color: #8A4B00;
    }
    .cert-release-modal-overlay {
      position: fixed;
      inset: 0;
      background: rgba(32, 33, 36, 0.45);
      display: none;
      align-items: center;
      justify-content: center;
      z-index: 10050;
      padding: 1rem;
    }
    .cert-release-modal-overlay.is-open {
      display: flex;
    }
    .cert-release-modal {
      background: #fff;
      border-radius: 12px;
      width: 100%;
      max-width: 520px;
      box-shadow: 0 12px 40px rgba(0, 0, 0, 0.18);
      overflow: hidden;
    }
    .cert-release-modal-header {
      padding: 1rem 1.25rem;
      border-bottom: 1px solid #E8EAED;
      font-weight: 600;
    }
    .cert-release-modal-body {
      padding: 1rem 1.25rem;
    }
    .cert-release-modal-body p {
      margin: 0 0 0.75rem;
      color: #5F6368;
      font-size: 0.875rem;
      line-height: 1.5;
    }
    .cert-release-modal-body textarea {
      width: 100%;
      min-height: 120px;
      border: 1px solid #DADCE0;
      border-radius: 8px;
      padding: 0.75rem;
      font-size: 0.875rem;
      resize: vertical;
      box-sizing: border-box;
    }
    .cert-release-modal-actions {
      display: flex;
      justify-content: flex-end;
      gap: 0.5rem;
      padding: 0 1.25rem 1.25rem;
    }
    .celebration-banner {
      margin: 1rem 0 0;
      padding: 1.5rem;
      border-radius: 14px;
      background: linear-gradient(135deg, #fff8e6 0%, #f6ffed 100%);
      border: 2px solid #fbbc04;
      text-align: center;
      position: relative;
      overflow: hidden;
    }
    .celebration-banner img {
      width: min(340px, 90%);
      height: auto;
      display: block;
      margin: 0 auto 1rem;
    }
    .celebration-title {
      font-size: 1.5rem;
      font-weight: 700;
      color: #1a5d1a;
      margin: 0;
    }
    #celebration-confetti-canvas {
      position: fixed;
      inset: 0;
      width: 100vw;
      height: 100vh;
      pointer-events: none;
      z-index: 9998;
    }
  </style>
</head>
<body class="has-sidebar">
  <%- include('../partials/sidebar', { user }) %>
  
  <main class="main-content">
    <div class="container">
      <div class="dashboard-header">
        <h1>Training Results</h1>
        <a href="/training/<%= enrollment.training_id %>" class="btn btn-outline">Back to Training</a>
      </div>

      <%
        const getBestTest = (testsList, type) => {
          const candidates = (testsList || []).filter(t => t.test_type === type);
          if (!candidates.length) return null;
          return candidates.reduce((best, t) => {
            const bestScore = parseFloat(best.score) || 0;
            const currScore = parseFloat(t.score) || 0;
            return currScore > bestScore ? t : best;
          }, candidates[0]);
        };
        const formatScore = (value) => {
          if (value == null || value === '') return null;
          const n = parseFloat(value);
          return Number.isFinite(n) ? n.toFixed(1) : null;
        };
      %>
      
      <div class="training-card results-info-card">
        <h2><%= enrollment.title %></h2>
        <span class="badge badge-<%= enrollment.type %>"><%= enrollment.type %></span>
        <p class="text-muted results-info-meta">
          Trainee: <%= enrollment.first_name %> <%= enrollment.last_name %> (<%= enrollment.trainee_id %>)
        </p>
      </div>
      <%
        const bestCertificate = getBestTest(tests, 'certificate_enrolment');
        const showCertificationCelebration = user.userRole === 'trainee' && !!(bestCertificate && (parseFloat(bestCertificate.score) || 0) >= 70);
      %>
      <% if (showCertificationCelebration) { %>
        <div class="celebration-banner">
          <img src="/images/Test%20Stickers/good%20mark.webp" alt="Certificate pass">
          <p class="celebration-title">Congrats you are now a certified K-Laser therapist</p>
        </div>
        <canvas id="celebration-confetti-canvas" aria-hidden="true"></canvas>
      <% } %>
      
      <!-- Test Results -->
      <div class="dashboard-section">
        <h2>Test Results</h2>
        
        <% if (tests.length === 0) { %>
          <div class="empty-state">
            <p>No test results available yet.</p>
          </div>
        <% } else { %>
          <%
            const testTypes = Array.from(new Set(tests.map(t => t.test_type)));
            const bestTests = testTypes.map(type => getBestTest(tests, type)).filter(Boolean);
          %>
          <div class="table-responsive">
            <table class="data-table">
              <thead>
                <tr>
                  <th>Test Type</th>
                  <th>Score</th>
                  <th>Questions</th>
                  <th>Completed</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody>
                <% bestTests.forEach(test => { %>
                  <tr>
                    <td>
                      <span class="badge badge-main">
                        <%= test.test_type.replace('_', ' ').replace(/\b\w/g, l => l.toUpperCase()) %>
                      </span>
                    </td>
                    <td>
                      <span class="results-score-text results-score-text--<%= test.score >= (test.test_type === 'certificate_enrolment' ? 70 : 80) ? 'pass' : 'fail' %>">
                        <%= test.score.toFixed(1) %>%
                      </span>
                    </td>
                    <td><%= test.total_questions %></td>
                    <td><%= new Date(test.completed_at).toLocaleDateString() %></td>
                    <td>
                      <a href="/tests/results/<%= test.id %>" class="btn btn-sm btn-secondary">View Details</a>
                    </td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>
      
      <!-- Practical Learning Outcome Scores (Main Training Only) -->
      <% if (enrollment.type === 'main' && handsOnScores.length > 0) { %>
        <div class="dashboard-section">
          <h2>Practical Learning Outcome Assessment Scores</h2>
          <% 
            const handsOnComment = (handsOnScores.find(s => s.comments && s.comments.trim().length > 0) || {}).comments;
          %>
          <% if (handsOnComment) { %>
            <div class="trainer-comment-card">
              <h3>Trainer Comment</h3>
              <p><%= handsOnComment %></p>
            </div>
          <% } %>
          <div class="table-responsive">
            <table class="data-table">
              <thead>
                <tr>
                  <th>Aspect</th>
                  <th>Score</th>
                  <th>Evaluated By</th>
                </tr>
              </thead>
              <tbody>
                <% handsOnScores.forEach(score => { %>
                  <tr>
                    <td><strong><%= score.aspect_name %></strong></td>
                    <td><strong><%= score.score %></strong> / <%= score.max_score %></td>
                    <td><%= score.first_name %> <%= score.last_name %></td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        </div>
      <% } %>
      
      <!-- Final Grades (if released) -->
      <% if (gradesReleased && finalGrades) { %>
        <div class="dashboard-section">
          <h2>Final Grades</h2>
          <div class="table-responsive">
            <table class="data-table">
              <thead>
                <tr>
                  <th>Metric</th>
                  <th>Score</th>
                  <th>Notes</th>
                </tr>
              </thead>
              <tbody>
                <% if (finalGrades.training_grade !== null && formatScore(finalGrades.training_grade) !== null) { %>
                  <tr>
                    <td><strong>Training Grade</strong></td>
                    <td><%= formatScore(finalGrades.training_grade) %>%</td>
                    <td>
                      <%= enrollment.type === 'main' ? '60% Practical Learning Outcome + 40% Certificate Enrolment' : 'Certificate Enrolment Test' %>
                    </td>
                  </tr>
                <% } %>
                <% if (finalGrades.endorsement_grade !== null && formatScore(finalGrades.endorsement_grade) !== null) { %>
                  <tr>
                    <td><strong>Endorsement Test Grade</strong></td>
                    <td><%= formatScore(finalGrades.endorsement_grade) %>%</td>
                    <td>-</td>
                  </tr>
                <% } %>
                <% if (finalGrades.objective_understanding_percentage !== null && formatScore(finalGrades.objective_understanding_percentage) !== null) { %>
                  <tr>
                    <td><strong>Objective Understanding</strong></td>
                    <td><%= formatScore(finalGrades.objective_understanding_percentage) %>%</td>
                    <td>-</td>
                  </tr>
                <% } %>
                <% if (finalGrades.hands_on_grade !== null && formatScore(finalGrades.hands_on_grade) !== null) { %>
                  <tr>
                    <td><strong>Practical Learning Outcome Grade</strong></td>
                    <td><%= formatScore(finalGrades.hands_on_grade) %>%</td>
                    <td>-</td>
                  </tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      <% } %>
      
      <!-- Objective Understanding Breakdown -->
      <% if (gradesReleased && objectiveScores && objectiveScores.length > 0) { %>
        <div class="dashboard-section">
          <h2>Objective Understanding Breakdown</h2>
          <div class="table-responsive">
            <table class="data-table">
              <thead>
                <tr>
                  <th>Objective</th>
                  <th>Questions Answered</th>
                  <th>Questions Correct</th>
                  <th>Understanding Percentage</th>
                </tr>
              </thead>
              <tbody>
                <% objectiveScores.forEach(score => { %>
                  <tr>
                    <td><strong><%= score.objective_name %></strong></td>
                    <td><%= score.questions_answered %></td>
                    <td><%= score.questions_correct %></td>
                    <td>
                      <span class="results-score-text results-score-text--<%= score.understanding_percentage >= 80 ? 'pass' : 'fail' %>">
                        <%= formatScore(score.understanding_percentage) %>%
                      </span>
                    </td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        </div>
      <% } %>

      <% if (['admin', 'trainer'].includes(user.userRole)) { %>
        <div class="dashboard-section">
          <h2>Certificate</h2>
          <% if (certificateReleaseOverride) { %>
            <div class="trainer-comment-card">
              <h3>Certificate Released With Justification</h3>
              <p><strong>Enrolment score at release:</strong> <%= formatScore(certificateReleaseOverride.certificate_enrolment_score) %>%</p>
              <p><strong>Released by:</strong> <%= certificateReleaseOverride.released_by_first_name %> <%= certificateReleaseOverride.released_by_last_name %></p>
              <p><strong>Released at:</strong> <%= new Date(certificateReleaseOverride.released_at).toLocaleString() %></p>
              <p><strong>Justification:</strong> <%= certificateReleaseOverride.justification %></p>
            </div>
          <% } %>
          <div style="display: flex; flex-wrap: wrap; gap: 0.5rem; align-items: center;">
            <% if (certificateActions && certificateActions.canShowCertificate) { %>
              <a href="/training/<%= enrollment.training_id %>/certificate/<%= enrollment.id %>" target="_blank" class="btn btn-sm btn-success">
                <i class="fas fa-certificate"></i> View Certificate
              </a>
            <% } %>
            <% if (certificateActions && certificateActions.canReleaseCertificateOverride && (enrollment.type !== 'main' || user.userRole === 'admin')) { %>
              <button type="button" class="btn btn-sm btn-warning" onclick="openCertificateReleaseModal()">
                <i class="fas fa-file-signature"></i> Release Certificate
              </button>
            <% } %>
            <a href="/training/<%= enrollment.training_id %>?tab=marks" class="btn btn-sm btn-outline">
              <i class="fas fa-chart-bar"></i> Open Marks Tab
            </a>
          </div>
          <% if (certificateActions && certificateActions.canReleaseCertificateOverride) { %>
            <p class="text-muted" style="margin-top: 0.75rem; font-size: 0.875rem;">
              Use <strong>Release Certificate</strong> when the enrolment test score is below 70%. A justification is required and stored permanently. This is separate from <strong>Release Scores</strong>.
            </p>
          <% } %>
        </div>
      <% } %>
      
      <!-- Attendance Summary -->
      <% if (attendance && attendance.total_days > 0) { %>
        <div class="dashboard-section">
          <h2>Attendance Summary</h2>
          <div class="stats-grid">
            <div class="stat-card">
              <h3><%= attendance.total_days %></h3>
              <p>Total Days</p>
            </div>
            <div class="stat-card">
              <h3 style="color: var(--color-success);"><%= attendance.present_days %></h3>
              <p>Present</p>
            </div>
            <div class="stat-card">
              <h3 style="color: var(--color-error);"><%= attendance.absent_days %></h3>
              <p>Absent</p>
            </div>
            <div class="stat-card">
              <h3 style="color: var(--color-orange);"><%= attendance.late_days %></h3>
              <p>Late</p>
            </div>
          </div>
        </div>
      <% } %>
      
      <!-- Download Results removed -->
    </div>

    <% if (['admin', 'trainer'].includes(user.userRole) && certificateActions && certificateActions.canReleaseCertificateOverride && (enrollment.type !== 'main' || user.userRole === 'admin')) { %>
      <div class="cert-release-modal-overlay" id="cert-release-modal" aria-hidden="true">
        <div class="cert-release-modal" role="dialog" aria-modal="true" aria-labelledby="cert-release-modal-title">
          <div class="cert-release-modal-header" id="cert-release-modal-title">Release Certificate</div>
          <div class="cert-release-modal-body">
            <p id="cert-release-modal-summary"></p>
            <label for="cert-release-justification" style="display:block; font-size:0.8125rem; font-weight:600; margin-bottom:0.35rem;">Justification (required)</label>
            <textarea id="cert-release-justification" maxlength="2000" placeholder="Explain why the certificate is being released despite the enrolment test score being below 70%."></textarea>
          </div>
          <div class="cert-release-modal-actions">
            <button type="button" class="btn btn-sm btn-outline" onclick="closeCertificateReleaseModal()">Cancel</button>
            <button type="button" class="btn btn-sm btn-warning" id="cert-release-submit-btn" onclick="submitCertificateRelease()">
              <i class="fas fa-file-signature"></i> Confirm Release
            </button>
          </div>
        </div>
      </div>
    <% } %>
  </main>
  
  <script>
    async function allowDownload(enrollmentId) {
      try {
        const response = await fetch(`/results/allow-download/${enrollmentId}`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          }
        });
        
        const data = await response.json();
        if (data.success) {
          window.qssShowSuccess && window.qssShowSuccess('Trainee can now download their results.', 'Success');
          location.reload();
        } else {
          window.qssShowError && window.qssShowError('Error allowing download.', 'Error');
        }
      } catch (error) {
        console.error('Error:', error);
        window.qssShowError && window.qssShowError('Error allowing download.', 'Error');
      }
    }
    
    async function calculateGrades(enrollmentId) {
      try {
        const response = await fetch(`/results/calculate-grades/${enrollmentId}`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          }
        });
        
        const data = await response.json();
        if (data.success) {
          window.qssShowSuccess && window.qssShowSuccess('Grades calculated successfully.', 'Success');
          location.reload();
        } else {
          window.qssShowError && window.qssShowError('Error calculating grades: ' + (data.error || 'Unknown error'), 'Error');
        }
      } catch (error) {
        console.error('Error:', error);
        window.qssShowError && window.qssShowError('Error calculating grades.', 'Error');
      }
    }

    function openCertificateReleaseModal() {
      const overlay = document.getElementById('cert-release-modal');
      const summary = document.getElementById('cert-release-modal-summary');
      const textarea = document.getElementById('cert-release-justification');
      if (!overlay || !summary || !textarea) return;

      const certScore = <%= certificateActions && certificateActions.certAttempt ? parseFloat(certificateActions.certAttempt.score) || 0 : 0 %>;
      summary.textContent = `Release certificate for <%= enrollment.first_name %> <%= enrollment.last_name %>? Enrolment test score: ${certScore.toFixed(1)}% (below 70%). This action is recorded with your justification.`;
      textarea.value = '';
      overlay.classList.add('is-open');
      overlay.setAttribute('aria-hidden', 'false');
      textarea.focus();
    }

    function closeCertificateReleaseModal() {
      const overlay = document.getElementById('cert-release-modal');
      if (overlay) {
        overlay.classList.remove('is-open');
        overlay.setAttribute('aria-hidden', 'true');
      }
    }

    async function submitCertificateRelease() {
      const justification = (document.getElementById('cert-release-justification')?.value || '').trim();
      if (justification.length < 10) {
        window.qssShowError && window.qssShowError('Please enter a justification of at least 10 characters.');
        return;
      }

      const btn = document.getElementById('cert-release-submit-btn');
      const originalSubmit = btn ? btn.innerHTML : '';
      if (btn) {
        btn.disabled = true;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Releasing...';
      }

      try {
        const response = await fetch(`/training/<%= enrollment.training_id %>/enrollment/<%= enrollment.id %>/certificate/release-override`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ justification })
        });
        const data = await response.json();

        if (data.success) {
          closeCertificateReleaseModal();
          window.qssShowMessage && window.qssShowMessage({
            type: 'success',
            title: 'Certificate Released',
            message: data.message || 'Certificate released with recorded justification.',
            onClose: () => location.reload()
          });
        } else {
          window.qssShowError && window.qssShowError('Error releasing certificate: ' + (data.error || 'Unknown error'));
          if (btn) {
            btn.disabled = false;
            btn.innerHTML = originalSubmit;
          }
        }
      } catch (error) {
        console.error('Certificate release error:', error);
        window.qssShowError && window.qssShowError('Error releasing certificate.');
        if (btn) {
          btn.disabled = false;
          btn.innerHTML = originalSubmit;
        }
      }
    }

    document.getElementById('cert-release-modal')?.addEventListener('click', (event) => {
      if (event.target && event.target.id === 'cert-release-modal') {
        closeCertificateReleaseModal();
      }
    });
    
    async function releaseGrades(enrollmentId) {
      if (typeof window.qssConfirm !== 'function') return;
      const ok = await window.qssConfirm({
        title: 'Release Grades?',
        message: 'Are you sure you want to release grades? Trainees will be able to see their final grades.',
        confirmText: 'Release',
        cancelText: 'Cancel',
        danger: true
      });
      if (!ok) return;
      
      try {
        const response = await fetch(`/results/release-grades/${enrollmentId}`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          }
        });
        
        const data = await response.json();
        if (data.success) {
          window.qssShowSuccess && window.qssShowSuccess('Grades released successfully.', 'Success');
          location.reload();
        } else {
          window.qssShowError && window.qssShowError('Error releasing grades: ' + (data.error || 'Unknown error'), 'Error');
        }
      } catch (error) {
        console.error('Error:', error);
        window.qssShowError && window.qssShowError('Error releasing grades.', 'Error');
      }
    }
  </script>
  <% if (user.userRole === 'trainee' && tests && tests.some(t => t.test_type === 'certificate_enrolment' && (parseFloat(t.score) || 0) >= 70)) { %>
    <script>
      (function () {
        const canvas = document.getElementById('celebration-confetti-canvas');
        if (!canvas) return;
        const ctx = canvas.getContext('2d');
        const DPR = Math.max(1, window.devicePixelRatio || 1);

        function resize() {
          canvas.width = Math.floor(window.innerWidth * DPR);
          canvas.height = Math.floor(window.innerHeight * DPR);
          canvas.style.width = window.innerWidth + 'px';
          canvas.style.height = window.innerHeight + 'px';
          ctx.setTransform(DPR, 0, 0, DPR, 0, 0);
        }
        resize();
        window.addEventListener('resize', resize);

        const colors = ['#fbbc04', '#34a853', '#4285f4', '#ea4335', '#ff7f50'];
        const particles = Array.from({ length: 180 }, () => ({
          x: Math.random() * window.innerWidth,
          y: -20 - Math.random() * window.innerHeight,
          r: 4 + Math.random() * 6,
          c: colors[Math.floor(Math.random() * colors.length)],
          vy: 1.5 + Math.random() * 3.5,
          vx: -1 + Math.random() * 2,
          rot: Math.random() * Math.PI,
          vr: (Math.random() - 0.5) * 0.2
        }));

        let start = performance.now();
        function frame(t) {
          const elapsed = t - start;
          ctx.clearRect(0, 0, window.innerWidth, window.innerHeight);
          particles.forEach(p => {
            p.x += p.vx;
            p.y += p.vy;
            p.rot += p.vr;
            if (p.y > window.innerHeight + 20) {
              p.y = -20;
              p.x = Math.random() * window.innerWidth;
            }
            ctx.save();
            ctx.translate(p.x, p.y);
            ctx.rotate(p.rot);
            ctx.fillStyle = p.c;
            ctx.fillRect(-p.r / 2, -p.r / 2, p.r, p.r);
            ctx.restore();
          });
          if (elapsed < 5000) {
            requestAnimationFrame(frame);
          } else {
            ctx.clearRect(0, 0, window.innerWidth, window.innerHeight);
            canvas.remove();
          }
        }
        requestAnimationFrame(frame);
      })();
    </script>
  <% } %>
  <script src="/js/main.js"></script>
</body>
</html>


