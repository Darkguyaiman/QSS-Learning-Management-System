<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Test Results - LMS</title>
  <link rel="stylesheet" href="/css/styles.css">
  <style>
    .results-scorebox-main-row {
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
      width: max-content;
      margin: 0 auto;
    }
    .results-scorebox-main-row .results-scorebox-sticker {
      position: absolute;
      width: 210px;
      height: 210px;
      right: calc(100% - 10px);
      top: -34px;
      transform: rotate(-12deg);
      z-index: 2;
      filter: drop-shadow(0 12px 18px rgba(0, 0, 0, 0.18));
    }
    .results-scorebox-main-row .results-scorebox-sticker img {
      width: 100%;
      height: 100%;
      object-fit: contain;
    }
    .results-scorebox-main-row .results-scorebox-score {
      position: relative;
      z-index: 1;
    }
    .results-scorebox-cert {
      margin: 0.75rem 0 0;
      font-size: 1.1rem;
      font-weight: 700;
      color: #1a5d1a;
      text-align: center;
    }
    @media (max-width: 640px) {
      .results-scorebox-main-row .results-scorebox-sticker {
        width: 160px;
        height: 160px;
        right: calc(100% - 6px);
        top: -20px;
      }
    }
    #celebration-confetti-canvas {
      position: fixed;
      inset: 0;
      width: 100vw;
      height: 100vh;
      pointer-events: none;
      z-index: 9998;
    }
  </style>
</head>
<body class="has-sidebar">
  <%- include('../partials/sidebar', { user }) %>
  <main class="main-content">
    <div class="container">
      <div class="dashboard-header">
        <h1>Test Results</h1>
        <a href="/training/<%= attempt.training_id %>?tab=tests" class="btn btn-outline">Back to Training Tests</a>
      </div>
      
      <div class="results-summary-card">
        <div class="results-summary-header">
          <div>
            <h2><%= attempt.training_title %></h2>
            <p class="text-muted">
              Test Type: <%= attempt.test_type.replace('_', ' ').replace(/\b\w/g, l => l.toUpperCase()) %>
            </p>
          </div>
          <div class="results-summary-meta">
            <span class="results-summary-label">Completed</span>
            <span class="results-summary-value"><%= new Date(attempt.completed_at).toLocaleString() %></span>
          </div>
        </div>
        
        <% 
          const correctCount = answers.filter(a => a.is_correct).length;
          const passState = (typeof passed !== 'undefined' && passed) ? 'passed' : 'failed';
          const stickerImage = passState === 'passed'
            ? '/images/Test%20Stickers/good%20mark.webp'
            : '/images/Test%20Stickers/bad%20mark.webp';
          const stickerLabel = passState === 'passed' ? 'Passed Sticker' : 'Failed Sticker';
          const isCertificatePass = user.userRole === 'trainee' && attempt.test_type === 'certificate_enrolment' && passState === 'passed';
        %>
        <div class="results-scorebox results-scorebox--<%= passState %>">
          <div class="results-scorebox-main">
            <div class="results-scorebox-main-row">
              <% if (isCertificatePass) { %>
                <div class="results-scorebox-sticker results-scorebox-sticker--passed" aria-hidden="true">
                  <img src="/images/Test%20Stickers/good%20mark.webp" alt="Passed Sticker">
                </div>
              <% } %>
              <div class="results-scorebox-score"><%= attempt.score.toFixed(1) %>%</div>
            </div>
            <div class="results-scorebox-status">
              <% if (typeof passed !== 'undefined' && passed) { %>
                <i class="fas fa-check-circle"></i> Outstanding
              <% } else { %>
                <i class="fas fa-times-circle"></i> Not Passed
              <% } %>
            </div>
            <% if (isCertificatePass) { %>
              <p class="results-scorebox-cert">Congrats you are now a certified K-Laser therapist</p>
            <% } %>
          </div>
          <div class="results-scorebox-details">
            <div class="results-scorebox-detail">
              <span class="results-summary-label">Correct</span>
              <span class="results-summary-value"><%= correctCount %> / <%= attempt.total_questions %></span>
            </div>
            <div class="results-scorebox-detail">
              <span class="results-summary-label">Accuracy</span>
              <span class="results-summary-value"><%= ((correctCount / attempt.total_questions) * 100).toFixed(1) %>%</span>
            </div>
          </div>
          <% if (!isCertificatePass) { %>
            <div class="results-scorebox-sticker results-scorebox-sticker--<%= passState %>" aria-hidden="true">
              <img src="<%= stickerImage %>" alt="<%= stickerLabel %>">
            </div>
          <% } %>
          <% if (typeof canRetake !== 'undefined' && canRetake) { %>
            <div class="results-scorebox-actions">
              <a href="/tests/start/<%= enrollmentId %>/<%= testType %>" class="btn btn-primary">
                <i class="fas fa-redo"></i> Retake Test
              </a>
            </div>
          <% } else if (typeof maxAttemptsReached !== 'undefined' && maxAttemptsReached) { %>
            <div class="results-scorebox-actions">
              <p style="margin: 0; color: #C5221F; font-weight: 500; text-align: center;">
                Maximum attempts reached (<%= failedAttempts %>/<%= maxFailedAttempts %>). Please refer to your trainer for further guidance.
              </p>
            </div>
          <% } %>
        </div>
        <% if (isCertificatePass) { %>
          <canvas id="celebration-confetti-canvas" aria-hidden="true"></canvas>
        <% } %>
      </div>
      
      <div class="results-review-card">
        <div class="results-review-header">
          <h2>Question Review</h2>
          <p class="text-muted"><%= answers.length %> questions</p>
        </div>
        
        <% answers.forEach((answer, index) => { %>
          <div class="results-question-card results-question-card--<%= answer.is_correct ? 'correct' : 'incorrect' %>">
            <div class="results-question-header">
              <h3>Question <%= index + 1 %></h3>
              <% if (answer.is_correct) { %>
                <span class="results-status results-status--correct">Correct</span>
              <% } else { %>
                <span class="results-status results-status--incorrect">Incorrect</span>
              <% } %>
            </div>
            
            <p class="results-question-text"><%= answer.question_text %></p>
            
            <div class="results-answer-block">
              <p><strong>Your Answer:</strong>
                <span class="results-answer results-answer--<%= answer.is_correct ? 'correct' : 'incorrect' %>">
                  <%= answer.selected_answer %> - 
                  <% if (answer.selected_answer === 'A') { %><%= answer.option_a %>
                  <% } else if (answer.selected_answer === 'B') { %><%= answer.option_b %>
                  <% } else if (answer.selected_answer === 'C') { %><%= answer.option_c %>
                  <% } else { %><%= answer.option_d %><% } %>
                </span>
              </p>
              
              <% if (!answer.is_correct && typeof passed !== 'undefined' && passed) { %>
                <p><strong>Correct Answer:</strong> 
                  <span class="results-answer results-answer--correct">
                    <%= answer.correct_answer %> - 
                    <% if (answer.correct_answer === 'A') { %><%= answer.option_a %>
                    <% } else if (answer.correct_answer === 'B') { %><%= answer.option_b %>
                    <% } else if (answer.correct_answer === 'C') { %><%= answer.option_c %>
                    <% } else { %><%= answer.option_d %><% } %>
                  </span>
                </p>
              <% } else if (!answer.is_correct && (typeof passed === 'undefined' || !passed)) { %>
                <p class="results-answer-locked">
                  <i class="fas fa-lock"></i> Correct answers will be shown after you pass the test.
                </p>
              <% } %>
            </div>
            
            <div class="results-option-list">
              <span class="results-option">
                A: <%= answer.option_a %>
              </span>
              <span class="results-option">
                B: <%= answer.option_b %>
              </span>
              <span class="results-option">
                C: <%= answer.option_c %>
              </span>
              <span class="results-option">
                D: <%= answer.option_d %>
              </span>
            </div>
          </div>
        <% }); %>
        
      <div class="results-review-footer">
          <a href="/training/<%= attempt.training_id %>?tab=tests" class="btn btn-primary">Back to Training Tests</a>
      </div>
      </div>
    </div>
  </main>
  <% if (user.userRole === 'trainee' && attempt.test_type === 'certificate_enrolment' && typeof passed !== 'undefined' && passed) { %>
    <script>
      (function () {
        const canvas = document.getElementById('celebration-confetti-canvas');
        if (!canvas) return;
        const ctx = canvas.getContext('2d');
        const DPR = Math.max(1, window.devicePixelRatio || 1);

        function resize() {
          canvas.width = Math.floor(window.innerWidth * DPR);
          canvas.height = Math.floor(window.innerHeight * DPR);
          canvas.style.width = window.innerWidth + 'px';
          canvas.style.height = window.innerHeight + 'px';
          ctx.setTransform(DPR, 0, 0, DPR, 0, 0);
        }
        resize();
        window.addEventListener('resize', resize);

        const colors = ['#fbbc04', '#34a853', '#4285f4', '#ea4335', '#ff7f50'];
        const particles = Array.from({ length: 180 }, () => ({
          x: Math.random() * window.innerWidth,
          y: -20 - Math.random() * window.innerHeight,
          r: 4 + Math.random() * 6,
          c: colors[Math.floor(Math.random() * colors.length)],
          vy: 1.5 + Math.random() * 3.5,
          vx: -1 + Math.random() * 2,
          rot: Math.random() * Math.PI,
          vr: (Math.random() - 0.5) * 0.2
        }));

        let start = performance.now();
        function frame(t) {
          const elapsed = t - start;
          ctx.clearRect(0, 0, window.innerWidth, window.innerHeight);
          particles.forEach(p => {
            p.x += p.vx;
            p.y += p.vy;
            p.rot += p.vr;
            if (p.y > window.innerHeight + 20) {
              p.y = -20;
              p.x = Math.random() * window.innerWidth;
            }
            ctx.save();
            ctx.translate(p.x, p.y);
            ctx.rotate(p.rot);
            ctx.fillStyle = p.c;
            ctx.fillRect(-p.r / 2, -p.r / 2, p.r, p.r);
            ctx.restore();
          });
          if (elapsed < 5000) {
            requestAnimationFrame(frame);
          } else {
            ctx.clearRect(0, 0, window.innerWidth, window.innerHeight);
            canvas.remove();
          }
        }
        requestAnimationFrame(frame);
      })();
    </script>
  <% } %>
</body>
</html>
