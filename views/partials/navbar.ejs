<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<!-- Mobile Top Nav: Logo + Title -->
<div class="mobile-navbar-header">
  <a href="/dashboard" class="mobile-navbar-logo" aria-label="QSS Home">
    <img src="/favicon.ico" alt="QSS Logo">
  </a>
  <div class="mobile-navbar-titles">
    <div class="mobile-navbar-app">Q-Learning Management System</div>
    <div class="mobile-navbar-page">
      <%= typeof pageTitle !== 'undefined' ? pageTitle : 'Dashboard' %>
    </div>
  </div>
</div>

<!-- Main Navbar (Desktop top bar, Mobile bottom nav tabs) -->
<nav class="navbar">
  <div class="navbar-container">
    <!-- Desktop Brand -->
    <div class="navbar-brand">
      <a href="/dashboard">
        QSS LMS
      </a>
    </div>

    <!-- Tabs + Profile -->
    <div class="navbar-menu">
      <a href="/dashboard" class="nav-link" data-route="/dashboard">
        <i class="fas fa-home"></i>
        <span>Home</span>
      </a>

      <a href="/training" class="nav-link" data-route="/training">
        <i class="fas fa-book"></i>
        <span>Trainings</span>
      </a>

      <% if (['admin', 'trainer'].includes(user.userRole)) { %>
        <a href="/trainees" class="nav-link" data-route="/trainees">
          <i class="fas fa-users"></i>
          <span>Trainees</span>
        </a>
      <% } %>

      <a href="/profile" class="nav-link" data-route="/profile">
        <% if (user && user.userProfile) { %>
          <span class="profile-picture-small-wrapper">
            <img src="<%= user.userProfile %>" alt="Profile" class="profile-picture-small">
          </span>
        <% } else { %>
          <i class="fas fa-user-circle"></i>
        <% } %>
        <span>Profile</span>
      </a>
    </div>
  </div>
</nav>

<script>
  // Highlight active tab based on current path (for both desktop and mobile)
  document.addEventListener('DOMContentLoaded', function() {
    var currentPath = window.location.pathname || '/';
    var links = document.querySelectorAll('.navbar .nav-link[data-route]');

    links.forEach(function(link) {
      var route = link.getAttribute('data-route');
      if (!route) return;

      // Dashboard: root or /dashboard
      if (route === '/dashboard' && (currentPath === '/' || currentPath === '/dashboard')) {
        link.classList.add('active');
        return;
      }

      // Other routes: any path starting with the route
      if (route !== '/dashboard' && currentPath.startsWith(route)) {
        link.classList.add('active');
      }
    });
  });
</script>
