  <% if (typeof traineeImportEnabled !== 'undefined' && traineeImportEnabled) { %>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
  <% } %>
  <script src="/js/main.js"></script>
  <script>
    function syncBulkActionsVisibility() {
      const content = document.getElementById('filters-content');
      const bulkActions = document.getElementById('bulk-actions-bar');
      if (!content || !bulkActions) return;
      const isExpanded = content.style.display !== 'none' && content.style.display !== '';
      bulkActions.style.display = isExpanded ? 'flex' : 'none';
    }

    // Toggle filters visibility
    function toggleFilters() {
      const content = document.getElementById('filters-content');
      const icon = document.getElementById('filter-toggle-icon');
      const text = document.getElementById('filter-toggle-text');
      
      const isCurrentlyHidden = content.style.display === 'none' || content.style.display === '';
      
      if (isCurrentlyHidden) {
        content.style.display = 'block';
        icon.classList.remove('fa-chevron-down');
        icon.classList.add('fa-chevron-up');
        text.textContent = 'Hide Filters';
        localStorage.setItem('traineeFiltersExpanded', 'true');
      } else {
        content.style.display = 'none';
        icon.classList.remove('fa-chevron-up');
        icon.classList.add('fa-chevron-down');
        text.textContent = 'Show Filters';
        localStorage.setItem('traineeFiltersExpanded', 'false');
      }

      syncBulkActionsVisibility();
    }
    
    // Check if filters should be shown by default
    document.addEventListener('DOMContentLoaded', function() {
      const content = document.getElementById('filters-content');
      const icon = document.getElementById('filter-toggle-icon');
      const text = document.getElementById('filter-toggle-text');
      
      <% 
        const hasActiveFilters = (typeof selectedStatuses !== 'undefined' && selectedStatuses.length > 0) ||
                                 (typeof selectedHealthcare !== 'undefined' && selectedHealthcare) ||
                                 (typeof searchQuery !== 'undefined' && searchQuery);
      %>
      
      // Check localStorage for saved state
      const savedState = localStorage.getItem('traineeFiltersExpanded');
      
      // Determine if filters should be shown
      let shouldShow = false;
      
      if (savedState !== null) {
        // Use saved preference
        shouldShow = savedState === 'true';
      } else {
        // First time - show if filters are active
        shouldShow = <%= hasActiveFilters ? 'true' : 'false' %>;
        if (shouldShow) {
          localStorage.setItem('traineeFiltersExpanded', 'true');
        }
      }
      
      // Apply state
      if (shouldShow) {
        content.style.display = 'block';
        icon.classList.remove('fa-chevron-down');
        icon.classList.add('fa-chevron-up');
        text.textContent = 'Hide Filters';
      } else {
        content.style.display = 'none';
        icon.classList.remove('fa-chevron-up');
        icon.classList.add('fa-chevron-down');
        text.textContent = 'Show Filters';
      }

      syncBulkActionsVisibility();
    });
    
    // Handle search form submission
    function handleSearch(event) {
      event.preventDefault();
      applyFilters();
    }
    
    // Apply all filters
    function applyFilters() {
      const url = new URL(window.location.href);
      
      // Get all filter values
      const search = document.getElementById('global-search').value.trim();
      const healthcare = document.getElementById('healthcare-filter').value;
      
      // Get existing status filters
      const statuses = url.searchParams.getAll('status');
      
      // Clear all params
      url.search = '';
      
      // Add status filters back
      statuses.forEach(s => url.searchParams.append('status', s));
      
      // Add new filters
      if (search) url.searchParams.set('search', search);
      if (healthcare) url.searchParams.set('healthcare', healthcare);
      window.location.href = url.toString();
    }
    
    // Update status filter (for chips)
    function updateFilter(event, filterType, value) {
      event.preventDefault();
      const url = new URL(window.location.href);
      const currentValues = url.searchParams.getAll(filterType);
      
      if (currentValues.includes(value)) {
        // Remove filter
        const newValues = currentValues.filter(v => v !== value);
        url.searchParams.delete(filterType);
        newValues.forEach(v => url.searchParams.append(filterType, v));
      } else {
        // Add filter
        url.searchParams.append(filterType, value);
      }
      
      // Preserve other filters
      const search = document.getElementById('global-search')?.value.trim();
      const healthcare = document.getElementById('healthcare-filter')?.value;
      url.searchParams.delete('page');
      
      if (search) url.searchParams.set('search', search);
      if (healthcare) url.searchParams.set('healthcare', healthcare);
      
      window.location.href = url.toString();
    }

    // Bulk actions
    function getSelectedIds() {
      const ids = new Set();
      document.querySelectorAll('.trainee-checkbox:checked').forEach(cb => {
        if (cb.value) ids.add(cb.value);
      });
      return Array.from(ids);
    }

    function updateSelectedCount() {
      const count = getSelectedIds().length;
      const countEl = document.getElementById('selected-count');
      if (countEl) {
        countEl.textContent = `${count} selected`;
      }
    }

    function setAllCheckboxes(checked) {
      document.querySelectorAll('.trainee-checkbox').forEach(cb => {
        cb.checked = checked;
      });
      const selectAll = document.getElementById('select-all');
      if (selectAll) selectAll.checked = checked;
      updateSelectedCount();
    }

    document.getElementById('select-all')?.addEventListener('change', function() {
      setAllCheckboxes(this.checked);
    });

    document.querySelectorAll('.trainee-checkbox').forEach(cb => {
      cb.addEventListener('change', updateSelectedCount);
    });

    document.getElementById('bulk-actions-form')?.addEventListener('submit', async function(e) {
      const selected = getSelectedIds();
      const action = (e.submitter && e.submitter.getAttribute('formaction')) || '';
      if (selected.length === 0) {
        e.preventDefault();
        window.qssShowWarning && window.qssShowWarning('Please select at least one trainee.', 'No Selection');
        return;
      }
      if (action.includes('/bulk-status')) {
        const status = document.getElementById('bulk-status')?.value;
        if (!status) {
          e.preventDefault();
          window.qssShowWarning && window.qssShowWarning('Please choose a status to apply.', 'Missing Status');
          return;
        }
      }
      let confirmMsg = e.submitter && e.submitter.dataset.confirm;
      if (confirmMsg) {
        e.preventDefault();
        if (typeof window.qssConfirm !== 'function') return;
        if (action.includes('/bulk-delete')) {
          confirmMsg = `Delete ${selected.length} trainee(s)?\n\nThis will permanently remove their records, including training history and certificates.`;
        }
        const ok = await window.qssConfirm({ title: 'Confirm Deletion', message: confirmMsg, confirmText: 'Delete', cancelText: 'Cancel', danger: true });
        if (ok) {
          e.currentTarget.submit();
        }
      }
    });

    // Bulk status dropdown
    if (typeof TailwindDropdown === 'function' && document.getElementById('bulkStatusDropdown')) {
      new TailwindDropdown('bulkStatusDropdown', {
        items: [
          { label: 'Change status...', value: '' },
          { label: 'Active', value: 'active' },
          { label: 'Inactive', value: 'inactive' },
          { label: 'Suspended', value: 'suspended' },
          { label: 'Registered', value: 'registered' }
        ],
        placeholder: 'Change status...',
        multiSelect: false,
        initialValue: '',
        onChange: function(val) {
          const input = document.getElementById('bulk-status');
          if (input) input.value = val || '';
        }
      });
    }

    (function initTraineeViewModal() {
      const overlay = document.getElementById('trainee-view-modal-overlay');
      const closeBtn = document.getElementById('trainee-view-modal-close');
      const title = document.getElementById('trainee-view-modal-title');
      const subtitle = document.getElementById('trainee-view-modal-subtitle');
      const emailEl = document.getElementById('modal-email');
      const designationEl = document.getElementById('modal-designation');
      const areaEl = document.getElementById('modal-area');
      const firstTrainingEl = document.getElementById('modal-first-training');
      const latestTrainingEl = document.getElementById('modal-latest-training');
      const recertificationDateEl = document.getElementById('modal-recertification-date');
      if (!overlay) return;

      function renderAreas(areaValue) {
        const normalized = (areaValue || '').split(',').map(area => area.trim()).filter(Boolean);
        if (!normalized.length) {
          areaEl.textContent = '-';
          return;
        }
        areaEl.innerHTML = normalized.map(area => `<span class="specialization-chip">${area}</span>`).join('');
        areaEl.classList.add('specialization-chips');
      }

      function clearAreaLayout() {
        areaEl.classList.remove('specialization-chips');
      }

      function openModal(button) {
        title.textContent = 'Trainee Details';
        subtitle.textContent = button.dataset.name || '';
        emailEl.textContent = button.dataset.email || '-';
        designationEl.textContent = button.dataset.designation || '-';
        firstTrainingEl.textContent = button.dataset.firstTraining || '-';
        latestTrainingEl.textContent = button.dataset.latestTraining || '-';
        recertificationDateEl.textContent = button.dataset.recertificationDate || '-';
        clearAreaLayout();
        renderAreas(button.dataset.area || '');
        overlay.classList.add('active');
        document.body.style.overflow = 'hidden';
      }

      function closeModal() {
        overlay.classList.remove('active');
        document.body.style.overflow = '';
      }

      document.querySelectorAll('.trainee-view-btn').forEach(button => {
        button.addEventListener('click', () => openModal(button));
      });

      closeBtn?.addEventListener('click', closeModal);
      overlay.addEventListener('click', (event) => {
        if (event.target === overlay) closeModal();
      });
      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape' && overlay.classList.contains('active')) {
          closeModal();
        }
      });
    })();

<% if (typeof traineeImportEnabled !== 'undefined' && traineeImportEnabled) { %>
    (function initTraineeExcelImport() {
      const HEADER_MAP = {
        'timestamp': 'timestamp',
        'name': 'full_name',
        'ic/passport': 'ic_passport',
        'email': 'email',
        'handphone number': 'handphone_number',
        'healthcare': 'healthcare',
        'designation': 'designation',
        'trainee id': 'trainee_id',
        'area of specialization': 'area_of_specialization',
        'serial number': 'serial_number',
        'first training': 'first_training',
        'latest training': 'latest_training',
        're-certification date': 'recertification_date',
        'number of completed trainings': 'number_of_completed_trainings',
        'trainee status': 'trainee_status'
      };
      function normH(h) {
        return String(h || '').trim().toLowerCase().replace(/\u00a0/g, ' ').replace(/\s+/g, ' ');
      }
      function rowToPayload(headerRow, dataRow) {
        const o = {};
        for (let i = 0; i < headerRow.length; i++) {
          const field = HEADER_MAP[normH(headerRow[i])];
          if (!field || field === 'timestamp') continue;
          let v = dataRow[i];
          if (v === undefined || v === null) v = '';
          o[field] = v;
        }
        return o;
      }
      function validateRows(trainees) {
        const errs = [];
        const allowed = new Set(['active', 'inactive', 'suspended', 'registered']);
        const seenE = new Set();
        const seenT = new Set();
        trainees.forEach(function (t, idx) {
          const rowNum = idx + 2;
          const name = String(t.full_name || '').trim();
          if (!name) errs.push('Row ' + rowNum + ': Name is required');
          if (!String(t.ic_passport || '').trim()) errs.push('Row ' + rowNum + ': IC/Passport is required');
          const em = String(t.email || '').trim().toLowerCase();
          if (!em) errs.push('Row ' + rowNum + ': Email is required');
          var st = String(t.trainee_status || '').trim().toLowerCase();
          if (!st) st = 'registered';
          if (!allowed.has(st)) errs.push('Row ' + rowNum + ': Trainee Status must be active, inactive, suspended, or registered');
          if (em && seenE.has(em)) errs.push('Row ' + rowNum + ': Duplicate email in file');
          if (em) seenE.add(em);
          var tid = String(t.trainee_id || '').trim();
          if (tid.length > 10) errs.push('Row ' + rowNum + ': Trainee ID max 10 characters');
          if (tid) {
            if (seenT.has(tid)) errs.push('Row ' + rowNum + ': Duplicate Trainee ID in file');
            seenT.add(tid);
          }
        });
        return errs;
      }

      var modal = document.getElementById('traineeImportModal');
      var fileInput = document.getElementById('traineeImportFile');
      var btn = document.getElementById('traineeImportExcelBtn');
      var closeBtn = document.getElementById('traineeImportModalClose');
      var cancelBtn = document.getElementById('traineeImportCancelBtn');
      var submitBtn = document.getElementById('traineeImportSubmitBtn');
      var errEl = document.getElementById('traineeImportErrors');
      var okEl = document.getElementById('traineeImportSuccess');
      var pendingPayload = null;

      function resetModalFeedback() {
        pendingPayload = null;
        if (errEl) { errEl.style.display = 'none'; errEl.innerHTML = ''; }
        if (okEl) { okEl.style.display = 'none'; okEl.textContent = ''; }
        if (submitBtn) submitBtn.disabled = true;
      }
      function closeM() {
        if (modal) modal.classList.remove('active');
        if (fileInput) fileInput.value = '';
        resetModalFeedback();
      }

      btn?.addEventListener('click', function () {
        if (fileInput) fileInput.click();
      });
      closeBtn?.addEventListener('click', closeM);
      cancelBtn?.addEventListener('click', closeM);
      modal?.addEventListener('click', function (e) {
        if (e.target === modal) closeM();
      });

      fileInput?.addEventListener('change', function () {
        var f = this.files[0];
        if (!f || typeof XLSX === 'undefined') return;
        if (modal) modal.classList.add('active');
        resetModalFeedback();
        var reader = new FileReader();
        reader.onload = function (ev) {
          try {
            var data = new Uint8Array(ev.target.result);
            var wb = XLSX.read(data, { type: 'array' });
            var sheetName = wb.SheetNames.find(function (n) { return String(n).toLowerCase() === 'trainees'; }) || wb.SheetNames[0];
            var sh = wb.Sheets[sheetName];
            var rows = XLSX.utils.sheet_to_json(sh, { header: 1, defval: '', raw: true, blankrows: false });
            if (!rows.length) {
              errEl.innerHTML = '<strong>No data found in sheet.</strong>';
              errEl.style.display = 'block';
              return;
            }
            var headerRow = rows[0].map(function (c) { return String(c || ''); });
            var trainees = [];
            for (var r = 1; r < rows.length; r++) {
              var line = rows[r];
              if (!line || !line.length) continue;
              if (line.every(function (c) { return c === '' || c === null || c === undefined; })) continue;
              var obj = rowToPayload(headerRow, line);
              if (!String(obj.full_name || '').trim() && !String(obj.email || '').trim() && !String(obj.ic_passport || '').trim()) continue;
              if (!obj.trainee_status) obj.trainee_status = 'registered';
              trainees.push(obj);
            }
            var verr = validateRows(trainees);
            if (verr.length) {
              errEl.innerHTML = '<strong>Fix these issues:</strong><ul>' + verr.map(function (e) { return '<li>' + e + '</li>'; }).join('') + '</ul>';
              errEl.style.display = 'block';
              return;
            }
            if (!trainees.length) {
              errEl.innerHTML = '<strong>No valid data rows.</strong>';
              errEl.style.display = 'block';
              return;
            }
            pendingPayload = trainees;
            okEl.textContent = trainees.length + ' trainee row(s) ready. Click Import to save.';
            okEl.style.display = 'block';
            submitBtn.disabled = false;
          } catch (er) {
            errEl.innerHTML = '<strong>Could not read file:</strong> ' + (er.message || String(er));
            errEl.style.display = 'block';
          }
        };
        reader.readAsArrayBuffer(f);
      });

      submitBtn?.addEventListener('click', function () {
        if (!pendingPayload || !pendingPayload.length) return;
        submitBtn.disabled = true;
        var prevHtml = submitBtn.innerHTML;
        submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Importing…';
        fetch('/trainees/import/bulk', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ trainees: pendingPayload })
        })
          .then(function (res) { return res.json().then(function (data) { return { res: res, data: data }; }); })
          .then(function (out) {
            if (out.data.success) {
              if (typeof window.qssShowSuccess === 'function') {
                window.qssShowSuccess('Imported ' + out.data.inserted + ' trainee(s).', 'Import complete');
              }
              setTimeout(function () { window.location.href = '/trainees'; }, 500);
              return;
            }
            submitBtn.disabled = false;
            submitBtn.innerHTML = prevHtml;
            if (out.data.errors && out.data.errors.length) {
              errEl.innerHTML = '<strong>Server validation:</strong><ul>' + out.data.errors.map(function (e) { return '<li>' + e + '</li>'; }).join('') + '</ul>';
              errEl.style.display = 'block';
            } else {
              errEl.innerHTML = '<strong>' + (out.data.error || 'Import failed') + '</strong>';
              errEl.style.display = 'block';
            }
            if (typeof TailwindModal !== 'undefined' && TailwindModal.error) {
              TailwindModal.error('Import failed', out.data.error || 'See messages below.');
            }
          })
          .catch(function (err) {
            submitBtn.disabled = false;
            submitBtn.innerHTML = prevHtml;
            errEl.innerHTML = '<strong>Network error:</strong> ' + (err.message || '');
            errEl.style.display = 'block';
          });
      });
    })();
<% } %>
  </script>
</body>
