  <% if (typeof traineeImportEnabled !== 'undefined' && traineeImportEnabled) { %>
  <input type="file" id="traineeImportFile" accept=".xlsx,.xls" style="display:none" />
  <div id="traineeImportModal" class="trainee-import-modal" role="dialog" aria-modal="true">
    <div class="trainee-import-modal-content" onclick="event.stopPropagation();">
      <div class="trainee-import-modal-header">
        <div>
          <h2 style="margin:0;font-size:1.125rem;color:#202124;"><i class="fas fa-file-excel" style="color:#217346;"></i> Import trainees from Excel</h2>
          <p style="margin:0.35rem 0 0;font-size:0.8125rem;color:#5F6368;">Only the first sheet is read. Row 1 must be the header row. Required columns: Name, IC/Passport, Email. Empty Trainee ID will be auto-generated. <strong>Area of Specialization</strong> can be one name or several separated by commas or semicolons (for example <code style="font-size:0.75rem;">Pain management, Diabetic foot ulcer</code>)—each name must exist in your Areas of Specialization list (matching is case-insensitive).</p>
        </div>
        <button type="button" class="close-modal" id="traineeImportModalClose" style="background:none;border:none;font-size:1.35rem;cursor:pointer;color:#5F6368;line-height:1;" aria-label="Close">&times;</button>
      </div>
      <p style="font-size:0.8125rem;color:#B45309;background:#FFFBEB;padding:0.65rem 0.75rem;border-radius:8px;border:1px solid #FCD34D;margin:0 0 0.75rem;">
        <strong>Password:</strong> Imported trainees all receive the same temporary password <code style="background:#FEF3C7;padding:0 4px;border-radius:4px;">TRAINEE_IMPORT_DEFAULT_PASSWORD</code> from server env (default <code style="background:#FEF3C7;padding:0 4px;border-radius:4px;">LmsTraineeImport#1</code>). Change it in production via environment variable.
      </p>
      <div id="traineeImportErrors" class="trainee-import-validation-errors" style="display:none;margin-bottom:1rem;"></div>
