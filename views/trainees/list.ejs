      <div class="trainee-import-modal-actions">
        <button type="button" class="btn btn-outline" id="traineeImportCancelBtn">Cancel</button>
        <button type="button" class="btn btn-success" id="traineeImportSubmitBtn" disabled><i class="fas fa-upload"></i> Import</button>
