<%
  const affiliatedCompany = ((training && training.affiliated_company) ? String(training.affiliated_company) : 'QSS').toUpperCase() === 'PMS' ? 'PMS' : 'QSS';
  const affiliatedBrand = affiliatedCompany === 'PMS'
    ? { code: 'PMS', name: 'PMS', logo: '/images/Affiliated%20Companies/pmslogo.svg' }
    : { code: 'QSS', name: 'Quick Stop Solution', logo: '/images/Affiliated%20Companies/qsslogo.svg' };
%>
<!-- Attendance Report Sub-tab -->
<div id="attendance-report" class="attendance-sub-content">
  <div class="attendance-update-container attendance-report-shell">
    <div class="form-group">
      <label for="report-session-select">Select Session <span class="required">*</span></label>
      <div class="select-wrapper">
        <select id="report-session-select" class="form-input session-select" required>
          <option value="">-- Select a session --</option>
        </select>
        <i class="fas fa-chevron-down select-arrow"></i>
      </div>
    </div>

    <div id="report-preview" style="display:none;">
      <div class="attendance-report-toolbar">
        <div>
          <div class="attendance-report-toolbar-title">Professional Attendance Report</div>
          <div id="report-session-meta" class="attendance-report-toolbar-subtitle"></div>
        </div>
        <button type="button" id="btn-generate-report" class="btn btn-primary">
          <i class="fas fa-file-pdf"></i> Generate PDF
        </button>
      </div>

      <article class="attendance-report-document">
        <header class="attendance-report-letterhead">
          <div class="attendance-report-brand">
            <img id="attendance-report-brand-logo" src="<%= affiliatedBrand.logo %>" alt="<%= affiliatedBrand.name %>" class="attendance-report-logo">
            <div>
              <h3 id="attendance-report-brand-name"><%= affiliatedBrand.name %></h3>
              <p>Learning Management System</p>
            </div>
          </div>
          <div class="attendance-report-title-wrap">
            <h2>Attendance Report</h2>
            <p id="report-generated-at"></p>
          </div>
        </header>

        <section class="attendance-report-meta-grid">
          <div class="attendance-report-meta-item">
            <span class="label">Training Title</span>
            <span class="value" id="report-field-training">-</span>
          </div>
          <div class="attendance-report-meta-item">
            <span class="label">Session Date</span>
            <span class="value" id="report-field-date">-</span>
          </div>
          <div class="attendance-report-meta-item">
            <span class="label">Session Time</span>
            <span class="value" id="report-field-time">-</span>
          </div>
          <div class="attendance-report-meta-item">
            <span class="label">Duration</span>
            <span class="value" id="report-field-duration">-</span>
          </div>
          <div class="attendance-report-meta-item">
            <span class="label">Prepared By</span>
            <span class="value" id="report-field-generated-by">-</span>
          </div>
          <div class="attendance-report-meta-item">
            <span class="label">Report Reference</span>
            <span class="value" id="report-field-reference">-</span>
          </div>
        </section>

        <div class="attendance-summary-table-container attendance-report-table-wrap">
          <div class="table-wrapper">
            <table class="attendance-summary-table attendance-report-table" id="report-table">
              <thead>
                <tr>
                  <th style="width: 56px;">No.</th>
                  <th>Trainee Name</th>
                  <th style="width: 140px;">Trainee ID</th>
                  <th class="text-center" style="width: 130px;">Status</th>
                  <th>Notes</th>
                </tr>
              </thead>
              <tbody id="report-table-body"></tbody>
            </table>
          </div>
        </div>

        <section class="attendance-report-summary-section">
          <h4>Attendance Summary</h4>
          <div class="attendance-summary-table-container">
            <div class="table-wrapper">
              <table class="attendance-summary-table attendance-report-summary-table">
                <thead>
                  <tr>
                    <th>Total Trainees</th>
                    <th>Present</th>
                    <th>Absent</th>
                    <th>Late</th>
                  </tr>
                </thead>
                <tbody>
                  <tr>
                    <td id="report-total-count">0</td>
                    <td id="report-present-count">0</td>
                    <td id="report-absent-count">0</td>
                    <td id="report-late-count">0</td>
                  </tr>
                </tbody>
              </table>
            </div>
          </div>
        </section>

        <footer class="attendance-report-signatures">
          <div class="signature-block">
            <div class="signature-role">Prepared By (Trainer)</div>
            <div class="signature-field">
              <div class="signature-line"></div>
              <div class="signature-label">Signature</div>
            </div>
            <div class="signature-field">
              <div class="signature-line"></div>
              <div class="signature-label">Name</div>
            </div>
            <div class="signature-field">
              <div class="signature-line date-line"></div>
              <div class="signature-label">Date</div>
            </div>
          </div>
          <div class="signature-block">
            <div class="signature-role">Verified By</div>
            <div class="signature-field">
              <div class="signature-line"></div>
              <div class="signature-label">Signature</div>
            </div>
            <div class="signature-field">
              <div class="signature-line"></div>
              <div class="signature-label">Name</div>
            </div>
            <div class="signature-field">
              <div class="signature-line date-line"></div>
              <div class="signature-label">Date</div>
            </div>
          </div>
          <div class="signature-block">
            <div class="signature-role">Approved By</div>
            <div class="signature-field">
              <div class="signature-line"></div>
              <div class="signature-label">Signature</div>
            </div>
            <div class="signature-field">
              <div class="signature-line"></div>
              <div class="signature-label">Name</div>
            </div>
            <div class="signature-field">
              <div class="signature-line date-line"></div>
              <div class="signature-label">Date</div>
            </div>
          </div>
        </footer>
      </article>
    </div>
  </div>
</div>

