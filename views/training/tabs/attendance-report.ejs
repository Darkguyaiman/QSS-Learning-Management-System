<!-- jsPDF (UMD) -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>

<script>
  const REPORT_COMPANY = {
    code: <%- JSON.stringify(affiliatedBrand.code) %>,
    name: <%- JSON.stringify(affiliatedBrand.name) %>,
    logoUrl: <%- JSON.stringify(affiliatedBrand.logo) %>
  };
  const REPORT_CONTEXT = {
    trainingId: <%- JSON.stringify(typeof training !== 'undefined' ? training.id : null) %>,
    trainingType: <%- JSON.stringify(typeof training !== 'undefined' ? training.type : '') %>,
    trainingTitle: <%- JSON.stringify(typeof training !== 'undefined' ? training.title : '') %>,
    generatedByName: <%- JSON.stringify(user.userName || '') %>,
    generatedByPosition: <%- JSON.stringify(user.userPosition || '') %>,
    healthcareNames: <%- JSON.stringify((typeof allHealthcare !== 'undefined' && Array.isArray(allHealthcare) && typeof trainingHealthcare !== 'undefined' && Array.isArray(trainingHealthcare)) ? trainingHealthcare.map(th => { const h = allHealthcare.find(x => String(x.id) === String(th.healthcare_id)); return h ? h.name : null; }).filter(Boolean) : []) %>,
    marksData: <%- JSON.stringify(Array.isArray(marksData) ? marksData : []) %>
  };
  let currentReportState = null;

  function getAttendanceTrainingIdForReport() {
    const el = document.getElementById('attendance-tab');
    const raw = el?.dataset?.trainingId;
    const n = raw ? parseInt(raw, 10) : NaN;
    return Number.isFinite(n) ? n : null;
  }

  function formatFriendlyDate(dateStr) {
    if (!dateStr) return 'N/A';
    const d = new Date(dateStr + 'T00:00:00');
    if (isNaN(d.getTime())) return dateStr;
    return d.toLocaleDateString('en-US', {
      weekday: 'short',
      year: 'numeric',
      month: 'short',
      day: 'numeric'
    });
  }

  function formatFriendlyTime(timeStr) {
    if (!timeStr) return 'N/A';
    let s = String(timeStr);
    if (s.split(':').length === 3) s = s.substring(0, 5);
    const [hoursRaw, minutesRaw] = s.split(':');
    const hours = parseInt(hoursRaw, 10);
    const minutes = minutesRaw || '00';
    if (!Number.isFinite(hours)) return s;
    const hour12 = hours % 12 || 12;
    const ampm = hours >= 12 ? 'PM' : 'AM';
    return `${hour12}:${minutes} ${ampm}`;
  }

  function formatFriendlyDuration(duration) {
    const d = parseFloat(duration);
    if (!Number.isFinite(d)) return 'N/A';
    const rounded = Math.round(d * 100) / 100;
    return `${rounded} ${rounded === 1 ? 'hour' : 'hours'}`;
  }

  function sanitizeFileName(name) {
    return String(name || 'file').replace(/[\\/:*?"<>|]+/g, '_').replace(/\s+/g, '_');
  }

  function formatDateYMD(dateStr) {
    if (!dateStr) return '';
    const d = new Date(`${dateStr}T00:00:00`);
    if (Number.isNaN(d.getTime())) return String(dateStr);
    const y = d.getFullYear();
    const m = String(d.getMonth() + 1).padStart(2, '0');
    const day = String(d.getDate()).padStart(2, '0');
    return `${y}-${m}-${day}`;
  }

  function getBestTestScore(tests, testType) {
    const candidates = (tests || []).filter(t => t.test_type === testType);
    if (!candidates.length) return null;
    return candidates.reduce((best, t) => {
      const bestScore = parseFloat(best.score) || 0;
      const currScore = parseFloat(t.score) || 0;
      return currScore > bestScore ? t : best;
    }, candidates[0]);
  }

  function summarizeHandsOn(handsOnScores) {
    const scores = Array.isArray(handsOnScores) ? handsOnScores : [];
    const totalScore = scores.reduce((sum, s) => sum + (parseFloat(s.score) || 0), 0);
    const maxScore = scores.reduce((sum, s) => sum + (parseFloat(s.max_score) || 0), 0);
    const percentage = maxScore > 0 ? ((totalScore / maxScore) * 100) : null;
    return { totalScore, maxScore, percentage };
  }

  function getMarksLookup() {
    const map = new Map();
    (REPORT_CONTEXT.marksData || []).forEach(row => {
      map.set(String(row.trainee_id || '').trim(), row);
    });
    return map;
  }

  function updateReportHeaderFields({ trainingTitle, date, time, duration, generatedByName, generatedByPosition, reference }) {
    const generated = generatedByPosition ? `${generatedByName} (${generatedByPosition})` : generatedByName || '-';
    const now = new Date();
    const generatedAt = now.toLocaleString('en-US', {
      year: 'numeric',
      month: 'short',
      day: 'numeric',
      hour: '2-digit',
      minute: '2-digit'
    });

    document.getElementById('report-generated-at').textContent = `Generated on ${generatedAt}`;
    document.getElementById('report-field-training').textContent = trainingTitle || '-';
    document.getElementById('report-field-date').textContent = formatFriendlyDate(date);
    document.getElementById('report-field-time').textContent = formatFriendlyTime(time);
    document.getElementById('report-field-duration').textContent = formatFriendlyDuration(duration);
    document.getElementById('report-field-generated-by').textContent = generated || '-';
    document.getElementById('report-field-reference').textContent = reference || '-';
  }

  function updateSummaryCounts(records) {
    const total = records.length;
    const present = records.filter(r => (r.status || '').toLowerCase() === 'present').length;
    const absent = records.filter(r => (r.status || '').toLowerCase() === 'absent').length;
    const late = records.filter(r => (r.status || '').toLowerCase() === 'late').length;

    document.getElementById('report-total-count').textContent = String(total);
    document.getElementById('report-present-count').textContent = String(present);
    document.getElementById('report-absent-count').textContent = String(absent);
    document.getElementById('report-late-count').textContent = String(late);
  }

  async function loadReportSessions() {
    const trainingId = getAttendanceTrainingIdForReport();
    if (!trainingId) return;

    try {
      const response = await fetch(`/attendance/sessions/${trainingId}`);
      const sessions = await response.json();

      const select = document.getElementById('report-session-select');
      if (!select) return;

      select.innerHTML = '<option value="">-- Select a session --</option>';
      sessions.forEach(session => {
        let dateStr = session.date;
        if (dateStr && dateStr.includes('T')) dateStr = dateStr.split('T')[0];

        const option = document.createElement('option');
        option.value = session.id;
        option.dataset.date = dateStr || '';
        option.dataset.time = session.time || '';
        option.dataset.duration = session.duration || '';

        const label = `${formatFriendlyDate(dateStr)} | ${formatFriendlyTime(session.time)} | ${formatFriendlyDuration(session.duration)}`;
        option.textContent = label;
        select.appendChild(option);
      });
    } catch (error) {
      console.error('Error loading report sessions:', error);
    }
  }

  document.addEventListener('DOMContentLoaded', function() {
    const reportSelect = document.getElementById('report-session-select');
    if (reportSelect) {
      reportSelect.addEventListener('change', async function() {
        const selectedOption = reportSelect.options[reportSelect.selectedIndex];
        if (!selectedOption || !selectedOption.value) {
          document.getElementById('report-preview').style.display = 'none';
          currentReportState = null;
          return;
        }

        const trainingId = getAttendanceTrainingIdForReport();
        const date = selectedOption.dataset.date;
        const time = selectedOption.dataset.time || '';
        const duration = selectedOption.dataset.duration || '';
        const trainingTitle = REPORT_CONTEXT.trainingTitle;
        const generatedByName = REPORT_CONTEXT.generatedByName;
        const generatedByPosition = REPORT_CONTEXT.generatedByPosition;
        const reference = `${REPORT_COMPANY.code}-ATT-${trainingId || 'NA'}-${date || 'NA'}`;

        try {
          const response = await fetch(`/attendance/session-details/${trainingId}?date=${encodeURIComponent(date)}`);
          const data = await response.json();

          const meta = document.getElementById('report-session-meta');
          if (meta) {
            meta.textContent = `Date: ${formatFriendlyDate(date)} | Time: ${formatFriendlyTime(time)} | Duration: ${formatFriendlyDuration(duration)}`;
          }

          const tbody = document.getElementById('report-table-body');
          tbody.innerHTML = '';
          (data.records || []).forEach((r, idx) => {
            const tr = document.createElement('tr');
            const status = (r.status || '').toLowerCase();
            const statusBadge =
              status === 'present' ? `<span class="badge badge-present"><i class="fas fa-check"></i> Present</span>` :
              status === 'absent' ? `<span class="badge badge-absent"><i class="fas fa-times"></i> Absent</span>` :
              status === 'late' ? `<span class="badge" style="background: rgba(249,171,0,0.12); color:#8a5b00;"><i class="fas fa-clock"></i> Late</span>` :
              `<span class="badge" style="background: #edf2f7; color:#4b5563;">${status || 'N/A'}</span>`;

            const fullName = (((r.first_name || '') + ' ' + (r.last_name || '')).trim());

            tr.innerHTML = `
              <td data-label="No.">${idx + 1}</td>
              <td data-label="Trainee Name"><strong>${escapeHtml(fullName)}</strong></td>
              <td data-label="Trainee ID"><span class="trainee-id-cell">${escapeHtml(r.trainee_id || '')}</span></td>
              <td class="text-center" data-label="Status">${statusBadge}</td>
              <td data-label="Notes">${escapeHtml(r.notes || '')}</td>
            `;
            tbody.appendChild(tr);
          });

          updateSummaryCounts(data.records || []);
          updateReportHeaderFields({
            trainingTitle,
            date,
            time,
            duration,
            generatedByName,
            generatedByPosition,
            reference
          });

          document.getElementById('report-preview').style.display = 'block';
          currentReportState = {
            trainingId,
            trainingTitle,
            date,
            time,
            duration,
            generatedByName,
            generatedByPosition,
            reportReference: reference,
            records: data.records || []
          };

          const btn = document.getElementById('btn-generate-report');
          if (btn) {
            btn.onclick = async () => {
              await generateAttendancePdfReport({
                trainingTitle,
                sessionDate: date,
                sessionTime: time,
                sessionDuration: duration,
                records: data.records || [],
                generatedByName,
                generatedByPosition,
                reportReference: reference
              });
            };
          }
        } catch (error) {
          console.error('Error loading report session details:', error);
          qssShowError('Error loading attendance session for report. Please try again.');
        }
      });
    }
  });

  function escapeHtml(str) {
    return String(str || '')
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#039;');
  }

  function loadLogoPngDataUrl() {
    return new Promise(resolve => {
      const img = new Image();
      img.onload = function() {
        try {
          const canvas = document.createElement('canvas');
          canvas.width = img.naturalWidth || 256;
          canvas.height = img.naturalHeight || 256;
          const ctx = canvas.getContext('2d');
          ctx.drawImage(img, 0, 0, canvas.width, canvas.height);
          resolve({
            dataUrl: canvas.toDataURL('image/png'),
            width: canvas.width,
            height: canvas.height
          });
        } catch (err) {
          resolve(null);
        }
      };
      img.onerror = function() {
        resolve(null);
      };
      img.src = REPORT_COMPANY.logoUrl;
    });
  }

  function drawSimpleWrappedText(doc, text, x, y, maxWidth, lineHeight) {
    const lines = doc.splitTextToSize(String(text || ''), maxWidth);
    doc.text(lines, x, y);
    return y + (Math.max(lines.length, 1) * lineHeight);
  }

  async function generateAttendancePdfReport({
    trainingTitle,
    sessionDate,
    sessionTime,
    sessionDuration,
    records,
    generatedByName,
    generatedByPosition,
    reportReference,
    download = true
  }) {
    if (!window.jspdf || !window.jspdf.jsPDF) {
      qssShowError('jsPDF failed to load. Please refresh the page and try again.');
      return;
    }

    const { jsPDF } = window.jspdf;
    const doc = new jsPDF({ unit: 'pt', format: 'a4' });
    const pageWidth = doc.internal.pageSize.getWidth();
    const pageHeight = doc.internal.pageSize.getHeight();
    const margin = 40;
    const logoImage = await loadLogoPngDataUrl();

    const summary = {
      total: records.length,
      present: records.filter(r => (r.status || '').toLowerCase() === 'present').length,
      absent: records.filter(r => (r.status || '').toLowerCase() === 'absent').length,
      late: records.filter(r => (r.status || '').toLowerCase() === 'late').length
    };

    const generatedBy = generatedByPosition ? `${generatedByName} (${generatedByPosition})` : (generatedByName || '-');
    const generatedAt = new Date().toLocaleString('en-US', {
      year: 'numeric',
      month: 'short',
      day: 'numeric',
      hour: '2-digit',
      minute: '2-digit'
    });

    let y = margin;

    function drawHeader() {
      doc.setDrawColor(203, 213, 225);
      doc.setFillColor(248, 250, 252);
      doc.roundedRect(margin, y, pageWidth - margin * 2, 92, 8, 8, 'FD');

      if (logoImage && logoImage.dataUrl) {
        const boxW = 64;
        const boxH = 58;
        const safeW = logoImage.width || boxW;
        const safeH = logoImage.height || boxH;
        const scale = Math.min(boxW / safeW, boxH / safeH);
        const drawW = safeW * scale;
        const drawH = safeH * scale;
        const drawX = margin + 12 + (boxW - drawW) / 2;
        const drawY = y + 12 + (boxH - drawH) / 2;
        doc.addImage(logoImage.dataUrl, 'PNG', drawX, drawY, drawW, drawH);
      }

      doc.setFont('helvetica', 'bold');
      doc.setFontSize(14);
      doc.setTextColor(15, 23, 42);
      doc.text(REPORT_COMPANY.name, margin + 82, y + 28);

      doc.setFont('helvetica', 'normal');
      doc.setFontSize(10);
      doc.setTextColor(71, 85, 105);
      doc.text('Learning Management System', margin + 82, y + 44);

      doc.setFont('helvetica', 'bold');
      doc.setFontSize(16);
      doc.setTextColor(11, 31, 68);
      doc.text('Attendance Report', pageWidth - margin - 12, y + 30, { align: 'right' });

      doc.setFont('helvetica', 'normal');
      doc.setFontSize(9);
      doc.setTextColor(100, 116, 139);
      doc.text(`Generated: ${generatedAt}`, pageWidth - margin - 12, y + 48, { align: 'right' });
      doc.text(`Ref: ${reportReference || '-'}`, pageWidth - margin - 12, y + 62, { align: 'right' });
    }

    drawHeader();
    y += 108;

    doc.setDrawColor(209, 213, 219);
    doc.roundedRect(margin, y, pageWidth - margin * 2, 86, 6, 6);
    doc.setFont('helvetica', 'bold');
    doc.setFontSize(10);
    doc.setTextColor(31, 41, 55);
    doc.text('Training Title', margin + 12, y + 20);
    doc.text('Session Date', margin + 12, y + 42);
    doc.text('Session Time', margin + 12, y + 64);

    doc.text('Duration', margin + 290, y + 20);
    doc.text('Prepared By', margin + 290, y + 42);
    doc.text('Reference', margin + 290, y + 64);

    doc.setFont('helvetica', 'normal');
    doc.setTextColor(17, 24, 39);
    doc.text(trainingTitle || '-', margin + 110, y + 20);
    doc.text(formatFriendlyDate(sessionDate), margin + 110, y + 42);
    doc.text(formatFriendlyTime(sessionTime), margin + 110, y + 64);

    doc.text(formatFriendlyDuration(sessionDuration), margin + 365, y + 20);
    doc.text(generatedBy || '-', margin + 365, y + 42);
    doc.text(reportReference || '-', margin + 365, y + 64);

    y += 104;

    const columns = [
      { label: 'No.', width: 28 },
      { label: 'Trainee Name', width: 170 },
      { label: 'Trainee ID', width: 95 },
      { label: 'Status', width: 70 },
      { label: 'Notes', width: pageWidth - margin * 2 - (28 + 170 + 95 + 70) - 16 }
    ];

    const tableX = margin;
    const tableWidth = pageWidth - margin * 2;
    const rowPadding = 4;

    function drawTableHeader() {
      doc.setFillColor(238, 242, 247);
      doc.rect(tableX, y, tableWidth, 22, 'F');
      doc.setDrawColor(214, 222, 232);
      doc.rect(tableX, y, tableWidth, 22);

      doc.setFont('helvetica', 'bold');
      doc.setFontSize(9);
      doc.setTextColor(31, 41, 55);
      let x = tableX + 8;
      columns.forEach(col => {
        doc.text(col.label, x, y + 14);
        x += col.width;
      });
      y += 24;
    }

    function hasSpace(neededHeight) {
      const signatureReserved = 150;
      return (y + neededHeight) <= (pageHeight - margin - signatureReserved);
    }

    drawTableHeader();
    doc.setFont('helvetica', 'normal');
    doc.setFontSize(9);

    records.forEach((r, idx) => {
      const rowData = [
        String(idx + 1),
        `${r.first_name || ''} ${r.last_name || ''}`.trim() || '-',
        String(r.trainee_id || '-'),
        String((r.status || '-')).toUpperCase(),
        String(r.notes || '-')
      ];

      const wrapped = rowData.map((v, i) => doc.splitTextToSize(v, columns[i].width - 10));
      const maxLines = Math.max(...wrapped.map(lines => Math.max(lines.length, 1)));
      const rowHeight = Math.max(18, maxLines * 11 + rowPadding * 2);

      if (!hasSpace(rowHeight + 8)) {
        doc.addPage();
        y = margin;
        drawHeader();
        y += 108;
        drawTableHeader();
      }

      doc.setDrawColor(230, 235, 241);
      doc.rect(tableX, y, tableWidth, rowHeight);

      let x = tableX + 8;
      wrapped.forEach((lines, i) => {
        doc.text(lines, x, y + 12 + rowPadding);
        x += columns[i].width;
      });

      y += rowHeight;
    });

    const summaryTableHeight = 62;
    if (y + summaryTableHeight > pageHeight - margin - 170) {
      doc.addPage();
      y = margin;
      drawHeader();
      y += 110;
    } else {
      y += 12;
    }

    doc.setFont('helvetica', 'bold');
    doc.setFontSize(10);
    doc.setTextColor(15, 23, 42);
    doc.text('Attendance Summary', margin, y);
    y += 10;

    const sumX = margin;
    const sumW = pageWidth - margin * 2;
    const sumHeadH = 20;
    const sumRowH = 24;
    const sumCols = [sumW * 0.28, sumW * 0.24, sumW * 0.24, sumW * 0.24];
    const sumLabels = ['Total Trainees', 'Present', 'Absent', 'Late'];
    const sumValues = [String(summary.total), String(summary.present), String(summary.absent), String(summary.late)];

    doc.setFillColor(237, 242, 247);
    doc.setDrawColor(203, 213, 225);
    doc.rect(sumX, y, sumW, sumHeadH, 'FD');
    doc.rect(sumX, y + sumHeadH, sumW, sumRowH);

    let sx = sumX;
    for (let i = 0; i < sumCols.length; i++) {
      if (i > 0) {
        doc.line(sx, y, sx, y + sumHeadH + sumRowH);
      }
      doc.setFont('helvetica', 'bold');
      doc.setFontSize(9);
      doc.setTextColor(31, 41, 55);
      doc.text(sumLabels[i], sx + sumCols[i] / 2, y + 13, { align: 'center' });

      doc.setFont('helvetica', 'bold');
      doc.setFontSize(12);
      doc.setTextColor(11, 31, 68);
      doc.text(sumValues[i], sx + sumCols[i] / 2, y + sumHeadH + 16, { align: 'center' });
      sx += sumCols[i];
    }

    y += sumHeadH + sumRowH + 16;

    const neededForSignatures = 154;
    if (y + neededForSignatures > pageHeight - margin) {
      doc.addPage();
      y = margin;
      drawHeader();
      y += 110;
    } else {
      y += 16;
    }

    doc.setDrawColor(203, 213, 225);
    doc.line(margin, y, pageWidth - margin, y);
    y += 16;

    const blockGap = 14;
    const signBlockWidth = (pageWidth - margin * 2 - blockGap * 2) / 3;
    const labels = ['Prepared By (Trainer)', 'Verified By', 'Approved By'];

    labels.forEach((label, i) => {
      const sx = margin + (signBlockWidth + blockGap) * i;
      doc.setFont('helvetica', 'bold');
      doc.setFontSize(9);
      doc.setTextColor(15, 23, 42);
      doc.text(label, sx, y);

      doc.setDrawColor(17, 24, 39);
      doc.setLineDashPattern([2, 2], 0);
      doc.line(sx, y + 34, sx + signBlockWidth - 8, y + 34);
      doc.setFont('helvetica', 'normal');
      doc.setTextColor(100, 116, 139);
      doc.text('Signature', sx, y + 48);

      doc.line(sx, y + 78, sx + signBlockWidth - 8, y + 78);
      doc.text('Name', sx, y + 92);

      doc.line(sx, y + 114, sx + (signBlockWidth - 8) * 0.62, y + 114);
      doc.text('Date', sx, y + 128);
      doc.setLineDashPattern([], 0);
    });

    if (download) {
      const safeDate = sanitizeFileName(formatDateYMD(sessionDate) || sessionDate || 'session');
      doc.save(`Attendance_Report_${safeDate}.pdf`);
      return null;
    }
    return doc.output('blob');
  }

  async function generateInHouseLetterPdfBlob(state, logoImage) {
    const { jsPDF } = window.jspdf;
    const doc = new jsPDF({ unit: 'pt', format: 'a4' });
    const pageWidth = doc.internal.pageSize.getWidth();
    const margin = 42;
    const right = pageWidth - margin;
    const generatedDate = new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
    const hospitals = REPORT_CONTEXT.healthcareNames.length ? REPORT_CONTEXT.healthcareNames.join(', ') : 'N/A';

    let y = margin;
    if (logoImage && logoImage.dataUrl) {
      doc.addImage(logoImage.dataUrl, 'PNG', margin, y, 80, 80);
    }
    doc.setFont('helvetica', 'bold');
    doc.setFontSize(14);
    doc.text(REPORT_COMPANY.name, margin + 92, y + 24);
    doc.setFont('helvetica', 'normal');
    doc.setFontSize(10);
    doc.text('In House Training Letter', margin + 92, y + 42);
    doc.text(`Date: ${generatedDate}`, right, y + 24, { align: 'right' });
    doc.text(`Ref: ${state.reportReference}`, right, y + 42, { align: 'right' });

    y += 108;
    doc.setFont('helvetica', 'bold');
    doc.setFontSize(12);
    doc.text('CONFIRMATION OF IN-HOUSE TRAINING FOR KLASER DEVICE', margin, y);
    y += 22;

    doc.setFont('helvetica', 'normal');
    doc.setFontSize(10);
    y = drawSimpleWrappedText(doc, `We are pleased to confirm that staff members have successfully attended the in-house training session "${state.trainingTitle}".`, margin, y, pageWidth - margin * 2, 14);
    y += 8;
    y = drawSimpleWrappedText(doc, `Training Date: ${formatFriendlyDate(state.date)} | Time: ${formatFriendlyTime(state.time)} | Duration: ${formatFriendlyDuration(state.duration)}`, margin, y, pageWidth - margin * 2, 14);
    y = drawSimpleWrappedText(doc, `Participating Healthcare Centre(s): ${hospitals}`, margin, y + 4, pageWidth - margin * 2, 14);
    y = drawSimpleWrappedText(doc, `This training was conducted by ${REPORT_COMPANY.name}, covering safety, technical, and clinical aspects relevant to trainees.`, margin, y + 8, pageWidth - margin * 2, 14);
    y = drawSimpleWrappedText(doc, 'Group report and individual trainee performance reports are attached in this package.', margin, y + 8, pageWidth - margin * 2, 14);

    y += 24;
    doc.text('Yours sincerely,', margin, y);
    y += 48;
    doc.line(margin, y, margin + 220, y);
    doc.text('Shah Zarak Kahn Bin Ashiq Hussain', margin, y + 14);
    doc.text(`Group Managing Director, ${REPORT_COMPANY.name}`, margin, y + 28);

    return doc.output('blob');
  }

  async function generateGroupReportPdfBlob(state) {
    const { jsPDF } = window.jspdf;
    const doc = new jsPDF({ unit: 'pt', format: 'a4' });
    const pageWidth = doc.internal.pageSize.getWidth();
    const pageHeight = doc.internal.pageSize.getHeight();
    const margin = 36;
    const marksLookup = getMarksLookup();
    let y = margin;

    doc.setFont('helvetica', 'bold');
    doc.setFontSize(14);
    doc.text('Group Report', margin, y);
    y += 16;
    doc.setFontSize(10);
    doc.setFont('helvetica', 'normal');
    doc.text(`${REPORT_CONTEXT.trainingTitle} | ${formatFriendlyDate(state.date)} ${formatFriendlyTime(state.time)}`, margin, y);
    y += 18;

    const columns = [
      { key: 'no', label: 'No', width: 24 },
      { key: 'name', label: 'Name', width: 120 },
      { key: 'id', label: 'Trainee ID', width: 66 },
      { key: 'pre', label: 'Pre', width: 42 },
      { key: 'post', label: 'Post/Ref', width: 52 },
      { key: 'cert', label: 'Cert', width: 40 },
      { key: 'handson', label: 'Hands-On %', width: 64 },
      { key: 'status', label: 'Attendance', width: 58 },
      { key: 'notes', label: 'Notes', width: pageWidth - margin * 2 - (24 + 120 + 66 + 42 + 52 + 40 + 64 + 58) - 16 }
    ];
    const tableWidth = pageWidth - margin * 2;

    const drawHeader = () => {
      doc.setFillColor(238, 242, 247);
      doc.rect(margin, y, tableWidth, 18, 'F');
      doc.setDrawColor(203, 213, 225);
      doc.rect(margin, y, tableWidth, 18);
      doc.setFont('helvetica', 'bold');
      doc.setFontSize(8);
      let x = margin + 6;
      columns.forEach(col => {
        doc.text(col.label, x, y + 12);
        x += col.width;
      });
      y += 20;
    };
    drawHeader();
    doc.setFont('helvetica', 'normal');
    doc.setFontSize(8);

    (state.records || []).forEach((r, idx) => {
      const marks = marksLookup.get(String(r.trainee_id || '').trim());
      const pre = marks ? getBestTestScore(marks.tests, 'pre_test') : null;
      const post = marks ? (getBestTestScore(marks.tests, 'post_test') || getBestTestScore(marks.tests, 'refresher_training')) : null;
      const cert = marks ? getBestTestScore(marks.tests, 'certificate_enrolment') : null;
      const handsOn = marks ? summarizeHandsOn(marks.handsOnScores) : { percentage: null };

      const row = [
        String(idx + 1),
        `${r.first_name || ''} ${r.last_name || ''}`.trim() || '-',
        String(r.trainee_id || '-'),
        pre ? `${(parseFloat(pre.score) || 0).toFixed(1)}%` : '-',
        post ? `${(parseFloat(post.score) || 0).toFixed(1)}%` : '-',
        cert ? `${(parseFloat(cert.score) || 0).toFixed(1)}%` : '-',
        handsOn.percentage == null ? '-' : `${handsOn.percentage.toFixed(1)}%`,
        String(r.status || '-').toUpperCase(),
        String(r.notes || '-')
      ];
      const wrapped = row.map((v, i) => doc.splitTextToSize(v, columns[i].width - 8));
      const rowHeight = Math.max(16, Math.max(...wrapped.map(lines => lines.length)) * 9 + 4);

      if (y + rowHeight > pageHeight - margin) {
        doc.addPage();
        y = margin;
        drawHeader();
      }

      doc.setDrawColor(226, 232, 240);
      doc.rect(margin, y, tableWidth, rowHeight);
      let x = margin + 6;
      wrapped.forEach((lines, i) => {
        doc.text(lines, x, y + 10);
        x += columns[i].width;
      });
      y += rowHeight;
    });

    return doc.output('blob');
  }

  async function generateIndividualReportPdfBlob(state, traineeRecord, marks) {
    const { jsPDF } = window.jspdf;
    const doc = new jsPDF({ unit: 'pt', format: 'a4' });
    const pageWidth = doc.internal.pageSize.getWidth();
    const margin = 42;
    const fullName = `${traineeRecord.first_name || ''} ${traineeRecord.last_name || ''}`.trim() || '-';
    const handsOn = summarizeHandsOn(marks?.handsOnScores || []);
    const pre = getBestTestScore(marks?.tests || [], 'pre_test');
    const post = getBestTestScore(marks?.tests || [], 'post_test');
    const refresher = getBestTestScore(marks?.tests || [], 'refresher_training');
    const cert = getBestTestScore(marks?.tests || [], 'certificate_enrolment');
    const effectiveMidTest = post || refresher;

    let y = margin;
    doc.setFont('helvetica', 'bold');
    doc.setFontSize(14);
    doc.text('Individual Trainee Report', margin, y);
    y += 20;

    doc.setFont('helvetica', 'normal');
    doc.setFontSize(10);
    doc.text(`Training: ${state.trainingTitle}`, margin, y); y += 14;
    doc.text(`Trainee: ${fullName}`, margin, y); y += 14;
    doc.text(`Trainee ID: ${traineeRecord.trainee_id || '-'}`, margin, y); y += 14;
    doc.text(`Session Date: ${formatFriendlyDate(state.date)}`, margin, y); y += 14;
    doc.text(`Attendance: ${String(traineeRecord.status || '-').toUpperCase()}`, margin, y); y += 20;

    doc.setFont('helvetica', 'bold');
    doc.text('Test Performance', margin, y); y += 14;
    doc.setFont('helvetica', 'normal');
    doc.text(`Pre-Test: ${pre ? `${(parseFloat(pre.score) || 0).toFixed(1)}%` : 'N/A'}`, margin, y); y += 14;
    doc.text(`${post ? 'Post-Test' : 'Refresher Test'}: ${effectiveMidTest ? `${(parseFloat(effectiveMidTest.score) || 0).toFixed(1)}%` : 'N/A'}`, margin, y); y += 14;
    doc.text(`Certificate Enrolment: ${cert ? `${(parseFloat(cert.score) || 0).toFixed(1)}%` : 'N/A'}`, margin, y); y += 20;

    doc.setFont('helvetica', 'bold');
    doc.text('Hands-On Performance', margin, y); y += 14;
    doc.setFont('helvetica', 'normal');
    if (handsOn.percentage == null) {
      doc.text('No hands-on scores recorded.', margin, y); y += 14;
    } else {
      doc.text(`Total: ${handsOn.totalScore.toFixed(1)} / ${handsOn.maxScore.toFixed(1)} (${handsOn.percentage.toFixed(1)}%)`, margin, y); y += 14;
      (marks?.handsOnScores || []).forEach(aspect => {
        const label = `${aspect.aspect_name || 'Aspect'}: ${(parseFloat(aspect.score) || 0).toFixed(1)} / ${(parseFloat(aspect.max_score) || 0).toFixed(1)}`;
        y = drawSimpleWrappedText(doc, label, margin + 8, y, pageWidth - margin * 2 - 8, 13);
      });
    }

    y += 10;
    doc.setFont('helvetica', 'bold');
    doc.text('Notes', margin, y); y += 14;
    doc.setFont('helvetica', 'normal');
    y = drawSimpleWrappedText(doc, traineeRecord.notes || 'N/A', margin, y, pageWidth - margin * 2, 13);

    return doc.output('blob');
  }

  async function downloadBlob(filename, blob) {
    const link = document.createElement('a');
    const url = URL.createObjectURL(blob);
    link.href = url;
    link.download = filename;
    document.body.appendChild(link);
    link.click();
    document.body.removeChild(link);
    setTimeout(() => URL.revokeObjectURL(url), 1000);
  }

  async function downloadTrainingPackage(state) {
    if (!state || !Array.isArray(state.records)) {
      qssShowError('Select an attendance session first.');
      return;
    }
    if (!window.JSZip) {
      qssShowError('JSZip failed to load. Please refresh and try again.');
      return;
    }
    if (!window.jspdf || !window.jspdf.jsPDF) {
      qssShowError('jsPDF failed to load. Please refresh and try again.');
      return;
    }

    const btn = document.getElementById('btn-download-package');
    const oldHtml = btn ? btn.innerHTML : '';
    if (btn) {
      btn.disabled = true;
      btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Preparing Package...';
    }

    try {
      const marksLookup = getMarksLookup();
      const logoImage = await loadLogoPngDataUrl();
      const zip = new JSZip();

      const letterBlob = await generateInHouseLetterPdfBlob(state, logoImage);
      zip.file('Inhouse_Training_Letter.pdf', letterBlob);

      const groupReportBlob = await generateGroupReportPdfBlob(state);
      zip.file('Attachment_1_Group_Report.pdf', groupReportBlob);

      const individualFolder = zip.folder('Individual Reports');
      for (const record of state.records) {
        const marks = marksLookup.get(String(record.trainee_id || '').trim()) || null;
        const individualBlob = await generateIndividualReportPdfBlob(state, record, marks);
        const fullName = `${record.first_name || ''} ${record.last_name || ''}`.trim() || 'Trainee';
        const traineeId = sanitizeFileName(record.trainee_id || 'NA');
        individualFolder.file(`${sanitizeFileName(fullName)}_${traineeId}.pdf`, individualBlob);
      }

      const zipBlob = await zip.generateAsync({ type: 'blob' });
      const packDate = sanitizeFileName(formatDateYMD(state.date) || state.date || 'session');
      const trainingName = sanitizeFileName(state.trainingTitle || 'Training');
      await downloadBlob(`${trainingName}_${packDate}_Reports.zip`, zipBlob);
    } catch (err) {
      console.error('Package generation error:', err);
      qssShowError('Failed to generate package. Please try again.');
    } finally {
      if (btn) {
        btn.disabled = false;
        btn.innerHTML = oldHtml;
      }
    }
  }
</script>
