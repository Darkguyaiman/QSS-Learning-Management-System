<!-- Attendance Report Sub-tab -->
<div id="attendance-report" class="attendance-sub-content">
  <div class="attendance-update-container attendance-report-shell">
    <div class="form-group">
      <label for="report-session-select">Select Session <span class="required">*</span></label>
