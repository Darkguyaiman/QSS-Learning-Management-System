            <span class="label">Training Title</span>
            <span class="value" id="report-field-training">-</span>
          </div>
          <div class="attendance-report-meta-item">
            <span class="label">Session Date</span>
            <span class="value" id="report-field-date">-</span>
          </div>
          <div class="attendance-report-meta-item">
            <span class="label">Session Time</span>
            <span class="value" id="report-field-time">-</span>
          </div>
          <div class="attendance-report-meta-item">
            <span class="label">Duration</span>
            <span class="value" id="report-field-duration">-</span>
          </div>
          <div class="attendance-report-meta-item">
            <span class="label">Prepared By</span>
            <span class="value" id="report-field-generated-by">-</span>
          </div>
          <div class="attendance-report-meta-item">
            <span class="label">Report Reference</span>
            <span class="value" id="report-field-reference">-</span>
          </div>
        </section>

        <div class="attendance-summary-table-container attendance-report-table-wrap">
          <div class="table-wrapper">
            <table class="attendance-summary-table attendance-report-table" id="report-table">
              <thead>
                <tr>
                  <th style="width: 56px;">No.</th>
                  <th>Trainee Name</th>
                  <th style="width: 140px;">Trainee ID</th>
                  <th class="text-center" style="width: 130px;">Status</th>
                  <th>Notes</th>
                </tr>
              </thead>
              <tbody id="report-table-body"></tbody>
            </table>
          </div>
        </div>

        <section class="attendance-report-summary-section">
          <h4>Attendance Summary</h4>
          <div class="attendance-summary-table-container">
            <div class="table-wrapper">
              <table class="attendance-summary-table attendance-report-summary-table">
                <thead>
                  <tr>
                    <th>Total Trainees</th>
                    <th>Present</th>
                    <th>Absent</th>
                    <th>Late</th>
                  </tr>
                </thead>
                <tbody>
                  <tr>
                    <td id="report-total-count">0</td>
                    <td id="report-present-count">0</td>
                    <td id="report-absent-count">0</td>
                    <td id="report-late-count">0</td>
                  </tr>
                </tbody>
              </table>
            </div>
          </div>
        </section>

        <footer class="attendance-report-signatures">
          <div class="signature-block">
            <div class="signature-role">Prepared By (Trainer)</div>
            <div class="signature-field">
              <div class="signature-line"></div>
              <div class="signature-label">Signature</div>
            </div>
            <div class="signature-field">
              <div class="signature-line"></div>
              <div class="signature-label">Name</div>
            </div>
            <div class="signature-field">
              <div class="signature-line date-line"></div>
              <div class="signature-label">Date</div>
            </div>
          </div>
          <div class="signature-block">
            <div class="signature-role">Verified By</div>
            <div class="signature-field">
              <div class="signature-line"></div>
              <div class="signature-label">Signature</div>
            </div>
            <div class="signature-field">
              <div class="signature-line"></div>
              <div class="signature-label">Name</div>
            </div>
            <div class="signature-field">
              <div class="signature-line date-line"></div>
              <div class="signature-label">Date</div>
            </div>
          </div>
          <div class="signature-block">
            <div class="signature-role">Approved By</div>
            <div class="signature-field">
              <div class="signature-line"></div>
              <div class="signature-label">Signature</div>
            </div>
            <div class="signature-field">
              <div class="signature-line"></div>
              <div class="signature-label">Name</div>
            </div>
            <div class="signature-field">
