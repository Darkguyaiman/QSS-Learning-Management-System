  </style>

  <script>
    function getAttendanceTrainingId() {
      const el = document.getElementById('attendance-tab');
      const raw = el?.dataset?.trainingId;
      const n = raw ? parseInt(raw, 10) : NaN;
      return Number.isFinite(n) ? n : null;
    }

    function switchAttendanceSubTab(tabName, clickedButton) {
      // Hide all sub-tabs
      document.querySelectorAll('.attendance-sub-content').forEach(tab => {
        tab.classList.remove('active');
      });
      
      // Remove active class from all buttons
      document.querySelectorAll('.attendance-sub-tab').forEach(btn => {
        btn.classList.remove('active');
      });
      
      // Show selected sub-tab
      document.getElementById('attendance-' + tabName).classList.add('active');
      
      // Add active class to clicked button
      if (clickedButton && clickedButton.classList) {
        clickedButton.classList.add('active');
      }
      
      // Initialize date/time pickers if needed
      if (tabName === 'add') {
        initializeAddAttendancePickers();
      } else if (tabName === 'update') {
        loadSessions();
      } else if (tabName === 'report') {
        if (typeof loadReportSessions === 'function') {
          loadReportSessions();
        }
      }
    }

    function initializeAddAttendancePickers() {
      // Initialize date picker
      const dateInput = document.getElementById('attendance-date');
      if (dateInput && !dateInput._flatpickr) {
        flatpickr(dateInput, {
          dateFormat: 'Y-m-d',
          allowInput: true
        });
      }

      // Initialize time picker
      const timeInput = document.getElementById('attendance-time');
      if (timeInput && !timeInput._flatpickr) {
        flatpickr(timeInput, {
          enableTime: true,
          noCalendar: true,
          dateFormat: 'H:i',
          time_24hr: false,
          allowInput: true,
          minuteIncrement: 1
        });
      }

      const endTimeInput = document.getElementById('attendance-end-time');
      if (endTimeInput && !endTimeInput._flatpickr) {
        flatpickr(endTimeInput, {
          enableTime: true,
          noCalendar: true,
          dateFormat: 'H:i',
          time_24hr: false,
          allowInput: true,
          minuteIncrement: 1
        });
      }
    }

    function initializeUpdatePickers() {
      const timeInput = document.getElementById('update-time');
      if (timeInput && !timeInput._flatpickr) {
        flatpickr(timeInput, {
          enableTime: true,
          noCalendar: true,
          dateFormat: 'H:i',
          time_24hr: false,
          allowInput: true,
          minuteIncrement: 1
        });
      }

      const endTimeInput = document.getElementById('update-end-time');
      if (endTimeInput && !endTimeInput._flatpickr) {
        flatpickr(endTimeInput, {
          enableTime: true,
          noCalendar: true,
          dateFormat: 'H:i',
          time_24hr: false,
          allowInput: true,
          minuteIncrement: 1
        });
      }
    }

    function getTimeFromInput(inputId, fallbackValue) {
      let value = fallbackValue;
      const input = document.getElementById(inputId);

      if (input && input._flatpickr) {
        const selectedDate = input._flatpickr.selectedDates[0];
        if (selectedDate) {
          const hours = String(selectedDate.getHours()).padStart(2, '0');
          const minutes = String(selectedDate.getMinutes()).padStart(2, '0');
          value = `${hours}:${minutes}`;
        } else {
          value = input.value || value;
        }
      } else {
        value = input ? (input.value || value) : value;
      }

      if (value && value.split(':').length === 3) {
        value = value.substring(0, 5);
      }

      return value;
    }

    // Handle add attendance form submission
    document.addEventListener('DOMContentLoaded', function() {
      function isMobileSelectMode() {
        return window.matchMedia && window.matchMedia('(max-width: 768px)').matches;
      }

      function attachMobileSelectModal(selectId, title) {
        const select = document.getElementById(selectId);
        if (!select) return;
        if (!select.classList.contains('session-select')) return;

        const wrapper = select.closest('.select-wrapper');
        if (!wrapper) return;

        // Create proxy button once
        let proxy = wrapper.querySelector(`.qss-mobile-select-proxy[data-for="${selectId}"]`);
        if (!proxy) {
          proxy = document.createElement('button');
          proxy.type = 'button';
          proxy.className = 'qss-mobile-select-proxy';
          proxy.dataset.for = selectId;
          proxy.innerHTML = `
            <span class="qss-mobile-select-value"></span>
            <span class="qss-mobile-select-hint">Tap to choose</span>
          `;
          wrapper.appendChild(proxy);

          proxy.addEventListener('click', () => {
            if (!isMobileSelectMode()) return;
            if (typeof window.qssShowSelectModal !== 'function') return;

            const opts = Array.from(select.options || [])
              .filter(o => o && o.value) // skip placeholder
              .map(o => ({ value: o.value, label: o.textContent || o.label || o.value }));

            if (opts.length === 0) {
              qssShowWarning('No sessions available yet.');
              return;
            }

            window.qssShowSelectModal({
              title: title || 'Select Session',
              options: opts,
              selectedValue: select.value || '',
              onPick: (val) => {
                select.value = val;
                select.dispatchEvent(new Event('change', { bubbles: true }));
              }
            });
          });
        }

        function updateProxyText() {
          const valueEl = proxy.querySelector('.qss-mobile-select-value');
          const hintEl = proxy.querySelector('.qss-mobile-select-hint');
          const selected = select.options && select.selectedIndex >= 0 ? select.options[select.selectedIndex] : null;
          const label = selected && selected.value ? (selected.textContent || selected.label || selected.value) : '-- Select a session --';
          if (valueEl) valueEl.textContent = label;
          if (hintEl) hintEl.textContent = (selected && selected.value) ? 'Tap to change' : 'Tap to choose';
        }

        // Keep proxy in sync
        updateProxyText();
        select.addEventListener('change', updateProxyText);
        const mo = new MutationObserver(updateProxyText);
        mo.observe(select, { childList: true, subtree: true });

        // Also update on resize breakpoint changes
        window.addEventListener('resize', updateProxyText);
      }

      // Initialize rate bar widths (avoid EJS inside inline style)
      document.querySelectorAll('#attendance-tab .rate-fill[data-rate]').forEach(el => {
        const raw = el.getAttribute('data-rate');
        const rate = raw ? parseFloat(raw) : 0;
        const safe = Number.isFinite(rate) ? Math.max(0, Math.min(100, rate)) : 0;
        el.style.width = `${safe}%`;
      });

      // Mobile session pickers (Update + Report)
      attachMobileSelectModal('update-session-select', 'Select Session (Update)');
      attachMobileSelectModal('report-session-select', 'Select Session (Report)');

      const addForm = document.getElementById('add-attendance-form');
      if (addForm) {
        addForm.addEventListener('submit', async function(e) {
          e.preventDefault();
          
          const formData = new FormData(addForm);
          const date = formData.get('date');
          const time = getTimeFromInput('attendance-time', formData.get('time'));
          const endTime = getTimeFromInput('attendance-end-time', formData.get('end_time'));

          if (!time || !time.match(/^\d{1,2}:\d{2}$/)) {
            qssShowWarning('Please enter a valid start time');
            return;
          }
          if (!endTime || !endTime.match(/^\d{1,2}:\d{2}$/)) {
            qssShowWarning('Please enter a valid end time');
            return;
          }
          
          // Collect attendance for all trainees
          const attendanceRecords = [];
          const enrollmentIds = Array.from(document.querySelectorAll('[name^="status_"]')).map(input => {
            const match = input.name.match(/status_(\d+)/);
            return match ? parseInt(match[1]) : null;
          }).filter(id => id !== null);
          
          enrollmentIds.forEach(enrollmentId => {
            const status = formData.get(`status_${enrollmentId}`);
            const notes = formData.get(`notes_${enrollmentId}`) || '';
            
            attendanceRecords.push({
              enrollment_id: enrollmentId,
              date: date,
              time: time,
              end_time: endTime,
              status: status,
              notes: notes
            });
          });
          
          try {
            const trainingId = getAttendanceTrainingId();
            const response = await fetch('/attendance/mark-bulk', {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json'
              },
              body: JSON.stringify({
                training_id: trainingId,
                records: attendanceRecords
              })
            });
            
            const result = await response.json();
            
            if (response.ok) {
              qssShowMessage({
                type: 'success',
                title: 'Success',
                message: 'Attendance marked successfully!',
                onClose: () => window.location.reload()
              });
              addForm.reset();
            } else {
              qssShowError('Error: ' + (result.error || 'Failed to mark attendance'));
            }
          } catch (error) {
            console.error('Error:', error);
            qssShowError('Error marking attendance. Please try again.');
          }
        });
      }

      // Handle session selection for update
      const sessionSelect = document.getElementById('update-session-select');
      if (sessionSelect) {
        sessionSelect.addEventListener('change', function() {
          const sessionId = this.value;
          if (sessionId) {
            loadSessionDetails(sessionId);
          } else {
            document.getElementById('update-attendance-form-container').style.display = 'none';
          }
        });
      }

      // Handle update attendance form submission
      const updateForm = document.getElementById('update-attendance-form');
      if (updateForm) {
        updateForm.addEventListener('submit', async function(e) {
          e.preventDefault();
          
          const formData = new FormData(updateForm);
          const attendanceId = formData.get('attendance_id');
          const date = formData.get('date');
          const time = getTimeFromInput('update-time', formData.get('time'));
          const endTime = getTimeFromInput('update-end-time', formData.get('end_time'));

          if (!time || !time.match(/^\d{1,2}:\d{2}$/)) {
            qssShowWarning('Please enter a valid start time');
            return;
          }
          if (!endTime || !endTime.match(/^\d{1,2}:\d{2}$/)) {
            qssShowWarning('Please enter a valid end time');
            return;
          }
          
          // Collect updated attendance for all trainees
          const attendanceRecords = [];
          const enrollmentIds = Array.from(document.querySelectorAll('#update-trainees-list [name^="status_"]')).map(input => {
            const match = input.name.match(/status_(\d+)/);
            return match ? parseInt(match[1]) : null;
          }).filter(id => id !== null);
          
          enrollmentIds.forEach(enrollmentId => {
            const status = formData.get(`status_${enrollmentId}`);
            const notes = formData.get(`notes_${enrollmentId}`) || '';
            
            attendanceRecords.push({
              enrollment_id: enrollmentId,
              date: date,
              time: time,
              end_time: endTime,
              status: status,
              notes: notes
            });
          });
          
          try {
            const trainingId = getAttendanceTrainingId();
            const originalTime = formData.get('original_time');
            const response = await fetch('/attendance/update-bulk', {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json'
              },
              body: JSON.stringify({
                training_id: trainingId,
                date: date,
                original_time: originalTime,
                records: attendanceRecords
              })
            });
            
            const result = await response.json();
            
            if (response.ok) {
              qssShowMessage({
                type: 'success',
                title: 'Success',
                message: 'Attendance updated successfully!',
                onClose: () => window.location.reload()
              });
              cancelUpdate();
            } else {
              qssShowError('Error: ' + (result.error || 'Failed to update attendance'));
            }
          } catch (error) {
            console.error('Error:', error);
            qssShowError('Error updating attendance. Please try again.');
          }
        });
      }
    });

    async function loadSessions() {
      const trainingId = getAttendanceTrainingId();
      if (!trainingId) return;
      
      try {
        const response = await fetch(`/attendance/sessions/${trainingId}`);
        const sessions = await response.json();
        
        const select = document.getElementById('update-session-select');
        if (select) {
          select.innerHTML = '<option value="">-- Select a session --</option>';
          
          sessions.forEach(session => {
            const option = document.createElement('option');
            
            // Parse date - handle both date string and ISO datetime formats
            let dateStr = session.date;
            if (dateStr.includes('T')) {
              // If it's an ISO datetime, extract just the date part
              dateStr = dateStr.split('T')[0];
            }
            
            // Format date nicely
            const dateObj = new Date(dateStr + 'T00:00:00');
            let formattedDate = 'Invalid Date';
            if (!isNaN(dateObj.getTime())) {
              formattedDate = dateObj.toLocaleDateString('en-US', { 
                weekday: 'short', 
                year: 'numeric', 
                month: 'short', 
                day: 'numeric' 
              });
            } else {
              // Fallback: try parsing the date string directly
              const parts = dateStr.split('-');
              if (parts.length === 3) {
                const year = parts[0];
                const month = parseInt(parts[1]) - 1;
                const day = parts[2];
                const fallbackDate = new Date(year, month, day);
                if (!isNaN(fallbackDate.getTime())) {
                  formattedDate = fallbackDate.toLocaleDateString('en-US', { 
                    weekday: 'short', 
                    year: 'numeric', 
                    month: 'short', 
                    day: 'numeric' 
                  });
                }
              }
            }
            
            // Format time nicely - handle both HH:mm and HH:mm:ss formats
            let formattedTime = 'N/A';
            if (session.time) {
              let timeStr = session.time;
              // Remove seconds if present (HH:mm:ss -> HH:mm)
              if (timeStr.split(':').length === 3) {
                timeStr = timeStr.substring(0, 5);
              }
              const [hours, minutes] = timeStr.split(':');
              const hour24 = parseInt(hours);
              const hour12 = hour24 % 12 || 12;
              const ampm = hour24 >= 12 ? 'PM' : 'AM';
              formattedTime = `${hour12}:${minutes} ${ampm}`;
            }
            
            // Format end time nicely - handle both HH:mm and HH:mm:ss formats
            let formattedEndTime = 'N/A';
            if (session.end_time) {
              let endTimeStr = session.end_time;
              if (endTimeStr.split(':').length === 3) {
                endTimeStr = endTimeStr.substring(0, 5);
              }
              const [endHours, endMinutes] = endTimeStr.split(':');
              const endHour24 = parseInt(endHours);
              const endHour12 = endHour24 % 12 || 12;
              const endAmpm = endHour24 >= 12 ? 'PM' : 'AM';
              formattedEndTime = `${endHour12}:${endMinutes} ${endAmpm}`;
            }
            
            option.value = session.id;
            option.textContent = `${formattedDate} • ${formattedTime} - ${formattedEndTime}`;
            option.dataset.date = dateStr; // Store clean date string
            option.dataset.time = session.time || '';
            option.dataset.endTime = session.end_time || '';
            select.appendChild(option);
          });
        }
      } catch (error) {
        console.error('Error loading sessions:', error);
      }
    }

    // Select All/Deselect All functionality
    function selectAllAttendance(formType, status = 'present') {
      let container;
      
      if (formType === 'add') {
        container = document.getElementById('add-attendance-form');
      } else if (formType === 'update') {
        container = document.getElementById('update-trainees-list');
      }
      
      if (!container) return;
      
      // Find all radio buttons with the specified status value
      const radioButtons = container.querySelectorAll(`input[type="radio"][value="${status}"]`);
      
      radioButtons.forEach(radio => {
        radio.checked = true;
        // Trigger change event to update any visual feedback
        const changeEvent = new Event('change', { bubbles: true });
        radio.dispatchEvent(changeEvent);
      });
      
      // Visual feedback
      const statusText = status === 'present' ? 'Present' : 'Absent';
      console.log(`Selected all ${statusText} for ${radioButtons.length} trainees`);
    }

    async function loadSessionDetails(sessionId) {
      const trainingId = getAttendanceTrainingId();
      const select = document.getElementById('update-session-select');
      const selectedOption = select.options[select.selectedIndex];
      
      if (!selectedOption || !selectedOption.value) return;
      
      const date = selectedOption.dataset.date;
      const time = selectedOption.dataset.time;
      const endTime = selectedOption.dataset.endTime;
      
      try {
        const response = await fetch(`/attendance/session-details/${trainingId}?date=${encodeURIComponent(date)}&time=${encodeURIComponent(time)}`);
        const data = await response.json();
        
      // Populate form
      document.getElementById('update-attendance-id').value = sessionId;
      document.getElementById('update-attendance-original-time').value = time || '';
      
      // Clean date - extract just the date part if it's an ISO datetime
      let cleanDate = date;
      if (date && date.includes('T')) {
        cleanDate = date.split('T')[0];
      }
      document.getElementById('update-attendance-date').value = cleanDate;
      
      // Format date nicely for display
      const dateObj = new Date(cleanDate + 'T00:00:00');
      let formattedDate = cleanDate;
      if (!isNaN(dateObj.getTime())) {
        formattedDate = dateObj.toLocaleDateString('en-US', { 
          weekday: 'long', 
          year: 'numeric', 
          month: 'long', 
          day: 'numeric' 
        });
      }
      document.getElementById('update-display-date').value = formattedDate;
      
      // Clean time - remove seconds if present (HH:mm:ss -> HH:mm)
      let cleanTime = time;
      if (time && time.split(':').length === 3) {
        cleanTime = time.substring(0, 5);
      }
      
      // Set the time value and update flatpickr if it exists
      const timeInput = document.getElementById('update-time');
      if (timeInput) {
        timeInput.value = cleanTime || '';
        // If flatpickr is already initialized, set the date
        if (timeInput._flatpickr && cleanTime) {
          // Parse the time and set it in flatpickr
          const [hours, minutes] = cleanTime.split(':');
          const today = new Date();
          today.setHours(parseInt(hours), parseInt(minutes), 0, 0);
          timeInput._flatpickr.setDate(today, false);
        }
      }
      
      // Clean end time - remove seconds if present (HH:mm:ss -> HH:mm)
      let cleanEndTime = endTime;
      if (endTime && endTime.split(':').length === 3) {
        cleanEndTime = endTime.substring(0, 5);
      }

      // Set end time and update flatpickr if it exists
      const endTimeInput = document.getElementById('update-end-time');
      if (endTimeInput) {
        endTimeInput.value = cleanEndTime || '';
        if (endTimeInput._flatpickr && cleanEndTime) {
          const [hours, minutes] = cleanEndTime.split(':');
          const today = new Date();
          today.setHours(parseInt(hours), parseInt(minutes), 0, 0);
          endTimeInput._flatpickr.setDate(today, false);
        }
      }
      
        // Populate trainees list
        const traineesList = document.getElementById('update-trainees-list');
        traineesList.innerHTML = '';
        
        data.records.forEach(record => {
          const item = document.createElement('div');
          item.className = 'trainee-attendance-item';
          item.innerHTML = `
            <div class="trainee-info">
              <strong>${record.first_name} ${record.last_name}</strong>
              <span class="trainee-id">${record.trainee_id}</span>
            </div>
            <div class="attendance-controls">
              <div class="status-radio-group">
                <label class="status-radio present">
                  <input type="radio" name="status_${record.enrollment_id}" value="present" ${record.status === 'present' ? 'checked' : ''}>
                  <span>Present</span>
                </label>
                <label class="status-radio absent">
                  <input type="radio" name="status_${record.enrollment_id}" value="absent" ${record.status === 'absent' ? 'checked' : ''}>
                  <span>Absent</span>
                </label>
              </div>
              <input type="text" 
                     name="notes_${record.enrollment_id}" 
                     class="notes-input" 
                     placeholder="Notes (optional)"
                     value="${record.notes || ''}"
                     data-enrollment-id="${record.enrollment_id}">
            </div>
          `;
          traineesList.appendChild(item);
        });
        
        document.getElementById('update-attendance-form-container').style.display = 'block';
        initializeUpdatePickers();
      } catch (error) {
        console.error('Error loading session details:', error);
      qssShowError('Error loading session details. Please try again.');
      }
    }

    function cancelUpdate() {
      document.getElementById('update-session-select').value = '';
      document.getElementById('update-attendance-form-container').style.display = 'none';
      document.getElementById('update-attendance-form').reset();
    }
  </script>
<% } %>
