<!-- Marks Tab (Admin/Trainer Only) -->
<% if (['admin', 'trainer'].includes(user.userRole)) { %>
  <div id="marks-tab" class="tab-content">
    <%
      const getBestTest = (tests, type) => {
        const candidates = (tests || []).filter(t => t.test_type === type);
        if (!candidates.length) return null;
        return candidates.reduce((best, t) => {
          const bestScore = parseFloat(best.score) || 0;
          const currScore = parseFloat(t.score) || 0;
          return currScore > bestScore ? t : best;
        }, candidates[0]);
      };
      /** One row per aspect (last wins). Avoids double totals if DB has dupes or joins duplicate. */
      const practicalOutcomeTotalsFromScores = (handsOnScores) => {
        const byAspect = new Map();
        for (const s of handsOnScores || []) {
          const aid = s.aspect_id;
          byAspect.set(aid, {
            score: parseFloat(s.score) || 0,
            max: parseInt(s.max_score, 10) || 0
          });
        }
        let total = 0;
        let max = 0;
        for (const v of byAspect.values()) {
          total += v.score;
          max += v.max;
        }
        return { total, max };
      };
      const practicalOutcomeCompletedCount = (handsOnScores) => {
        const aspectIds = new Set();
        for (const s of handsOnScores || []) {
          if (s && s.aspect_id != null) aspectIds.add(String(s.aspect_id));
        }
        return aspectIds.size;
      };
    %>
    <% if (marksData.length === 0) { %>
      <div class="empty-state">
        <p>No marks available yet.</p>
      </div>
    <% } else { %>
      <!-- Test Scores Table -->
      <div class="section-card" style="margin-bottom: 2rem;">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem; flex-wrap: wrap; gap: 0.75rem;">
          <h3 class="section-title" style="margin: 0;">Test Scores</h3>
          <div style="display: flex; gap: 0.5rem; flex-wrap: wrap;">
            <% if (training.type === 'main' && aspects && aspects.length > 0) { %>
              <button class="btn btn-primary btn-sm" onclick="toggleHandsOnGrading()" id="toggle-hands-on-btn" <%= training.is_locked ? 'disabled title="Training is locked"' : '' %>>
                <i class="fas fa-hand-paper"></i>
                <span>Grade Practical Learning Outcome</span>
                <i class="fas fa-chevron-down" style="margin-left: 0.25rem; transition: transform 0.3s ease; font-size: 0.75rem;"></i>
              </button>
            <% } %>
          </div>
        </div>
        
        <!-- Desktop Table View -->
        <div class="table-responsive">
        <table class="marks-table marks-table-desktop">
          <thead>
            <tr>
              <th>Trainee</th>
              <% if (training.type === 'main') { %>
                <th>Pre-Test</th>
                <th>Post-Test</th>
                <th>Practical Learning Outcome</th>
                <th>Certificate Enrolment</th>
              <% } else { %>
                <th>Certificate Enrolment</th>
              <% } %>
              <th>Status</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% marksData.forEach(data => { %>
              <tr>
                <td><strong><%= data.trainee_name %></strong><br><span style="color: #5F6368; font-size: 0.75rem;"><%= data.trainee_id %></span></td>
                <% 
                  const preTest = getBestTest(data.tests, 'pre_test');
                  const postTest = getBestTest(data.tests, 'post_test');
                  const certificateEnrolmentTest = getBestTest(data.tests, 'certificate_enrolment');
                %>
                <% if (training.type === 'main') { %>
                  <td>
                    <% if (preTest) { %>
                      <span class="test-score <%= preTest.score >= 80 ? 'score-Outstanding' : 'score-Not Passed' %>">
                        <%= preTest.score %>% (<%= preTest.score >= 80 ? 'Outstanding' : 'Not Passed' %>)
                      </span>
                    <% } else { %>
                      <span style="color: #5F6368;">Not taken</span>
                    <% } %>
                  </td>
                  <td>
                    <% if (postTest) { %>
                      <span class="test-score <%= postTest.score >= 80 ? 'score-Outstanding' : 'score-Not Passed' %>">
                        <%= postTest.score %>% (<%= postTest.score >= 80 ? 'Outstanding' : 'Not Passed' %>)
                      </span>
                    <% } else { %>
                      <span style="color: #5F6368;">Not taken</span>
                    <% } %>
                  </td>
                  <td>
                    <% if (data.handsOnScores.length > 0) { %>
                      <% 
                        const poRow = practicalOutcomeTotalsFromScores(data.handsOnScores);
                        const totalScore = poRow.total;
                        const maxScore = poRow.max;
                        const percentage = maxScore > 0 ? (totalScore / maxScore * 100).toFixed(1) : 0;
                      %>
                      <span class="test-score <%= percentage >= 80 ? 'score-Outstanding' : 'score-Not Passed' %>">
                        <%= percentage %>% (<%= totalScore %>/<%= maxScore %>)
                      </span>
                    <% } else { %>
                      <span style="color: #5F6368;">Not evaluated</span>
                    <% } %>
                  </td>
                  <td>
                    <% if (certificateEnrolmentTest) { %>
                      <span class="test-score <%= certificateEnrolmentTest.score >= 80 ? 'score-Outstanding' : 'score-Not Passed' %>">
                        <%= certificateEnrolmentTest.score %>% (<%= certificateEnrolmentTest.score >= 80 ? 'Outstanding' : 'Not Passed' %>)
                      </span>
                    <% } else { %>
                      <span style="color: #5F6368;">Not taken</span>
                    <% } %>
                  </td>
                <% } else { %>
                  <td>
                    <% if (certificateEnrolmentTest) { %>
                      <span class="test-score <%= certificateEnrolmentTest.score >= 80 ? 'score-Outstanding' : 'score-Not Passed' %>">
                        <%= certificateEnrolmentTest.score %>% (<%= certificateEnrolmentTest.score >= 80 ? 'Outstanding' : 'Not Passed' %>)
                      </span>
                    <% } else { %>
                      <span style="color: #5F6368;">Not taken</span>
                    <% } %>
                  </td>
                <% } %>
                <td>
                  <% if (data.can_download_results) { %>
                    <span style="color: #34A853; font-size: 0.875rem;">
                      <i class="fas fa-check-circle"></i> Released
                    </span>
                  <% } else { %>
                    <span style="color: #5F6368; font-size: 0.875rem;">
                      <i class="fas fa-lock"></i> Not Released
                    </span>
                  <% } %>
                </td>
                <td>
                  <div class="marks-actions">
                    <% if (data.tests.length > 0) { %>
                      <a class="btn btn-sm btn-secondary" href="/training/<%= training.id %>/enrollment/<%= data.enrollment_id %>/test-answers">
                        <i class="fas fa-eye"></i> View Test Answers
                      </a>
                      <a class="btn btn-sm btn-outline" href="/results/enrollment/<%= data.enrollment_id %>">
                        <i class="fas fa-list"></i> All Attempts
                      </a>
                    <% } %>
                    <% 
                      const completedHandsOnCount = practicalOutcomeCompletedCount(data.handsOnScores);
                      const totalHandsOnCount = Array.isArray(aspects) ? aspects.length : 0;
                      const certCompleted = !!certificateEnrolmentTest;
                      const preCompleted = !!preTest;
                      const postCompleted = !!postTest;
                      const practicalCompleted = totalHandsOnCount > 0 && completedHandsOnCount >= totalHandsOnCount;
                      const canReleaseMain = !data.can_download_results && preCompleted && postCompleted && certCompleted && practicalCompleted;
                      const canReleaseRefresher = !data.can_download_results && certCompleted;
                    %>
                    <% if (training.type === 'main') { %>
                      <% if (user.userRole === 'admin' && canReleaseMain) { %>
                        <button class="btn btn-sm btn-primary" onclick="releaseScores([<%= data.enrollment_id %>], this)">
                          <i class="fas fa-unlock"></i> Release
                        </button>
                      <% } %>
                    <% } else { %>
                      <% if (['admin', 'trainer'].includes(user.userRole) && canReleaseRefresher) { %>
                        <button class="btn btn-sm btn-primary" onclick="releaseScores([<%= data.enrollment_id %>], this)">
                          <i class="fas fa-unlock"></i> Release
                        </button>
                      <% } %>
                    <% } %>
                    <% if (data.can_download_results) { %>
                      <a href="/training/<%= training.id %>/certificate/<%= data.enrollment_id %>" target="_blank" class="btn btn-sm btn-success">
                        <i class="fas fa-certificate"></i> Certificate
                      </a>
                    <% } %>
                  </div>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
        </div>

        <!-- Mobile Card View -->
        <div class="marks-cards-mobile">
          <% marksData.forEach(data => { %>
            <div class="marks-card-mobile">
              <div class="marks-card-header">
                <div style="flex: 1;">
                  <strong><%= data.trainee_name %></strong>
                  <span class="trainee-id-badge"><%= data.trainee_id %></span>
                </div>
                <% if (data.can_download_results) { %>
                  <span style="color: #34A853; font-size: 0.75rem;">
                    <i class="fas fa-check-circle"></i> Released
                  </span>
                <% } else { %>
                  <span style="color: #5F6368; font-size: 0.75rem;">
                    <i class="fas fa-lock"></i> Not Released
                  </span>
                <% } %>
              </div>
              <div class="marks-card-body">
                <% 
                  const preTest = getBestTest(data.tests, 'pre_test');
                  const postTest = getBestTest(data.tests, 'post_test');
                  const certificateEnrolmentTest = getBestTest(data.tests, 'certificate_enrolment');
                %>
                
                <% if (training.type === 'main') { %>
                  <div class="marks-card-row">
                    <span class="marks-label">Pre-Test</span>
                    <% if (preTest) { %>
                      <span class="test-score <%= preTest.score >= 80 ? 'score-Outstanding' : 'score-Not Passed' %>">
                        <%= preTest.score %>% (<%= preTest.score >= 80 ? 'Outstanding' : 'Not Passed' %>)
                      </span>
                    <% } else { %>
                      <span style="color: #5F6368;">Not taken</span>
                    <% } %>
                  </div>
                  <div class="marks-card-row">
                    <span class="marks-label">Post-Test</span>
                    <% if (postTest) { %>
                      <span class="test-score <%= postTest.score >= 80 ? 'score-Outstanding' : 'score-Not Passed' %>">
                        <%= postTest.score %>% (<%= postTest.score >= 80 ? 'Outstanding' : 'Not Passed' %>)
                      </span>
                    <% } else { %>
                      <span style="color: #5F6368;">Not taken</span>
                    <% } %>
                  </div>

                  <div class="marks-card-row">
                    <span class="marks-label">Practical Learning Outcome</span>
                    <% if (data.handsOnScores.length > 0) { %>
                      <% 
                        const poMob = practicalOutcomeTotalsFromScores(data.handsOnScores);
                        const totalScore = poMob.total;
                        const maxScore = poMob.max;
                        const percentage = maxScore > 0 ? (totalScore / maxScore * 100).toFixed(1) : 0;
                      %>
                      <span class="test-score <%= percentage >= 80 ? 'score-Outstanding' : 'score-Not Passed' %>">
                        <%= percentage %>% (<%= totalScore %>/<%= maxScore %>)
                      </span>
                    <% } else { %>
                      <span style="color: #5F6368;">Not evaluated</span>
                    <% } %>
                  </div>

                  <div class="marks-card-row">
                    <span class="marks-label">Certificate Enrolment</span>
                    <% if (certificateEnrolmentTest) { %>
                      <span class="test-score <%= certificateEnrolmentTest.score >= 80 ? 'score-Outstanding' : 'score-Not Passed' %>">
                        <%= certificateEnrolmentTest.score %>% (<%= certificateEnrolmentTest.score >= 80 ? 'Outstanding' : 'Not Passed' %>)
                      </span>
                    <% } else { %>
                      <span style="color: #5F6368;">Not taken</span>
                    <% } %>
                  </div>
                <% } else { %>
                  <div class="marks-card-row">
                    <span class="marks-label">Certificate Enrolment</span>
                    <% if (certificateEnrolmentTest) { %>
                      <span class="test-score <%= certificateEnrolmentTest.score >= 80 ? 'score-Outstanding' : 'score-Not Passed' %>">
                        <%= certificateEnrolmentTest.score %>% (<%= certificateEnrolmentTest.score >= 80 ? 'Outstanding' : 'Not Passed' %>)
                      </span>
                    <% } else { %>
                      <span style="color: #5F6368;">Not taken</span>
                    <% } %>
                  </div>
                <% } %>

                <div class="marks-card-actions">
                  <% if (data.tests.length > 0) { %>
                    <a class="btn btn-sm btn-secondary" href="/training/<%= training.id %>/enrollment/<%= data.enrollment_id %>/test-answers">
                      <i class="fas fa-eye"></i> View Test Answers
                    </a>
                    <a class="btn btn-sm btn-outline" href="/results/enrollment/<%= data.enrollment_id %>">
                      <i class="fas fa-list"></i> All Attempts
                    </a>
                  <% } %>
                  <% 
                    const completedHandsOnCount = practicalOutcomeCompletedCount(data.handsOnScores);
                    const totalHandsOnCount = Array.isArray(aspects) ? aspects.length : 0;
                    const certCompleted = !!certificateEnrolmentTest;
                    const preCompleted = !!preTest;
                    const postCompleted = !!postTest;
                    const practicalCompleted = totalHandsOnCount > 0 && completedHandsOnCount >= totalHandsOnCount;
                    const canReleaseMain = !data.can_download_results && preCompleted && postCompleted && certCompleted && practicalCompleted;
                    const canReleaseRefresher = !data.can_download_results && certCompleted;
                  %>
                  <% if (training.type === 'main') { %>
                    <% if (user.userRole === 'admin' && canReleaseMain) { %>
                      <button class="btn btn-sm btn-primary" onclick="releaseScores([<%= data.enrollment_id %>], this)">
                        <i class="fas fa-unlock"></i> Release
                      </button>
                    <% } %>
                  <% } else { %>
                    <% if (['admin', 'trainer'].includes(user.userRole) && canReleaseRefresher) { %>
                      <button class="btn btn-sm btn-primary" onclick="releaseScores([<%= data.enrollment_id %>], this)">
                        <i class="fas fa-unlock"></i> Release
                      </button>
                    <% } %>
                  <% } %>
                  <% if (data.can_download_results) { %>
                    <a href="/training/<%= training.id %>/certificate/<%= data.enrollment_id %>" target="_blank" class="btn btn-sm btn-success">
                      <i class="fas fa-certificate"></i> Certificate
                    </a>
                  <% } %>
                </div>
              </div>
            </div>
          <% }); %>
        </div>
      </div>

      <!-- Practical Learning Outcome Grading Section (Main Training Only) -->
      <% if (training.type === 'main' && aspects && aspects.length > 0) { %>
        <div class="section-card hands-on-grading-section" id="hands-on-grading-section" style="display: none;">
          <div class="grading-header">
            <div>
              <h3 class="section-title" style="margin: 0 0 0.25rem 0;">Practical Learning Outcome Grading</h3>
              <p class="header-subtitle">Enter scores for each trainee and aspect</p>
            </div>
            <button class="btn-save-all" onclick="saveAllHandsOnScores()" id="save-all-hands-on-btn" <%= training.is_locked ? 'disabled title="Training is locked"' : '' %>>
              <i class="fas fa-save"></i>
              <span>Save All Scores</span>
            </button>
          </div>

          <%- include('../../partials/practical-grading-criteria') %>

          <!-- Desktop Table View -->
          <div class="hands-on-table-container">
            <table class="hands-on-grading-table">
              <thead>
                <tr>
                  <th class="sticky-col">Trainee</th>
                  <% aspects.forEach(aspect => { %>
                    <th>
                      <div class="aspect-header">
                        <div class="aspect-name"><%= aspect.aspect_name %></div>
                        <div class="aspect-max">Max: <%= aspect.max_score %></div>
                      </div>
                    </th>
                  <% }); %>
                  <th>Comment</th>
                  <th>Total</th>
                </tr>
              </thead>
              <tbody>
                <% marksData.forEach(data => { %>
                  <tr data-enrollment-id="<%= data.enrollment_id %>">
                    <td class="sticky-col">
                      <strong><%= data.trainee_name %></strong><br>
                      <span style="color: #5F6368; font-size: 0.75rem;"><%= data.trainee_id %></span>
                    </td>
                  <% aspects.forEach(aspect => { %>
                    <% 
                      const existingScore = data.handsOnScores.find(s => s.aspect_id === aspect.id);
                      const scoreValue = existingScore ? parseFloat(existingScore.score) : '';
                    %>
                    <td>
                      <div class="score-input-wrapper">
                        <input 
                          type="number" 
                          class="hands-on-score-input" 
                          data-enrollment-id="<%= data.enrollment_id %>"
                          data-aspect-id="<%= aspect.id %>"
                          data-max-score="<%= aspect.max_score %>"
                          min="0" 
                          max="<%= aspect.max_score %>" 
                          step="0.1"
                          value="<%= scoreValue %>"
                          placeholder="0"
                          <%= training.is_locked ? 'disabled' : '' %>>
                        <span class="score-max">/<%= aspect.max_score %></span>
                      </div>
                    </td>
                  <% }); %>
                  <td>
                      <textarea
                        class="hands-on-comment"
                        data-enrollment-id="<%= data.enrollment_id %>"
                        rows="2"
                        placeholder="One comment for all outcomes"
                        <%= training.is_locked ? 'disabled' : '' %>><%= (data.handsOnScores.find(s => s.comments && s.comments.trim().length > 0) || {}).comments || '' %></textarea>
                    </td>
                    <td>
                      <span class="hands-on-total" data-enrollment-id="<%= data.enrollment_id %>">
                        <% 
                          const totalScore = practicalOutcomeTotalsFromScores(data.handsOnScores).total;
                          const maxScore = aspects.reduce((sum, a) => sum + (parseInt(a.max_score) || 0), 0);
                          const percentage = maxScore > 0 ? (totalScore / maxScore * 100).toFixed(1) : 0;
                        %>
                        <%= totalScore %>/<%= maxScore %> (<%= percentage %>%)
                      </span>
                    </td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          </div>

          <!-- Mobile Card View -->
          <div class="hands-on-cards-container">
            <% marksData.forEach(data => { %>
              <div class="hands-on-card" data-enrollment-id="<%= data.enrollment_id %>">
                <div class="card-header">
                  <strong><%= data.trainee_name %></strong><br>
                  <span style="color: #5F6368; font-size: 0.75rem;"><%= data.trainee_id %></span>
                </div>
                <div class="card-body">
                  <% aspects.forEach(aspect => { %>
                    <% 
                      const existingScore = data.handsOnScores.find(s => s.aspect_id === aspect.id);
                      const scoreValue = existingScore ? parseFloat(existingScore.score) : '';
                    %>
                    <div class="card-score-field">
                      <label>
                        <span class="field-label"><%= aspect.aspect_name %></span>
                        <span class="field-max">Max: <%= aspect.max_score %></span>
                      </label>
                      <div class="score-input-wrapper">
                        <input 
                          type="number" 
                          class="hands-on-score-input" 
                          data-enrollment-id="<%= data.enrollment_id %>"
                          data-aspect-id="<%= aspect.id %>"
                          data-max-score="<%= aspect.max_score %>"
                          min="0" 
                          max="<%= aspect.max_score %>" 
                          step="0.1"
                          value="<%= scoreValue %>"
                          placeholder="0"
                          <%= training.is_locked ? 'disabled' : '' %>>
                        <span class="score-max">/<%= aspect.max_score %></span>
                      </div>
                    </div>
                  <% }); %>
                  <div class="card-score-field">
                    <label>
                      <span class="field-label">Comment</span>
                    </label>
                    <textarea
                      class="hands-on-comment"
                      data-enrollment-id="<%= data.enrollment_id %>"
                      rows="2"
                      placeholder="One comment for all outcomes"
                      <%= training.is_locked ? 'disabled' : '' %>><%= (data.handsOnScores.find(s => s.comments && s.comments.trim().length > 0) || {}).comments || '' %></textarea>
                  </div>
                  <div class="card-total">
                    <strong>Total: </strong>
                    <span class="hands-on-total" data-enrollment-id="<%= data.enrollment_id %>">
                      <% 
                        const totalScoreHo = practicalOutcomeTotalsFromScores(data.handsOnScores).total;
                        const maxScoreHo = aspects.reduce((sum, a) => sum + (parseInt(a.max_score) || 0), 0);
                        const percentageHo = maxScoreHo > 0 ? (totalScoreHo / maxScoreHo * 100).toFixed(1) : 0;
                      %>
                      <%= totalScoreHo %>/<%= maxScoreHo %> (<%= percentageHo %>%)
                    </span>
                  </div>
                </div>
              </div>
            <% }); %>
          </div>
        </div>
      <% } %>
    <% } %>
  </div>

  <style>
    /* Mobile Cards for Test Scores */
    .marks-cards-mobile {
      display: none;
    }

    .marks-card-mobile {
      background: white;
      border: 1px solid #E8EAED;
      border-radius: 8px;
      padding: 1.25rem;
      margin-bottom: 1rem;
    }

    .marks-card-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding-bottom: 1rem;
      margin-bottom: 1rem;
      border-bottom: 1px solid #E8EAED;
    }

    .trainee-id-badge {
      background: #F1F3F5;
      color: #5F6368;
      padding: 0.25rem 0.625rem;
      border-radius: 4px;
      font-size: 0.75rem;
      font-weight: 500;
    }

    .marks-card-body {
      display: flex;
      flex-direction: column;
      gap: 0.875rem;
    }

    .marks-card-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .marks-label {
      font-weight: 500;
      color: #202124;
      font-size: 0.875rem;
    }

    .marks-card-actions {
      margin-top: 0.5rem;
      padding-top: 1rem;
      border-top: 1px solid #E8EAED;
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
    }

    .marks-card-actions .btn {
      flex: 1 1 160px;
      min-width: 0;
    }

    .marks-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      align-items: center;
    }

    .marks-actions .btn {
      min-height: 36px;
      padding: 0.45rem 0.75rem;
      font-size: 0.8rem;
      line-height: 1.2;
    }

    .practical-grading-criteria {
      margin: 0 auto 1.5rem;
      border: 1px solid #DADCE0;
      border-radius: 12px;
      overflow: hidden;
      background: #FFFFFF;
      width: 100%;
      max-width: 1080px;
    }

    .practical-grading-criteria__header {
      padding: 0.7rem 0.9rem;
      background: #F8F9FA;
      border-bottom: 1px solid #E8EAED;
      font-weight: 700;
      font-size: 0.92rem;
      color: #202124;
    }

    .practical-grading-criteria__table-wrap {
      overflow-x: auto;
    }

    .practical-grading-criteria__table {
      width: 100%;
      min-width: 820px;
      border-collapse: collapse;
      font-size: 0.84rem;
      line-height: 1.4;
    }

    .practical-grading-criteria__table th,
    .practical-grading-criteria__table td {
      border: 1px solid #DADCE0;
      vertical-align: top;
      padding: 0.65rem 0.75rem;
    }

    .practical-grading-criteria__table th {
      background: #111111;
      color: #FFFFFF;
      text-align: center;
      font-size: 0.85rem;
      font-weight: 700;
    }

    .practical-grading-criteria__table ul {
      margin: 0;
      padding-left: 0.95rem;
    }

    .practical-grading-criteria__table li + li {
      margin-top: 0.45rem;
    }

    @media (max-width: 768px) {
      .marks-table-desktop {
        display: none;
      }

      .marks-cards-mobile {
        display: block;
      }
    }

    /* Extra small screens (320px) */
    @media (max-width: 480px) {
      .section-card {
        padding: 1rem !important;
      }

      .section-title {
        font-size: 1rem;
      }

      #toggle-hands-on-btn {
        padding: 0.5rem 0.75rem;
        font-size: 0.8125rem;
        width: 100%;
      }

      #toggle-hands-on-btn span {
        display: inline;
      }

      .marks-card-mobile {
        padding: 1rem;
        margin-bottom: 0.75rem;
      }

      .marks-card-header {
        flex-direction: column;
        align-items: flex-start;
        gap: 0.5rem;
        padding-bottom: 0.75rem;
        margin-bottom: 0.75rem;
      }

      .marks-card-header strong {
