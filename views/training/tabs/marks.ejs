  </style>

  <% if (training.type === 'main' && aspects && aspects.length > 0) { %>
  <script>
    // Toggle hands-on grading section
    function toggleHandsOnGrading() {
      const section = document.getElementById('hands-on-grading-section');
      const btn = document.getElementById('toggle-hands-on-btn');
      const chevron = btn.querySelector('.fa-chevron-down');
      const textSpan = btn.querySelector('span');
      
      if (section.style.display === 'none') {
        section.style.display = 'block';
        chevron.style.transform = 'rotate(180deg)';
        textSpan.textContent = 'Hide Grading';
      } else {
        section.style.display = 'none';
        chevron.style.transform = 'rotate(0deg)';
        textSpan.textContent = 'Grade Practical Learning Outcome';
      }
    }

    // Calculate total for a trainee
    function updateTraineeTotal(enrollmentId) {
      const inputs = document.querySelectorAll(`.hands-on-score-input[data-enrollment-id="${enrollmentId}"]`);
      const byAspect = new Map();
      inputs.forEach(input => {
        const aid = input.dataset.aspectId;
        if (!byAspect.has(aid)) byAspect.set(aid, input);
      });
      let total = 0;
      let maxTotal = 0;
      byAspect.forEach(input => {
        const score = parseFloat(input.value) || 0;
        const maxScore = parseInt(input.dataset.maxScore, 10) || 0;
        total += score;
        maxTotal += maxScore;
      });

      const totalElements = document.querySelectorAll(`.hands-on-total[data-enrollment-id="${enrollmentId}"]`);
      const percentage = maxTotal > 0 ? ((total / maxTotal) * 100).toFixed(1) : 0;
      
      totalElements.forEach(el => {
        el.textContent = `${total}/${maxTotal} (${percentage}%)`;
      });
    }

    function syncHandsOnScoreInputs(sourceInput) {
      const enrollmentId = sourceInput.dataset.enrollmentId;
      const aspectId = sourceInput.dataset.aspectId;
      const value = sourceInput.value;
      document.querySelectorAll(
        `.hands-on-score-input[data-enrollment-id="${enrollmentId}"][data-aspect-id="${aspectId}"]`
      ).forEach(input => {
        if (input !== sourceInput) {
          input.value = value;
        }
      });
    }

    function syncHandsOnComments(sourceTextarea) {
      const enrollmentId = sourceTextarea.dataset.enrollmentId;
      const value = sourceTextarea.value;
      document.querySelectorAll(`.hands-on-comment[data-enrollment-id="${enrollmentId}"]`).forEach(textarea => {
        if (textarea !== sourceTextarea) {
          textarea.value = value;
        }
      });
    }

    // Add event listeners to all score inputs
    document.addEventListener('DOMContentLoaded', function() {
      const inputs = document.querySelectorAll('.hands-on-score-input');
      inputs.forEach(input => {
        const max = parseInt(input.dataset.maxScore, 10);
        const v = parseFloat(input.value);
        if (Number.isFinite(max) && max >= 0 && Number.isFinite(v) && v > max) {
          input.value = String(max);
        }
      });
      const syncKeys = new Set();
      inputs.forEach(input => {
        const k = `${input.dataset.enrollmentId}:${input.dataset.aspectId}`;
        if (syncKeys.has(k)) return;
        syncKeys.add(k);
        syncHandsOnScoreInputs(input);
      });
      const enrollmentIdsForTotals = new Set(Array.from(inputs).map(i => i.dataset.enrollmentId).filter(Boolean));
      enrollmentIdsForTotals.forEach(eid => updateTraineeTotal(eid));

      inputs.forEach(input => {
        input.addEventListener('wheel', function(e) {
          if (document.activeElement === this) {
            e.preventDefault();
            this.blur();
          }
        }, { passive: false });

        input.addEventListener('input', function() {
          const enrollmentId = this.dataset.enrollmentId;
          const maxScore = parseInt(this.dataset.maxScore, 10);
          const raw = parseFloat(this.value);

          if (Number.isFinite(maxScore) && maxScore >= 0 && Number.isFinite(raw) && raw > maxScore) {
            this.value = String(maxScore);
          }

          syncHandsOnScoreInputs(this);

          this.classList.remove('success', 'error');
          const effective = parseFloat(this.value);
          if (Number.isFinite(maxScore) && maxScore > 0 && Number.isFinite(effective) && effective > 0 && effective <= maxScore) {
            this.classList.add('success');
            setTimeout(() => this.classList.remove('success'), 500);
          }

          updateTraineeTotal(enrollmentId);
        });
      });

      const comments = document.querySelectorAll('.hands-on-comment');
      comments.forEach(textarea => {
        textarea.addEventListener('input', function() {
          syncHandsOnComments(this);
        });
      });
    });

    // Save all hands-on scores
    async function saveAllHandsOnScores() {
      const btn = document.getElementById('save-all-hands-on-btn');
      const originalText = btn.innerHTML;
      btn.disabled = true;
      btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> <span>Saving...</span>';

      try {
        const inputs = document.querySelectorAll('.hands-on-score-input');
        const enrollmentMap = new Map();

        // Group scores by enrollment
        inputs.forEach(input => {
          const enrollmentId = input.dataset.enrollmentId;
          const aspectId = input.dataset.aspectId;
          const score = parseFloat(input.value);

          if (!enrollmentMap.has(enrollmentId)) {
            enrollmentMap.set(enrollmentId, new Map());
          }

          if (!Number.isFinite(score)) return;
          enrollmentMap.get(enrollmentId).set(String(aspectId), {
            aspect_id: parseInt(aspectId, 10),
            score: score,
            comments: ''
          });
        });

        // Save scores for each enrollment
        const savePromises = [];
        for (const [enrollmentId, scoreMap] of enrollmentMap) {
          const commentEl = document.querySelector(`.hands-on-comment[data-enrollment-id="${enrollmentId}"]`);
          const commentText = commentEl ? commentEl.value.trim() : '';
          const scores = Array.from(scoreMap.values());
          scores.forEach(s => {
            s.comments = commentText;
          });
          if (scores.length > 0) {
            savePromises.push(
              fetch(`/training/<%= training.id %>/enrollment/${enrollmentId}/hands-on/save`, {
                method: 'POST',
                headers: {
                  'Content-Type': 'application/json',
                },
                body: JSON.stringify({ scores, comment: commentText })
              })
            );
          }
        }

        const results = await Promise.all(savePromises);
        const responses = await Promise.all(results.map(r => r.json()));

        const allSuccess = responses.every(r => r.success);
        if (allSuccess) {
          btn.innerHTML = '<i class="fas fa-check"></i> <span>Saved!</span>';
          btn.style.background = '#34A853';
          
          setTimeout(() => {
            location.reload();
          }, 800);
        } else {
          btn.innerHTML = '<i class="fas fa-times"></i> <span>Error</span>';
          btn.style.background = '#EA4335';
          setTimeout(() => {
            btn.disabled = false;
            btn.innerHTML = originalText;
            btn.style.background = '#573FD7';
          }, 2000);
        }
      } catch (error) {
        console.error('Error:', error);
        btn.innerHTML = '<i class="fas fa-times"></i> <span>Error</span>';
        btn.style.background = '#EA4335';
        setTimeout(() => {
          btn.disabled = false;
          btn.innerHTML = originalText;
          btn.style.background = '#573FD7';
        }, 2000);
      }
    }
  </script>
  <% } %>
  
  <% if (['admin', 'trainer'].includes(user.userRole)) { %>
  <script>
    // Score release functionality
    async function releaseScores(enrollmentIds, buttonEl) {
      const btn = buttonEl || null;
      const originalText = btn ? btn.innerHTML : '';
      if (btn) {
        btn.disabled = true;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Releasing...';
      }
      
      try {
        const response = await fetch(`/training/<%= training.id %>/release-scores`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({ enrollment_ids: enrollmentIds })
        });
        
        const data = await response.json();
        
        if (data.success) {
          qssShowMessage({
            type: 'success',
            title: 'Success',
            message: data.message || 'Scores released successfully!',
            onClose: () => location.reload()
          });
        } else {
          qssShowError('Error releasing scores: ' + (data.error || 'Unknown error'));
          if (btn) {
            btn.disabled = false;
            btn.innerHTML = originalText;
          }
        }
      } catch (error) {
        console.error('Error:', error);
        qssShowError('Error releasing scores');
        if (btn) {
          btn.disabled = false;
          btn.innerHTML = originalText;
        }
      }
    }
  </script>
  <% } %>
<% } %>
