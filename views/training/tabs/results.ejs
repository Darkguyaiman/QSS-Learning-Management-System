<!-- Results Tab (Trainee Only - After Score Release) -->
<% if (user.userRole === 'trainee' && enrollment && enrollment.can_download_results) { %>
  <div id="results-tab" class="tab-content">
    <div class="results-container results-tab">
      <!-- Header Banner -->
      <div class="results-header">
        <div class="header-content">
          <div class="congratulations-icon">
            <i class="fas fa-trophy"></i>
          </div>
          <h1>Congratulations!</h1>
          <p>Your scores have been released. View your comprehensive results below.</p>
        </div>
      </div>
      
      <!-- Test Scores Section -->
      <div class="results-section">
        <div class="section-header">
          <i class="fas fa-clipboard-check"></i>
          <h2>Test Scores</h2>
        </div>
        
        <div class="test-scores-grid">
          <% 
            const preTest = marksData && marksData.tests ? marksData.tests.find(t => t.test_type === 'pre_test') : null;
            const postTest = marksData && marksData.tests ? marksData.tests.find(t => t.test_type === 'post_test') : null;
            const certificateEnrolmentTest = marksData && marksData.tests ? marksData.tests.find(t => t.test_type === 'certificate_enrolment') : null;
            const refresher_trainingTest = marksData && marksData.tests ? marksData.tests.find(t => t.test_type === 'refresher_training') : null;
          %>
          
          <% if (preTest) { %>
            <div class="test-card pre-test">
              <div class="test-icon">
                <i class="fas fa-play-circle"></i>
              </div>
              <div class="test-content">
                <h3>Pre-Test</h3>
                <p class="test-description">Initial Assessment</p>
                <div class="test-score <%= preTest.score >= 80 ? 'passed' : 'failed' %>">
                  <span class="score-value"><%= preTest.score.toFixed(1) %>%</span>
                  <span class="score-status"><%= preTest.score >= 80 ? 'Outstanding' : 'Not Passed' %></span>
                </div>
              </div>
            </div>
          <% } %>
          
          <% if (training.type === 'main') { %>
            <% if (postTest) { %>
              <div class="test-card post-test">
                <div class="test-icon">
                  <i class="fas fa-check-circle"></i>
                </div>
                <div class="test-content">
                  <h3>Post-Test</h3>
                  <p class="test-description">Final Assessment</p>
                  <div class="test-score <%= postTest.score >= 80 ? 'passed' : 'failed' %>">
                    <span class="score-value"><%= postTest.score.toFixed(1) %>%</span>
                    <span class="score-status"><%= postTest.score >= 80 ? 'Outstanding' : 'Not Passed' %></span>
                  </div>
                </div>
              </div>
            <% } %>
            
            <% if (certificateEnrolmentTest) { %>
              <div class="test-card certificate-test">
                <div class="test-icon">
                  <i class="fas fa-certificate"></i>
                </div>
                <div class="test-content">
                  <h3>Certificate Enrolment Test</h3>
                  <p class="test-description">Certification Assessment</p>
                  <div class="test-score <%= certificateEnrolmentTest.score >= 80 ? 'passed' : 'failed' %>">
                    <span class="score-value"><%= certificateEnrolmentTest.score.toFixed(1) %>%</span>
                    <span class="score-status"><%= certificateEnrolmentTest.score >= 80 ? 'Outstanding' : 'Not Passed' %></span>
                  </div>
                </div>
              </div>
            <% } %>
          <% } else { %>
            <% if (refresher_trainingTest) { %>
              <div class="test-card refresher_training-test">
                <div class="test-icon">
                  <i class="fas fa-sync-alt"></i>
                </div>
                <div class="test-content">
                  <h3>Refresher Training Test</h3>
                  <p class="test-description">Refresher Training Assessment</p>
                  <div class="test-score <%= refresher_trainingTest.score >= 80 ? 'passed' : 'failed' %>">
                    <span class="score-value"><%= refresher_trainingTest.score.toFixed(1) %>%</span>
                    <span class="score-status"><%= refresher_trainingTest.score >= 80 ? 'Outstanding' : 'Not Passed' %></span>
                  </div>
                </div>
              </div>
            <% } %>
          <% } %>
        </div>
      </div>
      
      <!-- Practical Learning Outcome Scores Section -->
      <% if (training.type === 'main' && marksData && marksData.handsOnScores && marksData.handsOnScores.length > 0) { %>
        <div class="results-section">
          <div class="section-header">
            <i class="fas fa-hand-paper"></i>
            <h2>Practical Learning Outcome Evaluation</h2>
          </div>
          
          <div class="hands-on-grid">
            <% marksData.handsOnScores.forEach(score => { %>
              <div class="hands-on-card">
                <div class="hands-on-header">
                  <h4><%= score.aspect_name %></h4>
                  <div class="hands-on-score">
                    <span class="score-numerator"><%= parseFloat(score.score).toFixed(1) %></span>
                    <span class="score-divider">/</span>
                    <span class="score-denominator"><%= score.max_score %></span>
                  </div>
                </div>
                <p class="hands-on-description"><%= score.description || 'No description available' %></p>
                <% const handsOnPercent = ((parseFloat(score.score) / parseInt(score.max_score)) * 100); %>
                <div class="hands-on-percentage">
                  <%= handsOnPercent.toFixed(1) %>%
                  <span class="hands-on-status <%= handsOnPercent >= 80 ? 'status-outstanding' : 'status-not-passed' %>">
                    <%= handsOnPercent >= 80 ? 'Outstanding' : 'Not Passed' %>
                  </span>
                </div>
              </div>
            <% }); %>
          </div>
        </div>
      <% } %>
      
      <!-- Final Grade Section -->
      <% if (marksData && marksData.finalGrade) { %>
        <div class="results-section">
          <div class="section-header">
            <i class="fas fa-trophy"></i>
            <h2>Final Grade</h2>
          </div>
          
          <div class="final-grade-card">
            <div class="final-grade-content">
              <div class="final-grade-label">Overall Performance</div>
              <div class="final-grade-value"><%= parseFloat(marksData.finalGrade.training_grade || 0).toFixed(1) %>%</div>
              <div class="final-grade-subtitle">Training Grade</div>
            </div>
          </div>
        </div>
      <% } %>
      
      <!-- Certificate Download Section -->
      <% 
        const certTest = marksData && marksData.tests ? marksData.tests.find(t => t.test_type === 'certificate_enrolment') : null;
        const certOutstanding = certTest && certTest.score >= 80;
        let practicalOutstanding = true;
        if (training.type === 'main' && marksData && marksData.handsOnScores && marksData.handsOnScores.length > 0) {
          const total = marksData.handsOnScores.reduce((sum, s) => sum + (parseFloat(s.score) / parseFloat(s.max_score) * 100), 0);
          const avg = total / marksData.handsOnScores.length;
          practicalOutstanding = avg >= 80;
        }
        const canDownloadCertificate = certOutstanding && practicalOutstanding;
      %>
      <div class="certificate-download-section">
        <div class="certificate-icon">
          <i class="fas fa-certificate"></i>
        </div>
        <h3>Download Your Certificate</h3>
        <% if (canDownloadCertificate) { %>
          <p>Your official certificate of completion is ready for download.</p>
          <a href="/training/<%= training.id %>/certificate/<%= enrollment.id %>" target="_blank" class="btn-certificate">
            <i class="fas fa-download"></i>
            Download Certificate
          </a>
        <% } else { %>
          <p>Certificate becomes available after both Certificate Enrolment Test and Practical Learning Outcome are Outstanding (80%+).</p>
          <button class="btn-certificate" style="opacity: 0.6; cursor: not-allowed;" disabled>
            <i class="fas fa-lock"></i>
            Certificate Locked
          </button>
        <% } %>
      </div>
    </div>
  </div>
<% } %>

