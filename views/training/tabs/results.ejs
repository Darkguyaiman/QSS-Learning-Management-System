<!-- Results Tab (Trainee Only - After Score Release) -->
<% if (user.userRole === 'trainee' && enrollment && enrollment.can_download_results) { %>
  <div id="results-tab" class="tab-content">
    <div class="results-container">
      <!-- Header Banner -->
      <div class="results-header">
        <div class="header-content">
          <div class="congratulations-icon">
            <i class="fas fa-trophy"></i>
          </div>
          <h1>Congratulations!</h1>
          <p>Your scores have been released. View your comprehensive results below.</p>
        </div>
      </div>
      
      <!-- Test Scores Section -->
      <div class="results-section">
        <div class="section-header">
          <i class="fas fa-clipboard-check"></i>
          <h2>Test Scores</h2>
        </div>
        
        <div class="test-scores-grid">
          <% 
            const preTest = marksData && marksData.tests ? marksData.tests.find(t => t.test_type === 'pre_test') : null;
            const postTest = marksData && marksData.tests ? marksData.tests.find(t => t.test_type === 'post_test') : null;
            const certificateEnrolmentTest = marksData && marksData.tests ? marksData.tests.find(t => t.test_type === 'certificate_enrolment') : null;
            const refreshmentTest = marksData && marksData.tests ? marksData.tests.find(t => t.test_type === 'refreshment') : null;
          %>
          
          <% if (preTest) { %>
            <div class="test-card pre-test">
              <div class="test-icon">
                <i class="fas fa-play-circle"></i>
              </div>
              <div class="test-content">
                <h3>Pre-Test</h3>
                <p class="test-description">Initial Assessment</p>
                <div class="test-score <%= preTest.score >= 50 ? 'passed' : 'failed' %>">
                  <span class="score-value"><%= preTest.score.toFixed(1) %>%</span>
                  <span class="score-status"><%= preTest.score >= 50 ? 'Passed' : 'Failed' %></span>
                </div>
              </div>
            </div>
          <% } %>
          
          <% if (training.type === 'main') { %>
            <% if (postTest) { %>
              <div class="test-card post-test">
                <div class="test-icon">
                  <i class="fas fa-check-circle"></i>
                </div>
                <div class="test-content">
                  <h3>Post-Test</h3>
                  <p class="test-description">Final Assessment</p>
                  <div class="test-score <%= postTest.score >= 50 ? 'passed' : 'failed' %>">
                    <span class="score-value"><%= postTest.score.toFixed(1) %>%</span>
                    <span class="score-status"><%= postTest.score >= 50 ? 'Passed' : 'Failed' %></span>
                  </div>
                </div>
              </div>
            <% } %>
            
            <% if (certificateEnrolmentTest) { %>
              <div class="test-card certificate-test">
                <div class="test-icon">
                  <i class="fas fa-certificate"></i>
                </div>
                <div class="test-content">
                  <h3>Certificate Enrolment Test</h3>
                  <p class="test-description">Certification Assessment</p>
                  <div class="test-score <%= certificateEnrolmentTest.score >= 50 ? 'passed' : 'failed' %>">
                    <span class="score-value"><%= certificateEnrolmentTest.score.toFixed(1) %>%</span>
                    <span class="score-status"><%= certificateEnrolmentTest.score >= 50 ? 'Passed' : 'Failed' %></span>
                  </div>
                </div>
              </div>
            <% } %>
          <% } else { %>
            <% if (refreshmentTest) { %>
              <div class="test-card refreshment-test">
                <div class="test-icon">
                  <i class="fas fa-sync-alt"></i>
                </div>
                <div class="test-content">
                  <h3>Refreshment Test</h3>
                  <p class="test-description">Refreshment Assessment</p>
                  <div class="test-score <%= refreshmentTest.score >= 50 ? 'passed' : 'failed' %>">
                    <span class="score-value"><%= refreshmentTest.score.toFixed(1) %>%</span>
                    <span class="score-status"><%= refreshmentTest.score >= 50 ? 'Passed' : 'Failed' %></span>
                  </div>
                </div>
              </div>
            <% } %>
          <% } %>
        </div>
      </div>
      
      <!-- Hands-On Scores Section -->
      <% if (training.type === 'main' && marksData && marksData.handsOnScores && marksData.handsOnScores.length > 0) { %>
        <div class="results-section">
          <div class="section-header">
            <i class="fas fa-hand-paper"></i>
            <h2>Hands-On Evaluation</h2>
          </div>
          
          <div class="hands-on-grid">
            <% marksData.handsOnScores.forEach(score => { %>
              <div class="hands-on-card">
                <div class="hands-on-header">
                  <h4><%= score.aspect_name %></h4>
                  <div class="hands-on-score">
                    <span class="score-numerator"><%= parseFloat(score.score).toFixed(1) %></span>
                    <span class="score-divider">/</span>
                    <span class="score-denominator"><%= score.max_score %></span>
                  </div>
                </div>
                <p class="hands-on-description"><%= score.description || 'No description available' %></p>
                <div class="hands-on-percentage">
                  <%= ((parseFloat(score.score) / parseInt(score.max_score)) * 100).toFixed(1) %>%
                </div>
              </div>
            <% }); %>
          </div>
        </div>
      <% } %>
      
      <!-- Final Grade Section -->
      <% if (marksData && marksData.finalGrade) { %>
        <div class="results-section">
          <div class="section-header">
            <i class="fas fa-trophy"></i>
            <h2>Final Grade</h2>
          </div>
          
          <div class="final-grade-card">
            <div class="final-grade-content">
              <div class="final-grade-label">Overall Performance</div>
              <div class="final-grade-value"><%= parseFloat(marksData.finalGrade.training_grade || 0).toFixed(1) %>%</div>
              <div class="final-grade-subtitle">Training Grade</div>
            </div>
          </div>
        </div>
      <% } %>
      
      <!-- Certificate Download Section -->
      <div class="certificate-download-section">
        <div class="certificate-icon">
          <i class="fas fa-certificate"></i>
        </div>
        <h3>Download Your Certificate</h3>
        <p>Your official certificate of completion is ready for download.</p>
        <a href="/training/<%= training.id %>/certificate/<%= enrollment.id %>" target="_blank" class="btn-certificate">
          <i class="fas fa-download"></i>
          Download Certificate
        </a>
      </div>
    </div>
  </div>
  
  <style>
    .results-container {
      max-width: 1200px;
      margin: 0 auto;
    }
    
    .results-header {
      background: linear-gradient(135deg, #573FD7 0%, #4A34B8 100%);
      border-radius: 16px;
      padding: 3rem 2rem;
      text-align: center;
      color: white;
      margin-bottom: 2rem;
      box-shadow: 0 8px 24px rgba(87, 63, 215, 0.3);
    }
    
    .header-content {
      position: relative;
    }
    
    .congratulations-icon {
      font-size: 4rem;
      margin-bottom: 1rem;
      opacity: 0.9;
    }
    
    .results-header h1 {
      font-size: 2.5rem;
      margin: 0 0 0.5rem 0;
      font-weight: 700;
    }
    
    .results-header p {
      font-size: 1.2rem;
      margin: 0;
      opacity: 0.95;
    }
    
    .results-section {
      background: white;
      border-radius: 12px;
      padding: 2rem;
      margin-bottom: 2rem;
      box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    }
    
    .section-header {
      display: flex;
      align-items: center;
      gap: 1rem;
      margin-bottom: 1.5rem;
      padding-bottom: 1rem;
      border-bottom: 2px solid #E8EAED;
    }
    
    .section-header i {
      font-size: 1.5rem;
      color: #573FD7;
    }
    
    .section-header h2 {
      margin: 0;
      font-size: 1.5rem;
      color: #202124;
    }
    
    .test-scores-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 1.5rem;
    }
    
    .test-card {
      background: white;
      border-radius: 12px;
      padding: 2rem;
      border: 2px solid #E8EAED;
      transition: all 0.3s ease;
      position: relative;
      overflow: hidden;
    }
    
    .test-card::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 5px;
      background: var(--test-color);
    }
    
    .test-card.pre-test::before {
      background: linear-gradient(90deg, #4285F4, #34A853);
    }
    
    .test-card.post-test::before {
      background: linear-gradient(90deg, #34A853, #FBBC04);
    }
    
    .test-card.certificate-test::before {
      background: linear-gradient(90deg, #EA4335, #573FD7);
    }
    
    .test-card.refreshment-test::before {
      background: linear-gradient(90deg, #9C27B0, #673AB7);
    }
    
    .test-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 8px 24px rgba(0,0,0,0.15);
    }
    
    .test-icon {
      width: 70px;
      height: 70px;
      border-radius: 50%;
      background: linear-gradient(135deg, #F8F9FF 0%, #FFF8F0 100%);
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 1.5rem;
      font-size: 2rem;
      color: #573FD7;
    }
    
    .test-content {
      text-align: center;
    }
    
    .test-content h3 {
      margin: 0 0 0.5rem 0;
      font-size: 1.3rem;
      color: #202124;
    }
    
    .test-description {
      margin: 0 0 1.5rem 0;
      color: #5F6368;
      font-size: 0.9rem;
    }
    
    .test-score {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.5rem;
    }
    
    .score-value {
      font-size: 2.5rem;
      font-weight: bold;
    }
    
    .score-status {
      font-size: 1rem;
      font-weight: 600;
      padding: 0.5rem 1.5rem;
      border-radius: 20px;
      text-transform: uppercase;
      letter-spacing: 1px;
    }
    
    .test-score.passed .score-value {
      color: #34A853;
    }
    
    .test-score.passed .score-status {
      background: #E6F4EA;
      color: #137333;
    }
    
    .test-score.failed .score-value {
      color: #EA4335;
    }
    
    .test-score.failed .score-status {
      background: #FCE8E6;
      color: #C5221F;
    }
    
    .hands-on-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 1.5rem;
    }
    
    .hands-on-card {
      background: linear-gradient(135deg, #F8F9FF 0%, #FFF8F0 100%);
      border-radius: 12px;
      padding: 1.5rem;
      border: 2px solid #E8EAED;
      transition: all 0.3s ease;
    }
    
    .hands-on-card:hover {
      transform: translateY(-2px);
      box-shadow: 0 4px 12px rgba(87, 63, 215, 0.15);
    }
    
    .hands-on-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 1rem;
    }
    
    .hands-on-header h4 {
      margin: 0;
      font-size: 1.1rem;
      color: #202124;
    }
    
    .hands-on-score {
      display: flex;
      align-items: baseline;
      gap: 0.25rem;
      font-size: 1.3rem;
      font-weight: bold;
      color: #573FD7;
    }
    
    .hands-on-description {
      margin: 0 0 1rem 0;
      color: #5F6368;
      font-size: 0.9rem;
      line-height: 1.5;
    }
    
    .hands-on-percentage {
      text-align: right;
      font-size: 0.9rem;
      color: #5F6368;
      font-weight: 600;
    }
    
    .final-grade-card {
      background: linear-gradient(135deg, #573FD7 0%, #4A34B8 100%);
      border-radius: 16px;
      padding: 3rem 2rem;
      text-align: center;
      color: white;
      box-shadow: 0 8px 24px rgba(87, 63, 215, 0.3);
    }
    
    .final-grade-label {
      font-size: 1.2rem;
      opacity: 0.95;
      margin-bottom: 1rem;
      text-transform: uppercase;
      letter-spacing: 2px;
    }
    
    .final-grade-value {
      font-size: 4.5rem;
      font-weight: bold;
      margin-bottom: 0.5rem;
      text-shadow: 2px 2px 4px rgba(0,0,0,0.2);
    }
    
    .final-grade-subtitle {
      font-size: 1.1rem;
      opacity: 0.9;
    }
    
    .certificate-download-section {
      background: linear-gradient(135deg, #F8F9FF 0%, #FFF8F0 100%);
      border-radius: 16px;
      padding: 3rem 2rem;
      text-align: center;
      border: 2px solid #E8EAED;
    }
    
    .certificate-icon {
      font-size: 4rem;
      color: #573FD7;
      margin-bottom: 1rem;
    }
    
    .certificate-download-section h3 {
      margin: 0 0 0.5rem 0;
      font-size: 1.8rem;
      color: #202124;
    }
    
    .certificate-download-section p {
      margin: 0 0 2rem 0;
      color: #5F6368;
      font-size: 1.1rem;
    }
    
    .btn-certificate {
      display: inline-flex;
      align-items: center;
      gap: 0.75rem;
      padding: 1rem 2.5rem;
      background: linear-gradient(135deg, #573FD7 0%, #4A34B8 100%);
      color: white;
      border-radius: 8px;
      text-decoration: none;
      font-size: 1.1rem;
      font-weight: 600;
      transition: all 0.3s ease;
      box-shadow: 0 4px 15px rgba(87, 63, 215, 0.3);
    }
    
    .btn-certificate:hover {
      transform: translateY(-2px);
      box-shadow: 0 6px 20px rgba(87, 63, 215, 0.4);
    }
    
    .btn-certificate i {
      font-size: 1.2rem;
    }
  </style>
<% } %>
