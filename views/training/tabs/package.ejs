<% if (['admin', 'trainer'].includes(user.userRole)) { %>
<%
  const affiliatedCompany = ((training && training.affiliated_company) ? String(training.affiliated_company) : 'QSS').toUpperCase() === 'PMS' ? 'PMS' : 'QSS';
  const affiliatedBrand = affiliatedCompany === 'PMS'
    ? { code: 'PMS', name: 'Photomedic Solutions Sdn. Bhd.', shortName: 'PMS', logo: '/images/Affiliated%20Companies/pmslogo.svg' }
    : { code: 'QSS', name: 'Quick Stop Solution Sdn. Bhd.', shortName: 'QSS', logo: '/images/Affiliated%20Companies/qsslogo.svg' };
  const selectedHealthcareId = Array.isArray(trainingHealthcare) && trainingHealthcare.length > 0
    ? String(trainingHealthcare[0].healthcare_id || '')
    : '';
  const selectedHealthcare = Array.isArray(allHealthcare)
    ? allHealthcare.find(item => String(item.id) === selectedHealthcareId)
    : null;
  const defaultHospitalName = selectedHealthcare?.name || '';
  const defaultHospitalAddress = selectedHealthcare?.hospital_address || '';
  let defaultModelName = '';
  if (Array.isArray(allDeviceModels)) {
    const model = allDeviceModels.find(m => String(m.id) === String(training.device_model_id));
    defaultModelName = model ? model.model_name : '';
  }
%>
<div id="package-tab" class="tab-content">
  <div class="package-shell">
    <div class="package-head">
      <h3>Generate Training Package</h3>
        <p>
          The system automatically generates a ZIP package that includes the in-house training letter, group report, individual reports, and certificates when available.
        </p>    
    </div>

    <div class="package-grid">
      <div class="form-group">
        <label>Affiliated Company</label>
        <input type="text" class="form-input" value="<%= affiliatedBrand.shortName %>" readonly>
      </div>
      <div class="form-group package-hidden-field">
        <label for="package-hospital-name">Hospital Name</label>
        <input id="package-hospital-name" class="form-input" type="text" value="<%= defaultHospitalName %>" readonly>
      </div>
      <div class="form-group">
        <label for="package-device-model">Device Model</label>
        <input id="package-device-model" class="form-input" type="text" value="<%= defaultModelName %>" readonly>
      </div>
      <div class="form-group package-span-2 package-hidden-field">
        <label for="package-address">Hospital Address</label>
        <textarea id="package-address" class="form-input" rows="2" readonly><%= defaultHospitalAddress %></textarea>
      </div>
      <div class="form-group">
        <label for="package-recipient-name">Recipient Name</label>
        <input id="package-recipient-name" class="form-input" type="text" placeholder="Mr/Mrs">
      </div>
      <div class="form-group">
        <label for="package-recipient-phone">Recipient Phone</label>
        <input id="package-recipient-phone" class="form-input" type="text" placeholder="+60...">
      </div>
    </div>

    <input type="hidden" id="package-hospital-name-hidden" value="<%= defaultHospitalName %>">
    <input type="hidden" id="package-address-hidden" value="<%= defaultHospitalAddress %>">

    <div class="package-actions">
      <button type="button" id="btn-generate-package-tab" class="btn btn-primary">
        <i class="fas fa-file-archive"></i> Generate ZIP Package
      </button>
    </div>
    <p id="package-job-status" class="package-job-status" aria-live="polite"></p>
  </div>
</div>

<style>
  .package-shell {
    background: #fff;
    border-radius: 14px;
    padding: 1.25rem;
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
  }
  .package-head h3 {
    margin: 0;
    color: #0f172a;
  }
  .package-head p {
    margin: 0.4rem 0 1rem 0;
    color: #475569;
    font-size: 0.92rem;
  }
  .package-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.85rem;
  }
  .package-span-2 {
    grid-column: span 2;
  }
  .package-hidden-field {
    display: none;
  }
  .package-actions {
    margin-top: 1rem;
    display: flex;
    justify-content: flex-end;
  }
  .package-job-status {
    margin: 0.75rem 0 0 0;
    min-height: 1.2rem;
    color: #475569;
    font-size: 0.9rem;
  }
  @media (max-width: 768px) {
    .package-grid {
      grid-template-columns: 1fr;
    }
    .package-span-2 {
      grid-column: span 1;
    }
  }
</style>

<script>
  window.PACKAGE_CONTEXT = {
    trainingId: <%- JSON.stringify(training.id) %>,
    trainingTitle: <%- JSON.stringify(training.title || '') %>,
    trainingType: <%- JSON.stringify(training.type || '') %>,
    isLocked: <%- JSON.stringify(training.status === 'completed') %>,
    trainingStartDate: <%- JSON.stringify(training.start_datetime || '') %>,
    trainingEndDate: <%- JSON.stringify(training.end_datetime || '') %>,
    companyCode: <%- JSON.stringify(affiliatedBrand.code) %>,
    companyName: <%- JSON.stringify(affiliatedBrand.name) %>,
    companyShortName: <%- JSON.stringify(affiliatedBrand.shortName) %>,
    companyLogo: <%- JSON.stringify(affiliatedBrand.logo) %>,
    generatedByName: <%- JSON.stringify(user.userName || '') %>,
    generatedByPosition: <%- JSON.stringify(user.userPosition || '') %>,
    autoHospitalName: <%- JSON.stringify(defaultHospitalName || '') %>,
    autoHospitalAddress: <%- JSON.stringify(defaultHospitalAddress || '') %>,
    marksData: <%- JSON.stringify(Array.isArray(marksData) ? marksData : []) %>,
    attendanceData: <%- JSON.stringify(Array.isArray(attendanceData) ? attendanceData : []) %>
  };
</script>
<script src="/js/training/package/package-common.js"></script>
<script src="/js/training/package/attendance-report.js"></script>
<script src="/js/training/package/letter.js"></script>
<script src="/js/training/package/group-report.js"></script>
<script src="/js/training/package/individual-report.js"></script>
<script src="/js/training/package/package.js"></script>
<% } %>
