    background: #fff;
    border-radius: 14px;
    padding: 1.25rem;
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
  }
  .package-head h3 {
    margin: 0;
    color: #0f172a;
  }
  .package-head p {
    margin: 0.4rem 0 1rem 0;
    color: #475569;
    font-size: 0.92rem;
  }
  .package-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.85rem;
  }
  .package-span-2 {
    grid-column: span 2;
  }
  .package-trainees-wrap {
    margin-top: 1rem;
    border: 1px solid #e2e8f0;
    border-radius: 12px;
    padding: 0.8rem;
    background: #f8fafc;
  }
  .package-trainees-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.55rem;
  }
  .package-trainees-head h4 {
    margin: 0;
    color: #0f172a;
  }
  .package-trainees-list {
    max-height: 280px;
    overflow: auto;
    border-radius: 8px;
  }
  .package-trainee-item {
    background: #fff;
    border: 1px solid #e2e8f0;
    border-radius: 10px;
    padding: 0.55rem 0.7rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
