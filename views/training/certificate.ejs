<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Certificate of Completion - <%= enrollment.training_title %></title>
  <style>
    @page {
      size: A4 landscape;
      margin: 0;
    }
    
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    
    body {
      font-family: 'Georgia', 'Times New Roman', serif;
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      padding: 40px 20px;
      min-height: 100vh;
    }
    
    .certificate-container {
      max-width: 1200px;
      margin: 0 auto;
      background: #ffffff;
      padding: 80px 60px;
      box-shadow: 0 20px 60px rgba(0,0,0,0.3);
      position: relative;
      border-radius: 8px;
    }
    
    /* Ornate Border Design */
    .certificate-container::before {
      content: '';
      position: absolute;
      top: 30px;
      left: 30px;
      right: 30px;
      bottom: 30px;
      border: 12px solid #573FD7;
      border-radius: 6px;
      pointer-events: none;
      z-index: 0;
    }
    
    .certificate-container::after {
      content: '';
      position: absolute;
      top: 50px;
      left: 50px;
      right: 50px;
      bottom: 50px;
      border: 3px solid #E48F24;
      border-radius: 4px;
      pointer-events: none;
      z-index: 0;
    }
    
    /* Decorative Corner Elements */
    .corner-decoration {
      position: absolute;
      width: 80px;
      height: 80px;
      border: 4px solid #573FD7;
      z-index: 1;
    }
    
    .corner-top-left {
      top: 60px;
      left: 60px;
      border-right: none;
      border-bottom: none;
    }
    
    .corner-top-right {
      top: 60px;
      right: 60px;
      border-left: none;
      border-bottom: none;
    }
    
    .corner-bottom-left {
      bottom: 60px;
      left: 60px;
      border-right: none;
      border-top: none;
    }
    
    .corner-bottom-right {
      bottom: 60px;
      right: 60px;
      border-left: none;
      border-top: none;
    }
    
    /* Header Section */
    .certificate-header {
      text-align: center;
      margin-bottom: 50px;
      position: relative;
      z-index: 1;
    }
    
    .certificate-logo {
      font-size: 2rem;
      font-weight: bold;
      color: #573FD7;
      margin-bottom: 15px;
      letter-spacing: 4px;
      text-transform: uppercase;
    }
    
    .certificate-seal {
      width: 120px;
      height: 120px;
      margin: 20px auto;
      border: 6px solid #573FD7;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      background: linear-gradient(135deg, #573FD7 0%, #E48F24 100%);
      color: white;
      font-size: 3rem;
      font-weight: bold;
      box-shadow: 0 4px 15px rgba(87, 63, 215, 0.3);
    }
    
    .certificate-title {
      font-size: 4rem;
      font-weight: bold;
      color: #1a1a1a;
      margin: 30px 0;
      text-transform: uppercase;
      letter-spacing: 6px;
      position: relative;
      display: inline-block;
      font-family: 'Times New Roman', serif;
    }
    
    .certificate-title::before,
    .certificate-title::after {
      content: '✦';
      position: absolute;
      top: 50%;
      transform: translateY(-50%);
      color: #E48F24;
      font-size: 2rem;
    }
    
    .certificate-title::before {
      left: -60px;
    }
    
    .certificate-title::after {
      right: -60px;
    }
    
    .certificate-subtitle {
      font-size: 1.6rem;
      color: #5F6368;
      margin-top: 30px;
      font-style: italic;
      font-weight: 300;
    }
    
    /* Body Section */
    .certificate-body {
      text-align: center;
      margin: 60px 0;
      position: relative;
      z-index: 1;
    }
    
    .certificate-text {
      font-size: 1.8rem;
      color: #202124;
      line-height: 2;
      margin-bottom: 40px;
      font-weight: 300;
    }
    
    .trainee-name {
      font-size: 3.5rem;
      font-weight: bold;
      color: #573FD7;
      margin: 40px 0;
      text-decoration: underline;
      text-decoration-color: #E48F24;
      text-decoration-thickness: 4px;
      text-underline-offset: 15px;
      letter-spacing: 2px;
    }
    
    .training-name {
      font-size: 2.2rem;
      font-weight: 600;
      color: #1a1a1a;
      margin: 30px 0;
      font-style: italic;
      padding: 20px;
      background: linear-gradient(135deg, #F8F9FF 0%, #FFF8F0 100%);
      border-radius: 8px;
      display: inline-block;
      border-left: 5px solid #573FD7;
      border-right: 5px solid #E48F24;
    }
    
    /* Details Section */
    .certificate-details {
      margin-top: 60px;
      padding-top: 40px;
      border-top: 3px solid #E8EAED;
      text-align: center;
      position: relative;
      z-index: 1;
    }
    
    .details-row {
      display: flex;
      justify-content: center;
      gap: 40px;
      margin: 30px 0;
      flex-wrap: wrap;
    }
    
    .detail-item {
      padding: 20px 30px;
      background: linear-gradient(135deg, #F8F9FF 0%, #FFF8F0 100%);
      border-radius: 10px;
      border: 2px solid #E8EAED;
      min-width: 250px;
    }
    
    .detail-label {
      font-size: 0.9rem;
      color: #5F6368;
      margin-bottom: 8px;
      text-transform: uppercase;
      letter-spacing: 2px;
      font-weight: 600;
    }
    
    .detail-value {
      font-size: 1.3rem;
      color: #202124;
      font-weight: bold;
    }
    
    .scores-section {
      margin-top: 40px;
      padding: 30px;
      background: linear-gradient(135deg, #F8F9FF 0%, #FFF8F0 100%);
      border-radius: 12px;
      border: 2px solid #E8EAED;
    }
    
    .scores-title {
      font-size: 1.5rem;
      font-weight: bold;
      color: #202124;
      margin-bottom: 25px;
      text-align: center;
      text-transform: uppercase;
      letter-spacing: 2px;
    }
    
    .scores-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 20px;
      margin-top: 20px;
    }
    
    .score-item {
      padding: 20px;
      background: white;
      border-radius: 10px;
      text-align: center;
      border: 2px solid #E8EAED;
      box-shadow: 0 2px 8px rgba(0,0,0,0.05);
      transition: transform 0.2s;
    }
    
    .score-item:hover {
      transform: translateY(-3px);
      box-shadow: 0 4px 12px rgba(87, 63, 215, 0.15);
    }
    
    .score-label {
      font-size: 0.9rem;
      color: #5F6368;
      margin-bottom: 10px;
      text-transform: uppercase;
      letter-spacing: 1px;
      font-weight: 600;
    }
    
    .score-value {
      font-size: 2rem;
      font-weight: bold;
      color: #573FD7;
    }
    
    .final-grade {
      margin-top: 40px;
      padding: 40px;
      background: linear-gradient(135deg, #573FD7 0%, #4A34B8 100%);
      color: white;
      border-radius: 12px;
      text-align: center;
      box-shadow: 0 8px 24px rgba(87, 63, 215, 0.3);
    }
    
    .final-grade-label {
      font-size: 1.2rem;
      opacity: 0.95;
      margin-bottom: 15px;
      text-transform: uppercase;
      letter-spacing: 2px;
    }
    
    .final-grade-value {
      font-size: 4rem;
      font-weight: bold;
      text-shadow: 2px 2px 4px rgba(0,0,0,0.2);
    }
    
    /* Footer Section */
    .certificate-footer {
      margin-top: 80px;
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      padding-top: 40px;
      border-top: 3px solid #E8EAED;
      position: relative;
      z-index: 1;
    }
    
    .signature {
      width: 280px;
      text-align: center;
    }
    
    .signature-line {
      border-top: 3px solid #202124;
      margin-top: 80px;
      margin-bottom: 15px;
      width: 100%;
    }
    
    .signature-name {
      font-size: 1.1rem;
      font-weight: bold;
      color: #202124;
      margin-top: 8px;
    }
    
    .signature-title {
      font-size: 0.95rem;
      color: #5F6368;
      margin-top: 5px;
      font-style: italic;
    }
    
    .certificate-date {
      text-align: center;
      flex: 1;
    }
    
    .date-label {
      font-size: 1rem;
      color: #5F6368;
      margin-bottom: 8px;
      text-transform: uppercase;
      letter-spacing: 1px;
    }
    
    .date-value {
      font-size: 1.3rem;
      font-weight: bold;
      color: #202124;
    }
    
    /* Print Styles */
    @media print {
      body {
        background: white;
        padding: 0;
      }
      
      .certificate-container {
        box-shadow: none;
        padding: 60px 40px;
        border-radius: 0;
      }
      
      .no-print {
        display: none;
      }
    }
    
    /* Download Button */
    .download-section {
      text-align: center;
      margin: 40px 0;
      padding: 30px;
      background: rgba(255, 255, 255, 0.95);
      border-radius: 12px;
      box-shadow: 0 4px 20px rgba(0,0,0,0.1);
    }
    
    .btn-download {
      display: inline-flex;
      align-items: center;
      gap: 12px;
      padding: 16px 40px;
      background: linear-gradient(135deg, #573FD7 0%, #4A34B8 100%);
      color: white;
      border: none;
      border-radius: 8px;
      font-size: 1.1rem;
      font-weight: 600;
      cursor: pointer;
      text-decoration: none;
      transition: all 0.3s ease;
      box-shadow: 0 4px 15px rgba(87, 63, 215, 0.3);
    }
    
    .btn-download:hover {
      transform: translateY(-2px);
      box-shadow: 0 6px 20px rgba(87, 63, 215, 0.4);
    }
    
    .btn-download i {
      font-size: 1.2rem;
    }
  </style>
</head>
<body>
  <div class="certificate-container">
    <!-- Decorative Corners -->
    <div class="corner-decoration corner-top-left"></div>
    <div class="corner-decoration corner-top-right"></div>
    <div class="corner-decoration corner-bottom-left"></div>
    <div class="corner-decoration corner-bottom-right"></div>
    
    <!-- Header -->
    <div class="certificate-header">
      <div class="certificate-logo">QUICK STOP SOLUTION</div>
      <div class="certificate-seal">QSS</div>
      <h1 class="certificate-title">Certificate of Completion</h1>
      <p class="certificate-subtitle">This is to certify that</p>
    </div>
    
    <!-- Body -->
    <div class="certificate-body">
      <p class="certificate-text">has successfully completed the training course</p>
      <div class="trainee-name"><%= enrollment.first_name %> <%= enrollment.last_name %></div>
      <div class="training-name"><%= enrollment.training_title %></div>
    </div>
    
    <!-- Details -->
    <div class="certificate-details">
      <div class="details-row">
        <div class="detail-item">
          <div class="detail-label">Trainee ID</div>
          <div class="detail-value"><%= enrollment.trainee_id || 'N/A' %></div>
        </div>
        <div class="detail-item">
          <div class="detail-label">Completion Date</div>
          <div class="detail-value"><%= new Date(enrollment.enrolled_at).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %></div>
        </div>
      </div>
      
      <% if (testAttempts && testAttempts.length > 0) { %>
        <div class="scores-section">
          <div class="scores-title">Test Scores</div>
          <div class="scores-grid">
            <% testAttempts.forEach(test => { %>
              <div class="score-item">
                <div class="score-label"><%= test.test_type.replace('_', ' ').replace(/\b\w/g, l => l.toUpperCase()) %></div>
                <div class="score-value"><%= parseFloat(test.score).toFixed(1) %>%</div>
              </div>
            <% }); %>
          </div>
        </div>
      <% } %>
      
      <% if (finalGrade && finalGrade.training_grade) { %>
        <div class="final-grade">
          <div class="final-grade-label">Final Grade</div>
          <div class="final-grade-value"><%= parseFloat(finalGrade.training_grade).toFixed(1) %>%</div>
        </div>
      <% } %>
    </div>
    
    <!-- Footer -->
    <div class="certificate-footer">
      <div class="signature">
        <div class="signature-line"></div>
        <div class="signature-name">Administrator</div>
        <div class="signature-title">Authorized Signatory</div>
      </div>
      <div class="certificate-date">
        <div class="date-label">Date Issued</div>
        <div class="date-value"><%= new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %></div>
      </div>
      <div class="signature">
        <div class="signature-line"></div>
        <div class="signature-name">Quick Stop Solution</div>
        <div class="signature-title">Training Provider</div>
      </div>
    </div>
  </div>
  
  <!-- Download Button -->
  <div class="download-section no-print">
    <button class="btn-download" onclick="downloadPDF()">
      <i class="fas fa-download"></i>
      Download as PDF
    </button>
  </div>
  
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
  <script>
    function downloadPDF() {
      const element = document.querySelector('.certificate-container');
      const opt = {
        margin: 0,
        filename: 'Certificate_<%= enrollment.first_name %>_<%= enrollment.last_name %>.pdf',
        image: { type: 'jpeg', quality: 0.98 },
        html2canvas: { 
          scale: 2, 
          useCORS: true,
          logging: false,
          letterRendering: true
        },
        jsPDF: { 
          unit: 'in', 
          format: 'a4', 
          orientation: 'landscape',
          compress: true
        }
      };
      
      const btn = document.querySelector('.btn-download');
      const originalText = btn.innerHTML;
      btn.disabled = true;
      btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Generating PDF...';
      
      html2pdf().set(opt).from(element).save().then(() => {
        btn.disabled = false;
        btn.innerHTML = originalText;
      }).catch((error) => {
        console.error('PDF generation error:', error);
        qssShowError('Error generating PDF. Please try again.');
        btn.disabled = false;
        btn.innerHTML = originalText;
      });
    }
    
    if (window.location.search.includes('print=true')) {
      window.onload = function() {
        window.print();
      };
    }
  </script>
</body>
</html>
