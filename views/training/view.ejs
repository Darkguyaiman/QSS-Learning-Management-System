          <button class="tab-button" onclick="switchTab('aspects')">
            <i class="fas fa-hand-paper"></i> Practical Learning Outcomes
          </button>
        <% } %>
        <% if (['admin', 'trainer'].includes(user.userRole)) { %>
          <button class="tab-button" onclick="switchTab('settings')">
            <i class="fas fa-cog"></i> Settings
          </button>
        <% } %>
      </div>
      
      <!-- Stream Tab -->
      <%- include('./tabs/stream', { training, trainers, trainer, sections }) %>

      <!-- Materials & Tests Tabs (Trainee only) -->
      <% if (user.userRole === 'trainee') { %>
        <%- include('./tabs/materials', { training, sections }) %>
        <%- include('./tabs/tests', { training, user, trainingTests, enrollment }) %>
      <% } %>
      
      <!-- Course Tab -->
      <%- include('./tabs/coursework', { training, user, sections, trainingTests, enrollment, trainingMedia }) %>
      
      <!-- People Tab -->
      <%- include('./tabs/people', { trainers, trainer, enrolledTrainees }) %>
      
      <!-- Results Tab (Trainee Only - After Score Release) -->
      <% if (user.userRole === 'trainee' && enrollment && enrollment.can_download_results) { %>
        <%- include('./tabs/results', { user, training, enrollment, marksData }) %>
      <% } %>
      
      <!-- Marks Tab (Admin/Trainer Only) -->
      <%- include('./tabs/marks', { user, training, marksData, aspects }) %>
      
      <!-- Attendance Tab (Admin/Trainer Only) -->
      <%- include('./tabs/attendance', { user, attendanceData, training }) %>

      <!-- Package Tab (Admin/Trainer Only, Locked Training Only) -->
      <% if (['admin', 'trainer'].includes(user.userRole) && training.is_locked) { %>
        <%- include('./tabs/package', { user, training, attendanceData, marksData, allDeviceModels, allHealthcare, trainingHealthcare }) %>
      <% } %>
      
      <!-- Practical Learning Outcomes Tab (Main Training, Admin Only) -->
      <%- include('./tabs/aspects', { training, user, aspects }) %>
      
