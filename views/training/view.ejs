        </button>
        <button class="tab-button" onclick="switchTab('people')">
          <i class="fas fa-users"></i> People (<%= enrolledTrainees.length + (typeof trainers !== 'undefined' ? trainers.length : 1) %>)
        </button>
        <% if (user.userRole === 'trainee' && enrollment && enrollment.can_download_results) { %>
          <button class="tab-button" onclick="switchTab('results')">
