# Copy to .env and set your values

# Default password for seeded users (admin@lms.com, trainer@lms.com)
SEED_PASSWORD=1234567890

# Server
PORT=3000
NODE_ENV=development
# Public URL used in notification emails. Leave blank to omit direct links.
# APP_BASE_URL=http://localhost:3000
# Use a long random string in production (e.g. openssl rand -hex 32)
SESSION_SECRET=change-me-in-production
# Session cookie name
SESSION_COOKIE_NAME=lms.sid
# Session max age in hours
SESSION_MAX_AGE_HOURS=24
# Force secure cookies (true/false). Leave unset to auto-enable in production.
# SESSION_COOKIE_SECURE=true
# Session table name (optional)
# SESSION_TABLE=sessions

# Database (optional; defaults shown)
# DB_HOST=localhost
# DB_USER=root
# DB_PASSWORD=password

# SMTP email notifications
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
# Keep true in production. Set false only for local/dev SMTP servers with self-signed or expired certificates.
SMTP_TLS_REJECT_UNAUTHORIZED=true
SMTP_USER=
SMTP_PASSWORD=
# Must be an address/domain accepted by your SMTP provider, usually the same as SMTP_USER.
SMTP_FROM=

# CRM API
# CRM_API_KEY=your-api-key

# CRM webhook hub
CRM_WEBHOOK_ENDPOINT=https://webhookhub.quickstopsolution.com/
CRM_WEBHOOK_SOURCE_SYSTEM=LMS

WEBHOOK_USERNAME=webhook_user
WEBHOOK_PASSWORD=webhook_password

# Local LMS receiver endpoint for testing incoming CRM callbacks
LOCAL_WEBHOOK_ENDPOINT=http://localhost:3000/webhook
